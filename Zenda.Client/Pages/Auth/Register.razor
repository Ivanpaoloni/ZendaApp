@page "/register"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@using System.Timers
@using Microsoft.AspNetCore.Components.Authorization
@using Zenda.Application.DTOs.Auth
@using Zenda.Client.Auth
@inject HttpClient Http
@inject NavigationManager Nav
@implements IDisposable
@inject AuthenticationStateProvider AuthProvider
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage

<div class="max-w-xl mx-auto mt-8 mb-12 p-8 bg-white rounded-[2.5rem] border border-surface-container-high shadow-sm">
    <div class="text-center mb-8">
        <h2 class="text-3xl font-bold text-primary tracking-tighter font-headline mb-2">Empezá con Zenda</h2>
        <p class="text-on-surface-variant text-sm px-4">Creá tu cuenta de administrador y configurá tu primer negocio en segundos.</p>
    </div>

    <EditForm Model="@regModel" OnValidSubmit="HandleRegister">
        <DataAnnotationsValidator />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            @* Datos Personales *@
            <div class="flex flex-col gap-2">
                <label class="text-[10px] font-black text-primary/50 tracking-widest uppercase px-1">Nombre</label>
                <input @bind-value="regModel.Nombre" class="input-zenda" placeholder="Ej: Ivan" required />
            </div>
            <div class="flex flex-col gap-2">
                <label class="text-[10px] font-black text-primary/50 tracking-widest uppercase px-1">Apellido</label>
                <input @bind-value="regModel.Apellido" class="input-zenda" placeholder="Ej: Pérez" required />
            </div>

            @* Credenciales *@
            <div class="md:col-span-2 flex flex-col gap-2">
                <label class="text-[10px] font-black text-primary/50 tracking-widest uppercase px-1">Email Profesional</label>
                <input type="email" @bind-value="regModel.Email" class="input-zenda" placeholder="hola@tuempresa.com" required />
            </div>

            @* Datos del Negocio *@
            <div class="md:col-span-2 p-4 bg-secondary-container/20 rounded-3xl border border-primary/5 mt-2">
                <p class="text-xs font-bold text-primary mb-4 text-center">INFORMACIÓN DEL NEGOCIO</p>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

                    @* NUEVO: Selector de Rubro *@
                    <div class="md:col-span-2 flex flex-col gap-2">
                        <label class="text-[10px] font-black text-primary/50 tracking-widest uppercase px-1">¿A qué se dedica tu negocio?</label>
                        <select @bind="regModel.RubroId" class="input-zenda bg-white cursor-pointer" required>
                            <option value="" disabled selected>Seleccioná un rubro...</option>
                            @foreach (var rubro in rubrosDisponibles)
                            {
                                <option value="@rubro.Id">@rubro.Nombre</option>
                            }
                        </select>
                    </div>

                    <div class="flex flex-col gap-2">
                        <label class="text-[10px] font-black text-primary/50 tracking-widest uppercase px-1">Nombre del Local</label>
                        <input value="@regModel.NombreNegocio" @oninput="OnNombreNegocioInput"
                               class="input-zenda bg-white" placeholder="Ej: Barbería Zenda" required />
                    </div>

                    <div class="flex flex-col gap-2">
                        <label class="text-[10px] font-black text-primary/50 tracking-widest uppercase px-1">URL (Slug)</label>
                        <div class="relative flex items-center">
                            <input value="@regModel.SlugNegocio" @oninput="OnSlugInput"
                                   class="input-zenda bg-white pr-10 @(slugDisponible == false ? "border-error/40" : "")"
                                   placeholder="ej-barberia-zenda" required />

                            <div class="absolute right-4 flex items-center">
                                @if (validandoSlug)
                                {
                                    <div class="animate-spin rounded-full h-4 w-4 border-t-2 border-b-2 border-primary"></div>
                                }
                                else if (slugDisponible == true)
                                {
                                    <span class="material-symbols-outlined text-green-600 text-[20px] font-bold">check_circle</span>
                                }
                                else if (slugDisponible == false)
                                {
                                    <span class="material-symbols-outlined text-error text-[20px] font-bold">cancel</span>
                                }
                            </div>
                        </div>

                        @if (slugDisponible == false)
                        {
                            <p class="text-error text-[10px] font-bold px-1 animate-in fade-in slide-in-from-top-1">
                                Este nombre ya está en uso. Elegí otro.
                            </p>
                        }
                    </div>
                </div>
            </div>

            <div class="md:col-span-2 flex flex-col gap-2">
                <label class="text-[10px] font-black text-primary/50 tracking-widest uppercase px-1">Contraseña</label>
                <input type="password" @bind-value="regModel.Password" class="input-zenda" placeholder="Mínimo 6 caracteres" required />
            </div>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="mt-6 p-4 rounded-2xl bg-error/10 text-error text-xs font-bold border border-error/20">
                @errorMessage
            </div>
        }

        <button type="submit" disabled="@isSubmitting"
                class="w-full mt-8 py-4 bg-primary text-white font-bold rounded-[1.5rem] shadow-xl shadow-primary/20 hover:scale-[1.02] active:scale-[0.98] transition-all disabled:opacity-50">
            @if (isSubmitting)
            {
                <span class="animate-pulse">Creando cuenta...</span>
            }
            else
            {

                <span>Registrar mi negocio</span>
            }
        </button>
    </EditForm>
</div>

<style>
    .input-zenda {
        width: 100%;
        padding: 0.85rem 1.25rem;
        border-radius: 1.25rem;
        background-color: #f1f5f0; /* secondary-container/30 */
        border: 2px solid transparent;
        font-size: 0.9rem;
        transition: all 0.2s;
        outline: none;
    }

        .input-zenda:focus {
            border-color: #166534; /* primary */
            background-color: white;
            box-shadow: 0 4px 12px rgba(22, 101, 52, 0.05);
        }
</style>

@code {
    [Inject] protected NegocioClient NegocioService { get; set; } = default!;

    private RegisterOwnerDto regModel = new();
    private string errorMessage = "";
    private bool isSubmitting = false;

    // Lógica de validación de Slug
    private System.Timers.Timer? debounceTimer;
    private bool validandoSlug = false;
    private bool? slugDisponible = null;
    private bool slugEditadoManualmente = false;

    // NUEVO: Lista hardcodeada para el MVP
    private List<RubroOption> rubrosDisponibles = new()
    {
        new RubroOption { Id = Guid.Parse("11111111-1111-1111-1111-111111111111"), Nombre = "Barbería" },
        new RubroOption { Id = Guid.Parse("22222222-2222-2222-2222-222222222222"), Nombre = "Peluquería" },
        new RubroOption { Id = Guid.Parse("33333333-3333-3333-3333-333333333333"), Nombre = "Centro de Estética" },
        new RubroOption { Id = Guid.Parse("44444444-4444-4444-4444-444444444444"), Nombre = "Manicura y Pedicura" }
    };

    // Clase auxiliar simple para no crear un archivo DTO extra en el frontend por ahora
    private class RubroOption
    {
        public Guid Id { get; set; }
        public string Nombre { get; set; } = "";
    }

    protected override void OnInitialized()
    {
        debounceTimer = new System.Timers.Timer(600);
        debounceTimer.Elapsed += ValidarSlugEnApi;
        debounceTimer.AutoReset = false;
    }

    private void OnNombreNegocioInput(ChangeEventArgs e)
    {
        var nombre = e.Value?.ToString() ?? "";
        regModel.NombreNegocio = nombre;

        if (!slugEditadoManualmente)
        {
            var sugerenciaSlug = nombre.ToLower().Trim().Replace(" ", "-");
            ActualizarSlug(sugerenciaSlug);
        }
    }

    private void OnSlugInput(ChangeEventArgs e)
    {
        slugEditadoManualmente = true;
        ActualizarSlug(e.Value?.ToString() ?? "");
    }

    private void ActualizarSlug(string valor)
    {
        regModel.SlugNegocio = valor.ToLower().Replace(" ", "-");

        debounceTimer?.Stop();

        if (string.IsNullOrWhiteSpace(regModel.SlugNegocio))
        {
            slugDisponible = null;
            return;
        }

        validandoSlug = true;
        slugDisponible = null;
        debounceTimer?.Start();
    }

    private async void ValidarSlugEnApi(object? sender, ElapsedEventArgs e)
    {
        try
        {
            var isFree = await NegocioService.ValidarSlugDisponible(regModel.SlugNegocio);
            slugDisponible = isFree;
        }
        catch
        {
            slugDisponible = false;
        }
        finally
        {
            validandoSlug = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task HandleRegister()
    {
        // 1. Validación del Rubro (la que ya tenías)
        if (regModel.RubroId == Guid.Empty)
        {
            errorMessage = "Por favor, seleccioná a qué se dedica tu negocio.";
            return;
        }

        if (slugDisponible == false || validandoSlug) return;

        isSubmitting = true;
        errorMessage = "";

        try
        {
            // 2. Llamada al endpoint (que ahora devuelve el Token)
            var response = await Http.PostAsJsonAsync("api/auth/register-owner", regModel);
            var result = await response.Content.ReadFromJsonAsync<AuthResponseDto>();

            if (result!.Success && !string.IsNullOrEmpty(result.Token))
            {
                // --- LÓGICA DE AUTO-LOGIN ---

                // 3. Guardamos el token en LocalStorage
                await LocalStorage.SetItemAsync("authToken", result.Token);

                // 4. Notificamos al Provider (Casteamos a tu clase custom)
                ((CustomAuthStateProvider)AuthProvider).NotifyUserAuthentication(result.Token);

                // 5. Redirigimos al Dashboard (o al home)
                // Uso forceLoad: true para asegurar que todos los servicios se reinicien con el nuevo contexto
                Nav.NavigateTo("/", forceLoad: true);
            }
            else
            {
                errorMessage = result.Message;
            }
        }
        catch
        {
            errorMessage = "Error de conexión con la API.";
        }
        finally
        {
            isSubmitting = false;
        }
    }
    public void Dispose()
    {
        debounceTimer?.Dispose();
    }
}