@page "/olvide-contrasena"
@layout EmptyLayout
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@using Zenda.Application.DTOs.Auth
@inject HttpClient Http

<div class="max-w-md mx-auto mt-16 p-8 bg-white rounded-[2.5rem] border border-surface-container-high shadow-sm">
    <div class="text-center mb-8">
        <h2 class="text-3xl font-bold text-primary tracking-tighter font-headline mb-2">Recuperá tu acceso</h2>
        <p class="text-on-surface-variant text-sm px-4">Ingresá tu email y te enviaremos un enlace para crear una nueva contraseña.</p>
    </div>

    @if (correoEnviado)
    {
        <div class="p-6 bg-secondary-container/20 rounded-3xl border border-primary/10 text-center">
            <span class="material-symbols-outlined text-primary text-4xl mb-2">mark_email_read</span>
            <h3 class="font-bold text-primary mb-2">¡Revisá tu bandeja!</h3>
            <p class="text-xs text-on-surface-variant">Si el correo <b>@requestModel.Email</b> está registrado, te llegará un enlace en los próximos minutos.</p>
            <a href="/login" class="block mt-6 text-sm font-bold text-primary hover:underline">Volver al login</a>
        </div>
    }
    else
    {
        <EditForm Model="@requestModel" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            <div class="flex flex-col gap-2 mb-6">
                <label class="text-[10px] font-black text-primary/50 tracking-widest uppercase px-1">Email Profesional</label>
                <input type="email" @bind-value="requestModel.Email" class="input-zenda" placeholder="hola@tuempresa.com" required />
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="mb-6 p-4 rounded-2xl bg-error/10 text-error text-xs font-bold border border-error/20">
                    @errorMessage
                </div>
            }

            <button type="submit" disabled="@isSubmitting"
                    class="w-full py-4 bg-primary text-white font-bold rounded-[1.5rem] shadow-xl shadow-primary/20 hover:scale-[1.02] active:scale-[0.98] transition-all disabled:opacity-50">
                @if (isSubmitting)
                {
                    <span class="animate-pulse">Enviando...</span>
                }
                else
                {
                    <span>Enviar enlace de recuperación</span>
                }
            </button>
        </EditForm>
        <div class="text-center mt-6">
            <a href="/login" class="text-xs text-primary font-bold hover:underline">Volver al login</a>
        </div>
    }
</div>

<style>
    /* Asegurate de tener la clase .input-zenda en tu CSS global o copiala acá igual que en Register */
</style>

@code {
    private ForgotPasswordRequest requestModel = new();
    private bool isSubmitting = false;
    private bool correoEnviado = false;
    private string errorMessage = "";

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        errorMessage = "";

        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/forgot-password", requestModel);
            var result = await response.Content.ReadFromJsonAsync<AuthResponseDto>();

            if (result != null && result.Success)
            {
                correoEnviado = true;
            }
            else
            {
                errorMessage = result?.Message ?? "Error al procesar la solicitud.";
            }
        }
        catch
        {
            errorMessage = "Error de conexión con el servidor.";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}