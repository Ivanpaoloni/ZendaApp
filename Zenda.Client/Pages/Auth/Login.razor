@page "/login"
@layout AuthLayout
@using Microsoft.AspNetCore.Components.Authorization
@using Zenda.Application.DTOs.Auth
@using Zenda.Client.Auth
@inject HttpClient Http
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthProvider
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage

@if (verificandoSesion)
{
    <div class="flex justify-center py-12">
        <div class="animate-spin rounded-full h-8 w-8 border-t-2 border-b-2 border-primary"></div>
    </div>
}
else
{
    <div class="max-w-md mx-auto p-8 bg-white rounded-[2rem] border border-surface-container-high shadow-sm">
        <div class="text-center mb-8">
            <h2 class="text-3xl font-bold text-primary tracking-tighter font-headline mb-2">Bienvenido a Zendy</h2>
            <p class="text-on-surface-variant text-sm">Ingresá tus credenciales para gestionar tu negocio</p>
        </div>

        <EditForm Model="@loginModel" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />

            <div class="space-y-6">
                @* Email *@
                <div class="flex flex-col gap-2">
                    <label class="text-xs font-bold text-primary px-1">EMAIL</label>
                    <input type="email" @bind-value="loginModel.Email"
                           class="w-full px-4 py-3 rounded-2xl bg-secondary-container/30 border-none focus:ring-2 focus:ring-primary transition-all outline-none"
                           placeholder="ejemplo@correo.com" required />
                </div>

                @* Password *@
                <div class="flex flex-col gap-2">
                    <label class="text-xs font-bold text-primary px-1">CONTRASEÑA</label>
                    <input type="password" @bind-value="loginModel.Password"
                           class="w-full px-4 py-3 rounded-2xl bg-secondary-container/30 border-none focus:ring-2 focus:ring-primary transition-all outline-none"
                           placeholder="••••••••" required />
                </div>
                <div class="flex justify-end mt-1 mb-4">
                    <a href="/olvide-contrasena" class="text-xs text-primary font-bold hover:underline">¿Olvidaste tu contraseña?</a>
                </div>
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="p-3 rounded-xl bg-error/10 text-error text-xs font-bold flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm">error</span>
                        @errorMessage
                    </div>
                }

                <button type="submit" disabled="@isSubmitting"
                        class="w-full py-4 bg-primary text-white font-bold rounded-2xl shadow-lg shadow-primary/20 hover:bg-primary/90 active:scale-[0.98] transition-all disabled:opacity-50">
                    @if (isSubmitting)
                    {
                        <span class="animate-pulse">Iniciando sesión...</span>
                    }
                    else
                    {
                        <span>Entrar al Panel</span>
                    }
                </button>
            </div>
        </EditForm>

        <div class="mt-8 text-center">
            <p class="text-sm text-on-surface-variant">
                ¿Aún no tenés tu cuenta?
                <NavLink href="register" class="text-primary font-bold hover:underline">Creá tu cuenta gratis</NavLink>
            </p>
        </div>
    </div>
}
@code {
    private LoginDto loginModel = new();
    private string errorMessage = "";
    private bool isSubmitting = false;
    private bool verificandoSesion = true;

    protected override async Task OnInitializedAsync()
    {
        // 1. Preguntamos el estado actual
        var authState = await AuthProvider.GetAuthenticationStateAsync();

        // 2. Si ya tiene un token válido y está logueado...
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            // Lo pateamos directo al inicio de la app.
            // (Recordá que tu MainLayout ya se encarga de enviarlo a /admin si es SuperAdmin)
            Nav.NavigateTo("/");
            return;
        }

        // 3. Si no está logueado, apagamos la carga y mostramos el form
        verificandoSesion = false;
    }
    private async Task HandleLogin()
    {
        isSubmitting = true;
        errorMessage = "";

        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/login", loginModel);
            var result = await response.Content.ReadFromJsonAsync<AuthResponseDto>();

            if (result!.Success && !string.IsNullOrEmpty(result.Token))
            {
                // 1. Guardamos el token
                await LocalStorage.SetItemAsync("authToken", result.Token);

                // 2. Avisamos al Provider para que refresque la UI
                ((CustomAuthStateProvider)AuthProvider).NotifyUserAuthentication(result.Token);

                // 3. Redirigimos al inicio o agenda
                Nav.NavigateTo("/", forceLoad: true);
            }
            else
            {
                errorMessage = result.Message;
            }
        }
        catch (Exception)
        {
            errorMessage = "No se pudo conectar con el servidor.";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}