@page "/restablecer-contrasena"
@layout EmptyLayout
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@using Zenda.Application.DTOs.Auth
@inject HttpClient Http
@inject NavigationManager Nav

<div class="max-w-md mx-auto mt-16 p-8 bg-white rounded-[2.5rem] border border-surface-container-high shadow-sm">
    <div class="text-center mb-8">
        <h2 class="text-3xl font-bold text-primary tracking-tighter font-headline mb-2">Nueva Contraseña</h2>
        <p class="text-on-surface-variant text-sm px-4">Ingresá tu nueva clave para tu negocio.</p>
    </div>

    @if (exito)
    {
        <div class="p-6 bg-secondary-container/20 rounded-3xl border border-primary/10 text-center">
            <span class="material-symbols-outlined text-green-600 text-4xl mb-2">check_circle</span>
            <h3 class="font-bold text-primary mb-2">¡Contraseña actualizada!</h3>
            <p class="text-xs text-on-surface-variant">Ya podés ingresar a tu cuenta con tu nueva clave.</p>
            <a href="/login" class="block mt-6 py-3 bg-primary text-white font-bold rounded-xl text-sm">Ir a Iniciar Sesión</a>
        </div>
    }
    else
    {
        <EditForm Model="@requestModel" OnValidSubmit="HandleSubmit">
            
            <div class="flex flex-col gap-4 mb-6">
                <div class="flex flex-col gap-2">
                    <label class="text-[10px] font-black text-primary/50 tracking-widest uppercase px-1">Nueva Contraseña</label>
                    <input type="password" @bind-value="requestModel.NewPassword" class="input-zenda" placeholder="Mínimo 6 caracteres" required />
                </div>
                
                <div class="flex flex-col gap-2">
                    <label class="text-[10px] font-black text-primary/50 tracking-widest uppercase px-1">Repetir Contraseña</label>
                    <input type="password" @bind-value="repetirPassword" class="input-zenda" placeholder="Escribila de nuevo" required />
                </div>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="mb-6 p-4 rounded-2xl bg-error/10 text-error text-xs font-bold border border-error/20">
                    @errorMessage
                </div>
            }

            <button type="submit" disabled="@isSubmitting"
                    class="w-full py-4 bg-primary text-white font-bold rounded-[1.5rem] shadow-xl shadow-primary/20 hover:scale-[1.02] active:scale-[0.98] transition-all disabled:opacity-50">
                @if (isSubmitting)
                {
                    <span class="animate-pulse">Guardando...</span>
                }
                else
                {
                    <span>Guardar contraseña</span>
                }
            </button>
        </EditForm>
    }
</div>

@code {
    [SupplyParameterFromQuery]
    public string Email { get; set; } = string.Empty;

    [SupplyParameterFromQuery]
    public string Token { get; set; } = string.Empty;

    private ResetPasswordRequest requestModel = new();
    private string repetirPassword = string.Empty;
    
    private bool isSubmitting = false;
    private bool exito = false;
    private string errorMessage = "";

    protected override void OnInitialized()
    {
        // Validamos que lleguen los parámetros mínimos
        if (string.IsNullOrEmpty(Email) || string.IsNullOrEmpty(Token))
        {
            errorMessage = "El enlace de recuperación no es válido o está incompleto.";
        }
        else
        {
            requestModel.Email = Email;
            requestModel.Token = Token;
        }
    }

    private async Task HandleSubmit()
    {
        if (requestModel.NewPassword != repetirPassword)
        {
            errorMessage = "Las contraseñas no coinciden.";
            return;
        }

        if (string.IsNullOrEmpty(Token)) return;

        isSubmitting = true;
        errorMessage = "";

        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/reset-password", requestModel);
            var result = await response.Content.ReadFromJsonAsync<AuthResponseDto>();

            if (result != null && result.Success)
            {
                exito = true;
            }
            else
            {
                errorMessage = result?.Message ?? "No se pudo restablecer la contraseña. El enlace puede haber expirado.";
            }
        }
        catch
        {
            errorMessage = "Error de conexión con el servidor.";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}