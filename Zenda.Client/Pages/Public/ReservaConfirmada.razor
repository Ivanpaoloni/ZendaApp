@page "/reserva-confirmada"
@layout EmptyLayout
@inject NavigationManager Nav

<div class="min-h-screen bg-surface-container-low flex items-center justify-center p-4">
    <div class="max-w-md w-full bg-white rounded-[2.5rem] editorial-shadow p-6 sm:p-8 text-center animate-in zoom-in-95 duration-500">

        <div class="w-16 h-16 bg-green-100 text-green-600 rounded-full flex items-center justify-center mx-auto mb-3 animate-bounce">
            <span class="material-symbols-outlined text-4xl">check_circle</span>
        </div>
        <h1 class="text-2xl font-headline font-extrabold text-primary mb-1">
            ¡Turno Confirmado!
        </h1>
        <p class="text-on-surface-variant text-sm font-body mb-5">
            Tu reserva ha sido procesada con éxito.
        </p>

        <div class="bg-surface-container-low rounded-2xl p-4 mb-5 space-y-3 text-left border border-surface-container-high">
            <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-primary/60 text-xl">calendar_today</span>
                <div>
                    <p class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant leading-none mb-1">Fecha y Hora</p>
                    <p class="font-headline font-bold text-primary text-sm leading-none">@FechaDisplay - @HoraDisplay hs</p>
                </div>
            </div>

            <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-primary/60 text-xl">person</span>
                <div>
                    <p class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant leading-none mb-1">Profesional</p>
                    <p class="font-headline font-bold text-primary text-sm leading-none">@NombrePrestador</p>
                </div>
            </div>
        </div>

        <div class="flex items-center justify-center gap-3 mb-6">
            @if (!string.IsNullOrEmpty(DireccionSede))
            {
                <a href="@GenerarGoogleMapsUrl()" target="_blank"
                   class="flex-1 py-3 px-2 bg-orange-500/10 text-orange-700 rounded-2xl flex flex-col items-center justify-center gap-1 hover:bg-orange-500/20 transition-all">
                    <span class="material-symbols-outlined text-2xl">map</span>
                    <span class="text-[10px] font-bold uppercase tracking-wider">Mapa</span>
                </a>
            }

            <a href="@GenerarGoogleCalendarUrl()" target="_blank"
               class="flex-1 py-3 px-2 bg-primary/5 text-primary rounded-2xl flex flex-col items-center justify-center gap-1 hover:bg-primary/10 transition-all">
                <span class="material-symbols-outlined text-2xl">calendar_add_on</span>
                <span class="text-[10px] font-bold uppercase tracking-wider">Agendar</span>
            </a>

            <a href="@GenerarWhatsAppUrl()" target="_blank"
               class="flex-1 py-3 px-2 bg-[#25D366]/10 text-[#075E54] rounded-2xl flex flex-col items-center justify-center gap-1 hover:bg-[#25D366] hover:text-white transition-all group">
                <i class="fa-brands fa-whatsapp text-2xl group-hover:text-white"></i>
                <span class="text-[10px] font-bold uppercase tracking-wider">WhatsApp</span>
            </a>
        </div>

        <div class="flex flex-col gap-4">
            <button @onclick='() => Nav.NavigateTo("/")'
                    class="w-full py-3.5 bg-primary text-on-primary rounded-xl font-headline font-bold text-sm hover:brightness-110 active:scale-95 transition-all shadow-md">
                Volver al inicio
            </button>

            @if (!string.IsNullOrEmpty(TurnoId))
            {
                <a href="/gestionar-turno?id=@TurnoId" class="text-xs font-bold text-error/80 hover:text-error underline">
                    Me equivoqué, cancelar reserva
                </a>
            }
        </div>

    </div>
</div>
@code {
    [Parameter, SupplyParameterFromQuery] public string? Fecha { get; set; }
    [Parameter, SupplyParameterFromQuery] public string? Hora { get; set; }
    [Parameter, SupplyParameterFromQuery] public string? Nombre { get; set; }
    [Parameter, SupplyParameterFromQuery] public string? Duracion { get; set; }
    [Parameter, SupplyParameterFromQuery] public string? Direccion { get; set; }
    [Parameter, SupplyParameterFromQuery] public string? TurnoId { get; set; }
    private string DireccionSede => Direccion ?? "";
    private string FechaDisplay => Fecha ?? "--/--/----";
    private string HoraDisplay => Hora ?? "--:--";
    private string NombrePrestador => Nombre ?? "Profesional";

    private string GenerarGoogleMapsUrl()
    {
        if (string.IsNullOrEmpty(DireccionSede)) return "#";

        // Le concatenamos el contexto geográfico para que Google no se pierda
        // "Bogotá 2240, Flores, CABA, Argentina"
        var direccionCompleta = $"{DireccionSede}, Argentina";

        return $"https://www.google.com/maps/search/?api=1&query={Uri.EscapeDataString(direccionCompleta)}";
    }

    private string GenerarGoogleCalendarUrl()
    {
        try
        {
            var titulo = Uri.EscapeDataString($"Turno en Zenda: {NombrePrestador}");
            var detalles = Uri.EscapeDataString("¡No faltes! Tu reserva está confirmada en Zenda.");

            // Parseamos la fecha (espera dd/MM/yyyy)
            var partesFecha = FechaDisplay.Split('/');
            var partesHora = HoraDisplay.Split(':');

            // Formato Google: YYYYMMDDTHHmmSS
            // Armamos el inicio
            var inicioStr = $"{partesFecha[2]}{partesFecha[1]}{partesFecha[0]}T{partesHora[0]}{partesHora[1]}00";

            // Calculamos el fin sumando la duración
            if (!int.TryParse(Duracion, out var minutos)) minutos = 30;

            // Usamos DateTime para calcular el fin correctamente (por si pasa de hora)
            var fechaBase = new DateTime(int.Parse(partesFecha[2]), int.Parse(partesFecha[1]), int.Parse(partesFecha[0]),
                                         int.Parse(partesHora[0]), int.Parse(partesHora[1]), 0);
            var fechaFin = fechaBase.AddMinutes(minutos);
            var finStr = fechaFin.ToString("yyyyMMddTHHmmss");

            return $"https://www.google.com/calendar/render?action=TEMPLATE&text={titulo}&dates={inicioStr}/{finStr}&details={detalles}&sf=true&output=xml";
        }
        catch
        {
            return "#";
        }
    }

    private string GenerarWhatsAppUrl()
    {
        // El mensaje que aparecerá en el chat
        var mensaje = $"¡Hola! Confirmo mi turno en Zenda:%0A" +
                      $"*Profesional:* {NombrePrestador}%0A" +
                      $"*Fecha:* {FechaDisplay}%0A" +
                      $"*Hora:* {HoraDisplay} hs%0A" +
                      $"¡Nos vemos pronto!";

        // Si tenés el celular del barbero, podés ponerlo acá (ej: 54911...)
        // Si lo dejás vacío, abre el selector de contactos para que el cliente elija a quién mandárselo.
        return $"https://wa.me/?text={mensaje}";
    }
}