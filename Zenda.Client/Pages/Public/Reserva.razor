@page "/{NegocioSlug}"
@layout EmptyLayout
@using Zenda.Client.Components
@using Zenda.Core.DTOs

<div class="min-h-screen bg-surface-container-low pb-20">

    @if (pasoActual == PasoReserva.Cargando)
    {
        <div class="min-h-screen flex justify-center items-center">
            <div class="animate-spin rounded-full h-12 w-12 border-t-4 border-b-4 border-primary"></div>
        </div>
    }
    else if (pasoActual == PasoReserva.NoEncontrado || negocio == null)
    {
        <NotFoundUI />
    }
    else if (negocio == null)
    {
        <NotFoundUI />
    }
    else
    {
        <div class="bg-white p-8 rounded-b-[3rem] editorial-shadow mb-8 text-center animate-in slide-in-from-top duration-700 relative overflow-hidden">
            <div class="relative z-10">
                @if (!string.IsNullOrEmpty(negocio.LogoUrl))
                {
                    <div class="w-24 h-24 md:w-28 md:h-28 mx-auto mb-4 relative">
                        <img src="@negocio.LogoUrl" alt="Logo de @negocio.Nombre" 
                             class="w-full h-full rounded-full object-cover border-4 border-white shadow-lg" />
                    </div>
                }
                else
                {
                    <div class="w-20 h-20 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4 border-4 border-white shadow-sm">
                        <span class="font-headline font-black text-4xl text-primary">
                            @(negocio.Nombre.FirstOrDefault())
                        </span>
                    </div>
                }

                <h1 class="text-3xl font-headline font-extrabold text-primary">@negocio.Nombre</h1>
                <p class="text-on-surface-variant font-body text-sm mt-1">
                    @ObtenerTextoPaso()
                </p>
            </div>
        </div>

        <div class="max-w-md mx-auto px-6">
            @if (pasoActual == PasoReserva.SeleccionarSede)
            {
                <div class="space-y-4 animate-in fade-in slide-in-from-bottom-4 duration-500">
                    @foreach (var sede in sedesDisponibles)
                    {
                        <button @onclick="() => SeleccionarSede(sede)"
                                class="w-full bg-white p-6 rounded-3xl editorial-shadow flex items-center gap-4 hover:border-primary border-2 border-transparent transition-all text-left group">
                            <div class="w-12 h-12 rounded-2xl bg-surface-container-low text-primary flex items-center justify-center group-hover:bg-primary/10 transition-colors">
                                <span class="material-symbols-outlined">location_on</span>
                            </div>
                            <div class="flex-grow">
                                <h3 class="font-headline font-bold text-lg text-primary">@sede.Nombre</h3>
                                <p class="text-xs text-on-surface-variant">@sede.Direccion</p>
                            </div>
                            <span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary transition-colors">arrow_forward</span>
                        </button>
                    }
                </div>
            }

            @if (pasoActual == PasoReserva.SeleccionarServicio)
            {
                <div class="space-y-4 animate-in fade-in slide-in-from-bottom-4 duration-500">
                    @if (sedesDisponibles.Count > 1)
                    {
                        <button @onclick="VolverASedes" class="text-[10px] font-bold uppercase tracking-widest text-primary hover:underline flex items-center gap-1 mb-4">
                            <span class="material-symbols-outlined text-xs">arrow_back</span> Cambiar Sede
                        </button>
                    }

                    @if (!serviciosDeSede.Any())
                    {
                        <p class="text-center text-on-surface-variant p-6 border-2 border-dashed border-surface-container-high rounded-3xl">
                            No hay servicios disponibles en esta sede.
                        </p>
                    }
                    else
                    {
                        @foreach (var categoria in serviciosDeSede.GroupBy(s => s.CategoriaNombre))
                        {
                            <div class="mb-6">
                                <h4 class="text-[10px] font-black tracking-widest uppercase text-on-surface-variant ml-2 mb-2">@categoria.Key</h4>
                                <div class="space-y-3">
                                    @foreach (var servicio in categoria)
                                    {
                                        <button @onclick="() => SeleccionarServicio(servicio)"
                                                class="w-full bg-white p-4 rounded-[2rem] editorial-shadow flex items-center justify-between hover:border-primary border-2 border-transparent transition-all text-left group">
                                            <div>
                                                <h3 class="font-bold text-sm text-primary group-hover:text-primary transition-colors">@servicio.Nombre</h3>
                                                <p class="text-xs text-on-surface-variant flex items-center gap-1 mt-1">
                                                    <span class="material-symbols-outlined text-[14px]">schedule</span> @servicio.DuracionMinutos min
                                                </p>
                                            </div>
                                            <div class="flex items-center gap-3">
                                                <span class="font-headline font-black text-primary text-sm">@servicio.Precio.ToString("C0")</span>
                                                <span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary transition-colors">arrow_forward</span>
                                            </div>
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            }

            @if (pasoActual == PasoReserva.SeleccionarPrestador)
            {
                <div class="space-y-4 animate-in fade-in slide-in-from-bottom-4 duration-500">
                    <button @onclick="VolverAServicios" class="text-[10px] font-bold uppercase tracking-widest text-primary hover:underline flex items-center gap-1 mb-4">
                        <span class="material-symbols-outlined text-xs">arrow_back</span> Cambiar Servicio
                    </button>

                    <div class="bg-primary/5 p-4 rounded-2xl flex items-center gap-3 border border-primary/10 mb-6">
                        <span class="material-symbols-outlined text-primary">cut</span>
                        <p class="text-xs font-body text-primary">
                            Elegiste <strong>@servicioSeleccionado?.Nombre</strong>. ¿Con quién te atendés?
                        </p>
                    </div>

                    @if (!prestadoresFiltrados.Any())
                    {
                        <div class="bg-white/50 p-6 rounded-3xl border border-dashed border-outline-variant text-center">
                            <p class="text-sm text-on-surface-variant">Ningún profesional realiza este servicio en esta sede.</p>
                        </div>
                    }
                    else
                    {
                        <div class="grid grid-cols-2 gap-4">
                            <button @onclick="() => SeleccionarPrestador(null)"
                                    class="bg-white p-6 rounded-3xl editorial-shadow flex flex-col items-center justify-center text-center hover:border-primary border-2 border-transparent transition-all group h-full">
                                <div class="w-14 h-14 rounded-full bg-secondary-container text-on-secondary-container flex items-center justify-center mb-3 group-hover:scale-110 transition-transform">
                                    <span class="material-symbols-outlined text-2xl">group</span>
                                </div>
                                <h3 class="font-headline font-bold text-sm text-primary">Cualquiera</h3>
                                <p class="text-[10px] text-on-surface-variant mt-1">El primero libre</p>
                            </button>

                            @foreach (var prestador in prestadoresFiltrados)
                            {
                                <button @onclick="() => SeleccionarPrestador(prestador)"
                                        class="bg-white p-6 rounded-3xl editorial-shadow flex flex-col items-center justify-center text-center hover:border-primary border-2 border-transparent transition-all group">
                                    <div class="w-14 h-14 rounded-full bg-surface-container-low text-primary flex items-center justify-center mb-3 group-hover:scale-110 transition-transform">
                                        <span class="material-symbols-outlined text-2xl">person</span>
                                    </div>
                                    <h3 class="font-headline font-bold text-sm text-primary">@prestador.Nombre</h3>
                                    <p class="text-[10px] text-on-surface-variant mt-1">Profesional</p>
                                </button>
                            }
                        </div>
                    }
                </div>
            }

            @if (pasoActual == PasoReserva.SeleccionarTurno)
            {
                <div class="animate-in fade-in slide-in-from-bottom-4 duration-500 space-y-8">
                    <button @onclick="VolverAPrestadores" class="text-[10px] font-bold uppercase tracking-widest text-primary hover:underline flex items-center gap-1 mb-2 ml-2">
                        <span class="material-symbols-outlined text-xs">arrow_back</span> Cambiar Profesional
                    </button>

                    <div class="bg-primary/5 p-4 rounded-2xl flex items-center gap-3 border border-primary/10">
                        <span class="material-symbols-outlined text-primary">info</span>
                        <p class="text-xs font-body text-primary">
                            <strong>@servicioSeleccionado?.Nombre</strong> con <strong>@(prestadorSeleccionado?.Nombre ?? "cualquier profesional")</strong>.
                        </p>
                    </div>

                    <section>
                        <label class="block text-[10px] font-bold uppercase tracking-[0.2em] text-on-surface-variant mb-3 ml-2">1. Selecciona el día</label>
                        <input type="date" @bind="fechaSeleccionada" @bind:after="CargarDisponibilidad"
                               min="@DateTime.Today.ToString("yyyy-MM-dd")"
                               class="w-full p-5 bg-white rounded-3xl border-none editorial-shadow font-headline font-bold text-primary focus:ring-2 focus:ring-primary outline-none" />
                    </section>

                    <section>
                        <label class="block text-[10px] font-bold uppercase tracking-[0.2em] text-on-surface-variant mb-3 ml-2">2. Selecciona la hora</label>
                        @if (cargandoHorarios)
                        {
                            <div class="flex justify-center py-6">
                                <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
                            </div>
                        }
                        else if (slots.Any())
                        {
                            <div class="grid grid-cols-3 gap-3">
                                @foreach (var hora in slots)
                                {
                                    <button @onclick="() => SeleccionarHora(hora)"
                                            class="py-4 rounded-2xl font-headline font-bold text-sm transition-all @(horaSeleccionada == hora ? "bg-primary text-on-primary shadow-lg shadow-primary/30 scale-95" : "bg-white text-primary editorial-shadow hover:border-primary border border-transparent")">
                                        @hora
                                    </button>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="bg-white/50 p-6 rounded-3xl border border-dashed border-outline-variant text-center">
                                <p class="text-sm text-on-surface-variant italic">No hay lugares para este día.</p>
                            </div>
                        }
                    </section>

                    @if (!string.IsNullOrEmpty(horaSeleccionada))
                    {
                        <div class="bg-white p-8 rounded-[2.5rem] editorial-shadow border-2 border-primary animate-in zoom-in-95 duration-300 space-y-4">
                            <h3 class="font-headline font-bold text-xl text-primary mb-2">3. Tus datos</h3>

                            <input @bind="nuevoTurno.NombreClienteInvitado" placeholder="¿Cómo te llamás?"
                                   class="w-full p-4 bg-surface-container-low rounded-2xl outline-none focus:ring-2 focus:ring-primary font-body text-primary" />

                            <input @bind="nuevoTurno.TelefonoClienteInvitado" placeholder="Tu WhatsApp" type="tel"
                                   class="w-full p-4 bg-surface-container-low rounded-2xl outline-none focus:ring-2 focus:ring-primary font-body text-primary" />

                            <input @bind="nuevoTurno.EmailClienteInvitado" placeholder="Tu Email (opcional)" type="email"
                                   class="w-full p-4 bg-surface-container-low rounded-2xl outline-none focus:ring-2 focus:ring-primary font-body text-primary" />

                            <button @onclick="ConfirmarReserva" disabled="@enviandoReserva"
                                    class="w-full py-5 mt-2 bg-primary text-on-primary rounded-2xl font-headline font-bold text-lg shadow-xl shadow-primary/20 hover:brightness-110 active:scale-95 transition-all flex justify-center items-center gap-2">
                                @if (enviandoReserva)
                                {
                                    <div class="animate-spin rounded-full h-5 w-5 border-t-2 border-b-2 border-white"></div>
                                    <span>Reservando...</span>
                                }
                                else
                                {
                                    <span>Confirmar Turno</span>
                                }
                            </button>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>