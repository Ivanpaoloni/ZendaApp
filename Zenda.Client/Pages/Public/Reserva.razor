@page "/{NegocioSlug}"
@page "/{NegocioSlug}/sede/{SedeId:guid}"

@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@layout EmptyLayout
@using Zenda.Client.Components
@using Zenda.Core.DTOs
<PageTitle>@(negocio != null ? $"{negocio.Nombre} - Reservas" : "Zendy")</PageTitle>

<div class="w-full min-h-screen bg-surface-container-low flex flex-col justify-start md:justify-center items-center overflow-x-hidden md:py-10">

    @if (pasoActual == PasoReserva.Cargando)
    {
        <div class="flex justify-center items-center h-64">
            <div class="animate-spin rounded-full h-12 w-12 border-t-4 border-b-4 border-primary"></div>
        </div>
    }
    else if (pasoActual == PasoReserva.NoEncontrado || negocio == null)
    {
        <NotFoundUI />
    }
    else
    {

        <div class="w-full md:w-[420px] shrink-0 bg-white md:rounded-[2.5rem] md:shadow-2xl md:shadow-primary/5 flex flex-col relative overflow-hidden min-h-screen md:min-h-[750px]">

            <!-- 1. NAVBAR STICKY -->
            <nav class="shrink-0 sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-surface-container-low px-6 py-4 flex items-center justify-center">
                <span class="font-headline font-black text-primary truncate w-full text-center text-lg md:text-xl tracking-tight">
                    @negocio.Nombre
                </span>
            </nav>

            <!-- 2. CABECERA DEL NEGOCIO -->
            <header class="px-6 pt-8 pb-6 text-center shrink-0 flex flex-col items-center">
                @if (!string.IsNullOrEmpty(negocio.LogoUrl))
                {
                    <div class="w-20 h-20 md:w-24 md:h-24 mb-4">
                        <img src="@negocio.LogoUrl" alt="Logo de @negocio.Nombre"
                             class="w-full h-full rounded-[1.25rem] object-cover border border-surface-container-high shadow-sm" />
                    </div>
                }
                else
                {
                    <div class="w-20 h-20 md:w-24 md:h-24 bg-primary/5 rounded-[1.25rem] flex items-center justify-center mb-4 border border-primary/10 shadow-sm">
                        <span class="font-headline font-black text-3xl text-primary">
                            @(negocio.Nombre.FirstOrDefault())
                        </span>
                    </div>
                }

                <h1 class="text-xl md:text-2xl font-headline font-bold text-primary">
                    @ObtenerTextoPaso()
                </h1>
            </header>

            <!-- 3. CONTENIDO DEL WIZARD -->
            <main class="flex-grow w-full px-6 pb-8 flex flex-col">

                @if (pasoActual == PasoReserva.SeleccionarSede)
                {
                    <div class="space-y-3 animate-in fade-in slide-in-from-bottom-4 duration-500">
                        @foreach (var sede in sedesDisponibles)
                        {
                            <button @onclick="() => SeleccionarSede(sede)"
                                    class="w-full p-5 bg-white border border-surface-container-high rounded-2xl shadow-sm text-left flex items-center gap-4 transition-colors hover:border-primary hover:bg-primary/5 focus:ring-2 focus:ring-primary focus:outline-none group">
                                <div class="w-12 h-12 rounded-xl bg-surface-container-low text-primary flex items-center justify-center shrink-0 group-hover:bg-white transition-colors">
                                    <span class="material-symbols-outlined">location_on</span>
                                </div>
                                <div class="flex-grow">
                                    <h3 class="font-headline font-bold text-base text-primary">@sede.Nombre</h3>
                                    <p class="text-xs text-on-surface-variant mt-0.5 line-clamp-1">@sede.Direccion</p>
                                </div>
                                <span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary transition-colors">arrow_forward</span>
                            </button>
                        }
                    </div>
                }

                @if (pasoActual == PasoReserva.SeleccionarServicio)
                {
                    <div class="space-y-4 animate-in fade-in slide-in-from-bottom-4 duration-500">
                        @if (sedesDisponibles.Count > 1)
                        {
                            <button @onclick="VolverASedes" class="text-[10px] font-bold uppercase tracking-widest text-primary hover:underline flex items-center gap-1 mb-4">
                                <span class="material-symbols-outlined text-xs">arrow_back</span> Cambiar Sede
                            </button>
                        }

                        @if (!serviciosDeSede.Any())
                        {
                            <p class="text-center text-on-surface-variant p-6 border-2 border-dashed border-surface-container-high rounded-2xl">
                                No hay servicios disponibles en esta sede.
                            </p>
                        }
                        else
                        {
                            @foreach (var categoria in serviciosDeSede.GroupBy(s => s.CategoriaNombre))
                            {
                                <div class="mb-6">
                                    <h4 class="text-[10px] font-black tracking-widest uppercase text-on-surface-variant ml-2 mb-2">@categoria.Key</h4>
                                    <div class="space-y-3">
                                        @foreach (var servicio in categoria)
                                        {
                                            <button @onclick="() => SeleccionarServicio(servicio)"
                                                    class="w-full bg-white p-4 rounded-2xl border border-surface-container-high shadow-sm flex items-center justify-between hover:border-primary hover:bg-primary/5 transition-colors text-left group">
                                                <div>
                                                    <h3 class="font-bold text-sm text-primary group-hover:text-primary transition-colors">@servicio.Nombre</h3>
                                                    <p class="text-xs text-on-surface-variant flex items-center gap-1 mt-1">
                                                        <span class="material-symbols-outlined text-[14px]">schedule</span> @servicio.DuracionMinutos min
                                                    </p>
                                                </div>
                                                <div class="flex items-center gap-3">
                                                    <span class="font-headline font-black text-primary text-sm">@servicio.Precio.ToString("C0")</span>
                                                    <span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary transition-colors">arrow_forward</span>
                                                </div>
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        }
                    </div>
                }

                @if (pasoActual == PasoReserva.SeleccionarPrestador)
                {
                    <div class="space-y-4 animate-in fade-in slide-in-from-bottom-4 duration-500">
                        <button @onclick="VolverAServicios" class="text-[10px] font-bold uppercase tracking-widest text-primary hover:underline flex items-center gap-1 mb-4">
                            <span class="material-symbols-outlined text-xs">arrow_back</span> Cambiar Servicio
                        </button>

                        <div class="bg-primary/5 p-4 rounded-2xl flex items-center gap-3 border border-primary/10 mb-6">
                            <span class="material-symbols-outlined text-primary">cut</span>
                            <p class="text-xs font-body text-primary">
                                Elegiste <strong>@servicioSeleccionado?.Nombre</strong>. ¿Con quién te atendés?
                            </p>
                        </div>

                        @if (!prestadoresFiltrados.Any())
                        {
                            <div class="bg-white/50 p-6 rounded-2xl border border-dashed border-outline-variant text-center">
                                <p class="text-sm text-on-surface-variant">Ningún profesional realiza este servicio en esta sede.</p>
                            </div>
                        }
                        else
                        {
                            <div class="grid grid-cols-2 gap-4">
                                <button @onclick="() => SeleccionarPrestador(null)"
                                        class="bg-white p-6 rounded-2xl border border-surface-container-high shadow-sm flex flex-col items-center justify-center text-center hover:border-primary hover:bg-primary/5 transition-colors group h-full">
                                    <div class="w-14 h-14 rounded-full bg-secondary-container text-on-secondary-container flex items-center justify-center mb-3 group-hover:bg-primary group-hover:text-white transition-colors">
                                        <span class="material-symbols-outlined text-2xl">group</span>
                                    </div>
                                    <h3 class="font-headline font-bold text-sm text-primary">Cualquiera</h3>
                                    <p class="text-[10px] text-on-surface-variant mt-1">El primero libre</p>
                                </button>

                                @foreach (var prestador in prestadoresFiltrados)
                                {
                                    <button @onclick="() => SeleccionarPrestador(prestador)"
                                            class="bg-white p-6 rounded-2xl border border-surface-container-high shadow-sm flex flex-col items-center justify-center text-center hover:border-primary hover:bg-primary/5 transition-colors group h-full">
                                        <div class="w-14 h-14 rounded-full bg-surface-container-low text-primary flex items-center justify-center mb-3 group-hover:bg-primary group-hover:text-white transition-colors">
                                            <span class="material-symbols-outlined text-2xl">person</span>
                                        </div>
                                        <h3 class="font-headline font-bold text-sm text-primary">@prestador.Nombre</h3>
                                        <p class="text-[10px] text-on-surface-variant mt-1">Profesional</p>
                                    </button>
                                }
                            </div>
                        }
                    </div>
                }

                @if (pasoActual == PasoReserva.SeleccionarTurno)
                {
                    <div class="animate-in fade-in slide-in-from-bottom-4 duration-500 space-y-8">
                        <button @onclick="VolverAPrestadores" class="text-[10px] font-bold uppercase tracking-widest text-primary hover:underline flex items-center gap-1 mb-2 ml-2">
                            <span class="material-symbols-outlined text-xs">arrow_back</span> Cambiar Profesional
                        </button>

                        <div class="bg-primary/5 p-4 rounded-2xl flex items-center gap-3 border border-primary/10">
                            <span class="material-symbols-outlined text-primary">info</span>
                            <p class="text-xs font-body text-primary">
                                <strong>@servicioSeleccionado?.Nombre</strong> con <strong>@(prestadorSeleccionado?.Nombre ?? "cualquier profesional")</strong>.
                            </p>
                        </div>

                        <section>
                            <label class="block text-[10px] font-bold uppercase tracking-[0.2em] text-on-surface-variant mb-3 ml-2">1. Selecciona el día</label>
                            <input type="date" @bind="fechaSeleccionada" @bind:after="CargarDisponibilidad"
                                   min="@DateTime.Today.ToString("yyyy-MM-dd")"
                                   class="w-full p-4 bg-white rounded-2xl border border-surface-container-high shadow-sm font-headline font-bold text-primary focus:ring-2 focus:ring-primary outline-none transition-colors hover:border-primary" />
                        </section>

                        <section>
                            <label class="block text-[10px] font-bold uppercase tracking-[0.2em] text-on-surface-variant mb-3 ml-2">2. Selecciona la hora</label>
                            @if (cargandoHorarios)
                            {
                                <div class="flex justify-center py-6">
                                    <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
                                </div>
                            }
                            else if (slots.Any())
                            {
                                <div class="grid grid-cols-3 gap-3">
                                    @foreach (var hora in slots)
                                    {
                                        <button @onclick="() => SeleccionarHora(hora)"
                                                class="py-4 rounded-xl font-headline font-bold text-sm transition-colors bg-white text-primary border border-surface-container-high shadow-sm hover:bg-primary hover:text-white hover:border-primary">
                                            @hora
                                        </button>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="bg-white/50 p-6 rounded-2xl border border-dashed border-outline-variant text-center">
                                    <p class="text-sm text-on-surface-variant italic">No hay lugares para este día.</p>
                                </div>
                            }
                        </section>
                    </div>
                }

                @if (pasoActual == PasoReserva.CompletarDatos)
                {
                    <div class="animate-in fade-in slide-in-from-right-8 duration-500">
                        <button @onclick="VolverAHorarios" class="text-[10px] font-bold uppercase tracking-widest text-primary hover:underline flex items-center gap-1 mb-4 ml-2">
                            <span class="material-symbols-outlined text-xs">arrow_back</span> Elegir otro horario
                        </button>

                        <div class="bg-white p-6 md:p-8 rounded-2xl shadow-sm border border-surface-container-high overflow-hidden">

                            <h3 class="font-headline font-bold text-xl text-primary mb-4">Último paso</h3>

                            <div class="bg-surface-container-lowest border border-surface-container-high rounded-2xl p-5 mb-6 relative">
                                <div class="absolute -right-4 -top-4 w-12 h-12 bg-primary/10 rounded-full flex justify-center items-center">
                                    <span class="material-symbols-outlined text-primary text-2xl">check_circle</span>
                                </div>

                                <h4 class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-3">Resumen de tu reserva</h4>

                                <div class="space-y-3">
                                    <div class="flex items-start gap-3">
                                        <div class="w-8 h-8 rounded-full bg-surface-container-low flex justify-center items-center text-primary shrink-0 mt-0.5">
                                            <span class="material-symbols-outlined text-[16px]">calendar_month</span>
                                        </div>
                                        <div>
                                            <p class="font-bold text-sm text-primary">@fechaSeleccionada.ToString("dddd, dd 'de' MMMM")</p>
                                            <p class="text-xs text-on-surface-variant">a las <strong class="text-primary">@horaSeleccionada hs</strong></p>
                                        </div>
                                    </div>

                                    <div class="flex items-start gap-3">
                                        <div class="w-8 h-8 rounded-full bg-surface-container-low flex justify-center items-center text-primary shrink-0 mt-0.5">
                                            <span class="material-symbols-outlined text-[16px]">cut</span>
                                        </div>
                                        <div>
                                            <p class="font-bold text-sm text-primary">@servicioSeleccionado?.Nombre</p>
                                            <div class="flex gap-2 items-center text-xs text-on-surface-variant">
                                                <span>@servicioSeleccionado?.DuracionMinutos min</span>
                                                <span>•</span>
                                                <span class="font-bold">@servicioSeleccionado?.Precio.ToString("C0")</span>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="flex items-start gap-3">
                                        <div class="w-8 h-8 rounded-full bg-surface-container-low flex justify-center items-center text-primary shrink-0 mt-0.5">
                                            <span class="material-symbols-outlined text-[16px]">person</span>
                                        </div>
                                        <div>
                                            <p class="font-bold text-sm text-primary">
                                                @(prestadorSeleccionado != null ? prestadorSeleccionado.Nombre : "Cualquier profesional")
                                            </p>
                                            <p class="text-xs text-on-surface-variant">en @sedeSeleccionada?.Nombre</p>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(errorReserva))
                            {
                                <div class="mb-4 p-3 bg-error/10 text-error rounded-xl text-sm font-bold flex items-center gap-2">
                                    <span class="material-symbols-outlined text-lg">error</span>
                                    @errorReserva
                                </div>
                            }

                            <EditForm Model="@nuevoTurno" OnValidSubmit="ConfirmarReserva">
                                <DataAnnotationsValidator />

                                <div class="space-y-4">
                                    <div>
                                        <InputText @bind-Value="nuevoTurno.NombreClienteInvitado" placeholder="¿Cómo te llamás?"
                                                   class="w-full p-4 bg-surface-container-low border border-transparent rounded-xl outline-none focus:ring-2 focus:ring-primary focus:border-transparent font-body text-primary transition-all" />
                                        <ValidationMessage For="@(() => nuevoTurno.NombreClienteInvitado)" class="text-error text-xs font-bold mt-1 ml-2" />
                                    </div>

                                    <div>
                                        <InputText @bind-Value="nuevoTurno.TelefonoClienteInvitado" placeholder="Tu WhatsApp"
                                                   class="w-full p-4 bg-surface-container-low border border-transparent rounded-xl outline-none focus:ring-2 focus:ring-primary focus:border-transparent font-body text-primary transition-all" />
                                        <ValidationMessage For="@(() => nuevoTurno.TelefonoClienteInvitado)" class="text-error text-xs font-bold mt-1 ml-2" />
                                    </div>

                                    <div>
                                        <InputText @bind-Value="nuevoTurno.EmailClienteInvitado" placeholder="Tu Email"
                                                   class="w-full p-4 bg-surface-container-low border border-transparent rounded-xl outline-none focus:ring-2 focus:ring-primary focus:border-transparent font-body text-primary transition-all" />
                                        <ValidationMessage For="@(() => nuevoTurno.EmailClienteInvitado)" class="text-error text-xs font-bold mt-1 ml-2" />
                                        <p class="text-[10px] text-on-surface-variant mt-1 ml-2">Te enviaremos los detalles y el link para cancelar si lo necesitás.</p>
                                    </div>

                                    <button type="submit" disabled="@enviandoReserva"
                                            class="w-full py-3.5 mt-4 bg-primary text-white rounded-xl font-headline font-bold text-base hover:brightness-95 focus:ring-2 focus:ring-primary focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed transition-colors flex justify-center items-center gap-2">
                                        @if (enviandoReserva)
                                        {
                                            <div class="animate-spin rounded-full h-5 w-5 border-t-2 border-b-2 border-white"></div>
                                            <span>Confirmando...</span>
                                        }
                                        else
                                        {
                                            <span>Confirmar Turno</span>
                                        }
                                    </button>
                                </div>
                            </EditForm>
                        </div>
                    </div>
                }
            </main>

            <!-- 4. BOTTOM SHEET INFO SEDE (Integrado al widget) -->
            @if (sedeSeleccionada != null)
            {
                <div class="border-t border-surface-container-low bg-surface-container-lowest mt-auto">
                    <InfoSedeUI Sede="sedeSeleccionada" Negocio="negocio" />
                </div>
            }
        </div>
    }
</div>
