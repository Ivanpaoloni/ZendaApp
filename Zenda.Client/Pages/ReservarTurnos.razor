@page "/reservar/{PrestadorId:guid}"
@using Zenda.Client.Services
@using Zenda.Core.DTOs
@inject TurnoClient TurnoService
@inject PrestadorClient PrestadorService
@inject NavigationManager Nav

<div class="max-w-4xl mx-auto py-10 px-4 animate-in fade-in duration-700">
    <div class="text-center mb-10">
        <h1 class="text-4xl font-headline font-extrabold text-primary tracking-tight">
            Reservar con @(nombrePrestador ?? "...")
        </h1>
        <p class="text-on-surface-variant mt-2 font-body">Selecciona el día y horario que mejor te quede.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        <div class="bg-white p-8 rounded-4xl editorial-shadow border border-surface-container-high">
            <label class="block text-sm font-bold text-primary uppercase tracking-widest mb-4">Selecciona el Día</label>
            <input type="date" @bind="fechaSeleccionada" @bind:after="CargarDisponibilidad"
                   min="@DateTime.Today.ToString("yyyy-MM-dd")"
                   class="w-full p-4 bg-surface-container-low border-none rounded-2xl focus:ring-2 focus:ring-primary outline-none font-headline font-bold text-lg" />

            <div class="mt-8">
                <div class="p-4 rounded-2xl bg-secondary-container/30 border border-secondary-container">
                    <p class="text-xs font-bold text-on-secondary-container uppercase mb-1">Duración del servicio</p>
                    <p class="text-primary font-headline font-bold">@duracion min</p>
                </div>
            </div>
        </div>

        <div class="bg-white p-8 rounded-4xl editorial-shadow border border-surface-container-high">
            <label class="block text-sm font-bold text-primary uppercase tracking-widest mb-4">Horarios Disponibles</label>

            @if (cargando)
            {
                <div class="flex justify-center py-10">
                    <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
                </div>
            }
            else if (slots.Any())
            {
                <div class="grid grid-cols-3 gap-3">
                    @foreach (var hora in slots)
                    {
                        <button @onclick="() => SeleccionarHora(hora)"
                                class="py-3 px-2 rounded-xl font-headline font-bold text-sm transition-all @(horaSeleccionada == hora ? "bg-primary text-on-primary shadow-lg scale-105" : "bg-surface-container-low text-primary hover:bg-primary/10")">
                            @hora
                        </button>
                    }
                </div>
            }
            else
            {
                <p class="text-on-surface-variant italic py-10 text-center">No hay horarios disponibles para este día.</p>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(horaSeleccionada))
    {
        <div class="mt-10 bg-white p-8 rounded-4xl editorial-shadow border-2 border-primary animate-in zoom-in-95 duration-300">
            <h3 class="text-2xl font-headline font-bold text-primary mb-6">Confirmar Turno: @fechaSeleccionada.ToShortDateString() a las @horaSeleccionada hs</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <input @bind="nuevoTurno.NombreClienteInvitado" placeholder="Tu Nombre" class="p-4 bg-surface-container-low rounded-2xl outline-none focus:ring-2 focus:ring-primary" />
                <input @bind="nuevoTurno.TelefonoClienteInvitado" placeholder="WhatsApp / Teléfono" class="p-4 bg-surface-container-low rounded-2xl outline-none focus:ring-2 focus:ring-primary" />
            </div>
            <button @onclick="ConfirmarReserva" disabled="@enviando"
                    class="w-full mt-6 py-4 bg-primary text-on-primary rounded-2xl font-headline font-bold text-lg hover:brightness-110 active:scale-[0.98] transition-all">
                @(enviando ? "Procesando..." : "¡Reservar ahora!")
            </button>
        </div>
    }
</div>

@code {
    [Parameter] public Guid PrestadorId { get; set; }
    private string? nombrePrestador;
    private int duracion;
    private DateTime fechaSeleccionada = DateTime.Today;
    private List<string> slots = new();
    private string? horaSeleccionada;
    private bool cargando = false;
    private bool enviando = false;
    private TurnoCreateDto nuevoTurno = new();

    protected override async Task OnInitializedAsync()
    {
        var p = await PrestadorService.GetById(PrestadorId);
        nombrePrestador = p?.Nombre;
        duracion = p?.DuracionTurnoMinutos ?? 30;
        await CargarDisponibilidad();
    }

    private async Task CargarDisponibilidad()
    {
        cargando = true;
        horaSeleccionada = null;
        var res = await TurnoService.GetDisponibilidad(PrestadorId, fechaSeleccionada);
        slots = res?.HorariosLibres ?? new();
        cargando = false;
    }

    private void SeleccionarHora(string hora) => horaSeleccionada = hora;

    private async Task ConfirmarReserva()
    {
        if (string.IsNullOrEmpty(nuevoTurno.NombreClienteInvitado)) return;

        enviando = true;

        // Construimos el DateTime completo para el DTO
        var h = TimeOnly.Parse(horaSeleccionada!);
        nuevoTurno.PrestadorId = PrestadorId;
        nuevoTurno.Inicio = fechaSeleccionada.Date.Add(h.ToTimeSpan());

        var exito = await TurnoService.Reservar(nuevoTurno);

        if (exito != null) Nav.NavigateTo("/turnos-exito");

        enviando = false;
    }
}