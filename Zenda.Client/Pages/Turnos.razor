@page "/turnos"
@using Zenda.Core.Enums
@using System.Globalization

<div class="space-y-6 animate-in fade-in duration-500 pb-20 relative">

    @* ========================================== *@
    @* 1. TOOLBAR PRINCIPAL (UX Desktop & Mobile) *@
    @* ========================================== *@
    <div class="flex flex-col xl:flex-row justify-between items-start xl:items-center gap-4 bg-white p-4 rounded-2xl border border-surface-container-low shadow-sm">

        @* Zona Izquierda: Contexto y Refresco *@
        <div class="flex flex-col">
            <div class="flex items-center gap-3">
                <h1 class="text-2xl font-bold text-primary font-headline leading-none">Agenda</h1>
                <button @onclick="RefrescarManual" disabled="@cargando"
                        class="w-7 h-7 flex items-center justify-center rounded-full bg-surface-container-lowest text-primary hover:bg-primary/10 transition-colors disabled:opacity-50">
                    <span class="material-symbols-outlined text-[18px] @(cargando ? "animate-spin" : "")">refresh</span>
                </button>
            </div>
            <span class="text-[10px] font-bold text-on-surface-variant/50 uppercase tracking-widest mt-1">
                Act: @ultimaActualizacion.ToString("HH:mm")
            </span>
        </div>

        @* Zona Central: Pivotes de Navegación (Profesional + Fecha) *@
        <div class="flex flex-col sm:flex-row items-center gap-3 w-full xl:w-auto">

            @* Selector Principal de Profesional (SIN OPCIÓN TODOS) *@
            @if (listaProfesionalesDropdown.Count > 1)
            {
                <div class="relative w-full sm:w-auto">
                    <span class="material-symbols-outlined absolute left-3 top-2.5 text-[18px] text-primary">person</span>
                    <select @bind="profesionalFiltro" class="w-full sm:w-56 bg-surface-container-lowest border border-surface-container-high text-primary text-sm font-bold rounded-xl pl-9 pr-8 py-2.5 outline-none focus:ring-2 focus:ring-primary appearance-none shadow-sm transition-all truncate cursor-pointer">
                        @foreach (var prof in listaProfesionalesDropdown)
                        {
                            <option value="@prof">@prof</option>
                        }
                    </select>
                </div>
            }

            @* Selector de Fecha con Navegación Adyacente *@
            <div class="flex items-center gap-2 w-full sm:w-auto">

                @* Botón Día Anterior *@
                <button @onclick="RetrocederDia" disabled="@cargando"
                        class="w-10 h-10 flex items-center justify-center bg-surface-container-lowest border border-surface-container-high rounded-xl text-on-surface-variant hover:text-primary hover:bg-surface-container-low transition-colors shadow-sm shrink-0 disabled:opacity-50"
                        title="Día anterior">
                    <span class="material-symbols-outlined text-[20px]">chevron_left</span>
                </button>

                <input type="date" @bind="fechaFiltro" @bind:after="CambiarFechaFiltro"
                       class="w-full sm:w-auto p-2.5 bg-surface-container-lowest rounded-xl border border-surface-container-high shadow-sm font-bold text-primary focus:ring-2 focus:ring-primary outline-none cursor-pointer uppercase text-sm tracking-wide" />

                @* Botón Día Siguiente *@
                <button @onclick="AvanzarDia" disabled="@cargando"
                        class="w-10 h-10 flex items-center justify-center bg-surface-container-lowest border border-surface-container-high rounded-xl text-on-surface-variant hover:text-primary hover:bg-surface-container-low transition-colors shadow-sm shrink-0 disabled:opacity-50"
                        title="Día siguiente">
                    <span class="material-symbols-outlined text-[20px]">chevron_right</span>
                </button>

                @if (fechaFiltro.Date != DateTime.Today)
                {
                    <button @onclick="IrAHoy" disabled="@cargando"
                            class="px-3 py-2.5 bg-secondary-container/50 text-on-secondary-container text-xs font-bold uppercase tracking-widest rounded-xl hover:bg-secondary-container transition-colors shrink-0 animate-in fade-in slide-in-from-right-2">
                        Hoy
                    </button>
                }
            </div>
        </div>

        @* Zona Derecha: Vistas y Acciones Globales *@
        <div class="flex items-center gap-3 w-full xl:w-auto overflow-x-auto pb-1 xl:pb-0 scrollbar-hide">

            @* Selector de Vista UI Compacto *@
            <div class="bg-surface-container-lowest p-1 rounded-xl flex gap-1 shadow-sm border border-surface-container-high shrink-0">
                <button @onclick='() => CambiarModoVista("Lista")'
                        class="@(modoVista == "Lista" ? "bg-primary text-white shadow-sm" : "text-on-surface-variant hover:text-primary") px-3 py-1.5 rounded-lg text-sm font-bold transition-all flex items-center gap-1">
                    <span class="material-symbols-outlined text-[16px]">view_list</span>
                    <span class="hidden md:inline">Lista</span>
                </button>
                <button @onclick='() => CambiarModoVista("Calendario")'
                        class="@(modoVista == "Calendario" ? "bg-primary text-white shadow-sm" : "text-on-surface-variant hover:text-primary") px-3 py-1.5 rounded-lg text-sm font-bold transition-all flex items-center gap-1">
                    <span class="material-symbols-outlined text-[16px]">calendar_month</span>
                    <span class="hidden md:inline">Calendario</span>
                </button>
            </div>

            @* Botón Exportar Responsivo *@
            <button @onclick="ExportarExcelMes" disabled="@exportando"
                    class="h-9 px-3 flex items-center justify-center gap-2 bg-white text-green-700 border border-surface-container-high rounded-xl hover:bg-green-50 transition-all disabled:opacity-50 shadow-sm shrink-0" title="Exportar Mes">
                @if (exportando)
                {
                    <div class="animate-spin rounded-full h-4 w-4 border-t-2 border-b-2 border-green-700"></div>
                }
                else
                {
                    <span class="material-symbols-outlined text-[18px]">download</span>
                    <span class="hidden md:inline text-sm font-bold">Exportar</span>
                }
            </button>

            <button @onclick="() => mostrarDrawerTurno = true"
                    class="px-4 py-2 bg-primary text-white rounded-xl font-bold hover:brightness-110 transition-all flex items-center gap-2 shadow-sm shrink-0 h-9">
                <span class="material-symbols-outlined text-[18px]">add</span>
                <span class="hidden sm:inline text-sm">Nuevo</span>
            </button>
        </div>
    </div>

    @* ========================================== *@
    @* 2. FILTROS SECUNDARIOS (Ocultos por defecto) *@
    @* ========================================== *@
    @if (turnosDelPeriodo.Any())
    {
        <div class="bg-white rounded-2xl border border-surface-container-high overflow-hidden shadow-sm mt-4">
            <button @onclick="ToggleFiltros" class="w-full flex items-center justify-between p-3 hover:bg-surface-container-lowest/50 transition-colors">
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-on-surface-variant text-[20px]">filter_list</span>
                    <span class="text-xs font-bold text-on-surface-variant uppercase tracking-widest">Búsqueda y Filtros</span>
                    @if (!mostrarFiltros && (CantidadFiltrosActivos - (!string.IsNullOrEmpty(profesionalFiltro) ? 1 : 0)) > 0)
                    {
                        <span class="bg-primary text-white text-[9px] font-bold px-2 py-0.5 rounded-full ml-2">Activo</span>
                    }
                </div>
                <div class="flex items-center gap-4">
                    @if ((CantidadFiltrosActivos - (!string.IsNullOrEmpty(profesionalFiltro) ? 1 : 0)) > 0)
                    {
                        <div @onclick:stopPropagation @onclick="LimpiarFiltros" class="text-[10px] font-bold text-error hover:underline cursor-pointer uppercase tracking-wider">
                            Limpiar
                        </div>
                    }
                    <span class="material-symbols-outlined text-on-surface-variant transition-transform duration-300 @(mostrarFiltros ? "rotate-180" : "")">expand_more</span>
                </div>
            </button>

            @if (mostrarFiltros)
            {
                <div class="p-4 flex flex-wrap gap-4 items-end border-t border-surface-container-high/50 bg-surface-container-lowest/30 animate-in slide-in-from-top-2 fade-in">

                    <div class="flex flex-col gap-1 w-full md:flex-grow max-w-sm">
                        <label class="text-[9px] font-bold text-on-surface-variant uppercase tracking-widest ml-1">Buscar Cliente</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-3 top-2.5 text-[18px] text-on-surface-variant/50">search</span>
                            <input type="text" @bind="busquedaCliente" @bind:event="oninput" placeholder="Ej: Juan Pérez..."
                                   class="w-full bg-white border border-surface-container-high rounded-xl pl-9 pr-4 py-2 text-sm font-bold text-primary outline-none focus:border-primary shadow-sm" />
                        </div>
                    </div>

                    <div class="flex flex-col gap-1 w-full sm:w-auto">
                        <label class="text-[9px] font-bold text-on-surface-variant uppercase tracking-widest ml-1">Estado</label>
                        <select @bind="estadoFiltro" class="bg-white border border-surface-container-high rounded-xl px-3 py-2 text-sm font-bold text-primary outline-none focus:border-primary cursor-pointer shadow-sm min-w-[140px]">
                            <option value="">Todos</option>
                            <option value="Pendiente">Pendientes</option>
                            <option value="Confirmado">Confirmados</option>
                            <option value="Completado">Completados</option>
                            <option value="Cancelado">Cancelados</option>
                        </select>
                    </div>

                    @if (listaSedesDropdown.Count > 1)
                    {
                        <div class="flex flex-col gap-1 w-full sm:w-auto">
                            <label class="text-[9px] font-bold text-on-surface-variant uppercase tracking-widest ml-1">Sede</label>
                            <select @bind="sedeFiltro" class="bg-white border border-surface-container-high rounded-xl px-3 py-2 text-sm font-bold text-primary outline-none focus:border-primary cursor-pointer shadow-sm max-w-[200px] truncate">
                                <option value="">Todas</option>
                                @foreach (var sede in listaSedesDropdown)
                                {
                                    <option value="@sede">@sede</option>
                                }
                            </select>
                        </div>
                    }
                </div>
            }
        </div>
    }

    @* ========================================== *@
    @* 3. RENDERIZADO DEL CONTENIDO PRINCIPAL     *@
    @* ========================================== *@
    @if (cargando)
    {
        <Zenda.Client.Components.Spinner></Zenda.Client.Components.Spinner>
    }
    else if (!TurnosPlanosFiltrados.Any())
    {
        <div class="bg-white border border-surface-container-high rounded-4xl p-12 text-center flex flex-col items-center justify-center min-h-[300px] shadow-sm mt-4">
            <span class="material-symbols-outlined text-6xl text-on-surface-variant/50 mb-4">coffee</span>
            <h3 class="font-headline font-bold text-xl text-primary mb-2">Sin actividad</h3>
            <p class="text-on-surface-variant font-body text-sm">No hay turnos para los filtros o fechas seleccionados.</p>
        </div>
    }
    else
    {
        @if (modoVista == "Lista")
        {
            <div class="flex flex-col gap-3 mt-4 animate-in fade-in duration-300 w-full">
                @if (!TurnosDelDiaSeleccionado.Any())
                {
                    <div class="bg-surface-container-lowest border border-surface-container-high rounded-2xl p-8 text-center text-on-surface-variant font-medium">
                        No hay turnos agendados para este día.
                    </div>
                }
                else
                {
                    <div class="mb-2 flex justify-between items-center">
                        <span class="text-xs font-bold text-on-surface-variant uppercase tracking-widest">
                            Turnos de @profesionalFiltro
                        </span>
                        <span class="text-xs font-bold bg-primary/10 text-primary px-3 py-1 rounded-lg">
                            Total: @TurnosDelDiaSeleccionado.Count
                        </span>
                    </div>

                    @foreach (var turno in TurnosDelDiaSeleccionado)
                    {
                        var horaInicio = turno.FechaHoraInicioUtc.ToLocalTime();
                        var colorBorde = turno.Estado == EstadoTurnoEnum.Pendiente ? "border-l-warning" :
                        turno.Estado == EstadoTurnoEnum.Confirmado ? "border-l-success" :
                        turno.Estado == EstadoTurnoEnum.Cancelado ? "border-l-error" : "border-l-surface-container-highest";

                        <div class="bg-white p-4 md:px-6 rounded-2xl border border-surface-container-high border-l-[6px] @colorBorde shadow-sm hover:shadow-md transition-all flex flex-col md:flex-row md:items-center gap-4 md:gap-6 group">

                            <div class="flex flex-row md:flex-col items-center md:items-start justify-between md:w-28 shrink-0 border-b md:border-b-0 md:border-r border-surface-container-high pb-3 md:pb-0 pr-0 md:pr-4">
                                <span class="text-3xl font-bold text-primary font-headline leading-none">@horaInicio.ToString("HH:mm")</span>
                                <div class="flex items-center gap-1 text-[11px] text-on-surface-variant font-bold bg-surface-container-low px-2 py-1 rounded-md mt-1">
                                    <span class="material-symbols-outlined text-[14px]">schedule</span>
                                    @turno.DuracionMinutos min
                                </div>
                            </div>

                            <div class="flex-grow flex flex-col">
                                <h4 class="text-xl font-bold text-on-surface leading-tight cursor-pointer hover:text-primary transition-colors" @onclick="() => OnTurnoSeleccionadoDesdeCalendario(turno)">
                                    @turno.ClienteNombre
                                </h4>
                                <div class="flex flex-wrap items-center gap-3 md:gap-4 mt-2">
                                    <span class="flex items-center gap-1 text-sm text-on-surface-variant font-medium">
                                        <span class="material-symbols-outlined text-[16px]">content_cut</span>
                                        @turno.ServicioNombre
                                    </span>

                                    @if (turno.Precio > 0)
                                    {
                                        <span class="flex items-center gap-1 text-sm text-on-surface-variant font-medium">
                                            <span class="material-symbols-outlined text-[16px]">payments</span>
                                            $@turno.Precio.ToString("N0")
                                        </span>
                                    }
                                </div>
                            </div>

                            <div class="flex flex-row items-center justify-between md:justify-end gap-4 shrink-0 pt-3 md:pt-0 border-t md:border-t-0 border-surface-container-high">
                                <span class="text-xs font-bold uppercase tracking-widest @Zenda.Client.Extensions.EstadoTurnoExtensions.ObtenerColorEstado(turno.Estado) px-3 py-1.5 rounded-lg">
                                    @turno.Estado
                                </span>

                                <div class="flex items-center gap-2 opacity-100 md:opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                                    @if (turno.Estado != EstadoTurnoEnum.Completado && turno.Estado != EstadoTurnoEnum.Cancelado)
                                    {
                                        <a href="@GenerarWhatsAppUrl(turno.ClienteTelefono, turno.ClienteNombre, horaInicio)" target="_blank"
                                           class="w-10 h-10 flex items-center justify-center rounded-xl bg-[#25D366]/10 text-[#25D366] hover:bg-[#25D366] hover:text-white transition-all shadow-sm" title="WhatsApp">
                                            <i class="fa-brands fa-whatsapp text-xl"></i>
                                        </a>
                                        <button @onclick="() => MostrarModalCobro(turno)" class="w-10 h-10 flex items-center justify-center rounded-xl bg-green-500/10 text-green-700 hover:bg-green-500 hover:text-white transition-all shadow-sm" title="Cobrar">
                                            <span class="material-symbols-outlined text-[20px]">task_alt</span>
                                        </button>
                                        <button @onclick="() => MostrarModalCancelacion(turno)" class="w-10 h-10 flex items-center justify-center rounded-xl bg-red-600/10 text-red-600 hover:bg-red-600 hover:text-white transition-all shadow-sm" title="Cancelar Turno">
                                            <span class="material-symbols-outlined text-[20px]">block</span>
                                        </button>
                                    }
                                    else
                                    {
                                        <button @onclick="() => OnTurnoSeleccionadoDesdeCalendario(turno)" class="w-10 h-10 flex items-center justify-center rounded-xl bg-surface-container-low text-on-surface-variant hover:bg-primary/10 hover:text-primary transition-all shadow-sm" title="Ver Detalles">
                                            <span class="material-symbols-outlined text-[20px]">visibility</span>
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        }
        else if (modoVista == "Calendario")
        {
            <div class="mt-4 animate-in fade-in duration-300">
                <div class="bg-white p-3 rounded-2xl border border-surface-container-high shadow-sm">
                    @* AQUI PASAMOS EL TIMEZONE A LA GRILLA *@
                    <Zenda.Client.Components.ZendyScheduler Turnos="TurnosPlanosFiltrados"
                                                            @bind-FechaBase="fechaFiltro"
                                                            TimeZoneId="@ObtenerTimeZoneActual()"
                                                            OnTurnoSeleccionado="OnTurnoSeleccionadoDesdeCalendario" />
                </div>
            </div>
        }
    }
</div>

@* ========================================== *@
@* MODALES Y DRAWERS                          *@
@* ========================================== *@
@if (mostrarModal)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/20 backdrop-blur-sm animate-in fade-in duration-200">
        <div class="bg-white rounded-3xl p-6 w-full max-w-sm border border-surface-container-high shadow-xl animate-in zoom-in-95 duration-200">
            <div class="flex items-center gap-3 mb-4 text-red-600">
                <span class="material-symbols-outlined text-3xl">warning</span>
                <h3 class="font-headline font-bold text-xl text-primary">¿Cancelar Turno?</h3>
            </div>
            <p class="text-sm text-on-surface-variant mb-6">
                Estás por cancelar el turno de <strong class="text-primary">@turnoAEliminar?.ClienteNombre</strong>. Esta acción le enviará un correo de notificación y liberará el horario en la agenda.
            </p>
            <div class="flex gap-3">
                <button @onclick="CerrarModal" class="flex-1 py-3 bg-white border border-surface-container-high text-on-surface-variant rounded-xl font-bold hover:bg-surface-container-lowest transition-colors">Volver</button>
                <button @onclick="ConfirmarCancelacion" disabled="@procesandoCancelacion" class="flex-1 py-3 bg-red-600 text-white rounded-xl font-bold hover:bg-red-700 transition-colors disabled:opacity-50 flex justify-center items-center gap-2">
                    @if (procesandoCancelacion)
                    {
                        <div class="animate-spin rounded-full h-4 w-4 border-t-2 border-b-2 border-white"></div>
                        <span>Cancelando...</span>
                    }
                    else
                    {
                        <span>Sí, cancelar</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@if (mostrarModalCobro)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/20 backdrop-blur-sm animate-in fade-in duration-200">
        <div class="bg-white rounded-3xl p-6 w-full max-w-sm border border-surface-container-high shadow-xl animate-in zoom-in-95 duration-200">
            <div class="flex items-center gap-3 mb-2 text-primary">
                <span class="material-symbols-outlined text-3xl text-green-500">payments</span>
                <h3 class="font-headline font-bold text-xl">Cobrar Turno</h3>
            </div>
            <p class="text-sm text-on-surface-variant mb-4">¿Cómo pagó <strong class="text-primary">@turnoACobrar?.ClienteNombre</strong>?</p>

            @if (!string.IsNullOrEmpty(errorCobro))
            {
                <div class="bg-red-50 text-red-600 text-[10px] font-bold p-3 rounded-xl mb-4 text-center uppercase tracking-wider">
                    @errorCobro
                </div>
            }

            <div class="flex flex-col gap-2 mb-6">
                <select @bind="medioPagoSeleccionado" class="w-full p-4 bg-surface-container-low rounded-2xl border border-surface-container-high outline-none focus:ring-2 focus:ring-primary font-body text-primary font-bold cursor-pointer">
                    <option value="@MedioPagoEnum.Efectivo">💵 Efectivo</option>
                    <option value="@MedioPagoEnum.Transferencia">🏦 Transferencia</option>
                    <option value="@MedioPagoEnum.MercadoPago">📱 MercadoPago</option>
                    <option value="@MedioPagoEnum.TarjetaDebito">💳 Tarjeta de Débito</option>
                    <option value="@MedioPagoEnum.TarjetaCredito">💳 Tarjeta de Crédito</option>
                </select>
            </div>

            <div class="flex gap-3">
                <button @onclick="CerrarModalCobro" class="flex-1 py-3 bg-white border border-surface-container-high text-on-surface-variant rounded-xl font-bold hover:bg-surface-container-lowest transition-colors">Cancelar</button>
                <button @onclick="ConfirmarCobro" disabled="@procesandoCobro" class="flex-1 py-3 bg-green-500 text-white rounded-xl font-bold hover:bg-green-600 transition-colors disabled:opacity-50 flex justify-center items-center gap-2">
                    @if (procesandoCobro)
                    {
                        <div class="animate-spin rounded-full h-4 w-4 border-t-2 border-b-2 border-white"></div>
                    }
                    else
                    {
                        <span>Confirmar</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@if (mostrarModalDetalle && turnoSeleccionado != null)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/20 backdrop-blur-sm animate-in fade-in duration-200 p-4">
        <div class="bg-white rounded-3xl w-full max-w-md border border-surface-container-high shadow-xl animate-in zoom-in-95 duration-200 overflow-hidden relative">

            <button @onclick="CerrarModalDetalle" class="absolute top-4 right-4 w-8 h-8 flex items-center justify-center rounded-full bg-surface-container-lowest text-on-surface-variant hover:bg-surface-container-low transition-colors">
                <span class="material-symbols-outlined text-[18px]">close</span>
            </button>

            <div class="p-6">
                <div class="flex items-center gap-3 mb-6 pr-8">
                    <div class="w-12 h-12 rounded-full bg-primary/10 text-primary flex shrink-0 items-center justify-center text-xl font-bold">
                        @(turnoSeleccionado.ClienteNombre.FirstOrDefault())
                    </div>
                    <div class="overflow-hidden">
                        <h3 class="font-headline font-bold text-xl text-primary leading-tight truncate">@turnoSeleccionado.ClienteNombre</h3>
                        <p class="text-sm text-on-surface-variant truncate mt-0.5">@turnoSeleccionado.ServicioNombre</p>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4 mb-6 bg-surface-container-lowest p-4 rounded-2xl border border-surface-container-low">
                    <div>
                        <span class="block text-[9px] font-bold text-on-surface-variant uppercase tracking-widest mb-1">Horario</span>
                        <span class="font-bold text-primary text-sm">
                            @turnoSeleccionado.FechaHoraInicioUtc.ToLocalTime().ToString("HH:mm") - @turnoSeleccionado.FechaHoraFinUtc.ToLocalTime().ToString("HH:mm")
                        </span>
                    </div>
                    <div>
                        <span class="block text-[9px] font-bold text-on-surface-variant uppercase tracking-widest mb-1">Estado</span>
                        <span class="text-[10px] font-bold uppercase tracking-tighter @Zenda.Client.Extensions.EstadoTurnoExtensions.ObtenerColorEstado(turnoSeleccionado.Estado) px-2 py-0.5 rounded-md inline-block mt-0.5">
                            @turnoSeleccionado.Estado
                        </span>
                    </div>
                    <div>
                        <span class="block text-[9px] font-bold text-on-surface-variant uppercase tracking-widest mb-1">Profesional</span>
                        <span class="text-sm text-primary font-medium truncate block">@turnoSeleccionado.PrestadorNombre</span>
                    </div>
                    <div>
                        <span class="block text-[9px] font-bold text-on-surface-variant uppercase tracking-widest mb-1">Duración</span>
                        <span class="text-sm text-primary font-medium">@turnoSeleccionado.DuracionMinutos min</span>
                    </div>
                </div>

                <div class="flex flex-col gap-3">
                    <a href="@GenerarWhatsAppUrl(turnoSeleccionado.ClienteTelefono, turnoSeleccionado.ClienteNombre, turnoSeleccionado.FechaHoraInicioUtc.ToLocalTime())" target="_blank"
                       class="w-full py-3 flex items-center justify-center gap-2 rounded-xl bg-[#25D366]/10 text-[#25D366] font-bold hover:bg-[#25D366] hover:text-white transition-colors">
                        <i class="fa-brands fa-whatsapp text-lg"></i>
                        Contactar por WhatsApp
                    </a>

                    @if (turnoSeleccionado.Estado != EstadoTurnoEnum.Completado && turnoSeleccionado.Estado != EstadoTurnoEnum.Cancelado)
                    {
                        <div class="flex gap-3">
                            <button @onclick="PrepararCobroDesdeDetalle" class="flex-1 py-3 flex items-center justify-center gap-2 rounded-xl bg-green-500/10 text-green-700 font-bold hover:bg-green-500 hover:text-white transition-colors">
                                <span class="material-symbols-outlined text-[18px]">task_alt</span>
                                Cobrar
                            </button>
                            <button @onclick="PrepararCancelacionDesdeDetalle" class="flex-1 py-3 flex items-center justify-center gap-2 rounded-xl bg-red-600/10 text-red-600 font-bold hover:bg-red-600 hover:text-white transition-colors">
                                <span class="material-symbols-outlined text-[18px]">block</span>
                                Cancelar
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

<NuevoTurnoAdminDrawer @bind-Visible="mostrarDrawerTurno" OnTurnoGuardado="() => CargarTurnosDesdeCero()"></NuevoTurnoAdminDrawer>