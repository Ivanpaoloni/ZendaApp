@page "/turnos"
@using Zenda.Core.DTOs
@using Zenda.Client.Services
@using Zenda.Core.Enums
@inject TurnoClient TurnoService

<div class="space-y-6 animate-in fade-in duration-500 pb-20 relative">

    @* ========================================== *@
    @* 1. HEADER Y SELECTOR DE FECHA PRINCIPAL *@
    @* ========================================== *@
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
            <div class="flex items-center gap-3">
                <h1 class="text-3xl font-bold text-primary tracking-tighter font-headline">Agenda del Día</h1>

                @* NUEVO: Botón de Refresh y Label de Hora *@
                <div class="flex items-center gap-2 mt-1">
                    <button @onclick="RefrescarManual" disabled="@cargando"
                            class="w-8 h-8 flex items-center justify-center rounded-full bg-surface-container-low text-primary hover:bg-primary/10 transition-colors disabled:opacity-50" title="Refrescar turnos">
                        <span class="material-symbols-outlined text-[18px] @(cargando ? "animate-spin" : "")">refresh</span>
                    </button>
                    <span class="text-[10px] font-bold text-on-surface-variant/50 uppercase tracking-widest hidden sm:inline-block">
                        Actualizado @ultimaActualizacion.ToString("HH:mm")
                    </span>
                </div>
            </div>
            <p class="text-on-surface-variant text-sm mt-1">Mostrando los turnos del <strong>@fechaFiltro.Date.ToShortDateString()</strong></p>
        </div>

        @* El motor de búsqueda por día *@
        <div class="flex items-center gap-3 w-full md:w-auto mt-2 md:mt-0">
            @if (fechaFiltro.Date != DateTime.Today)
            {
                <button @onclick="IrAHoy" class="px-4 py-3 bg-secondary-container/50 text-on-secondary-container text-xs font-bold uppercase tracking-widest rounded-xl hover:bg-secondary-container transition-colors shrink-0 animate-in fade-in slide-in-from-right-4">
                    Ir a Hoy
                </button>
            }

            @* Modificamos el binding para que al cambiar la fecha limpie los filtros *@
            <input type="date" @bind="fechaFiltro" @bind:after="CambiarFecha"
                   class="w-full md:w-auto p-4 bg-white rounded-2xl border-none shadow-sm font-headline font-bold text-primary focus:ring-2 focus:ring-primary outline-none cursor-pointer" />
        </div>
    </div>

    @* ========================================== *@
    @* 2. BARRA DE FILTROS AVANZADOS (Colapsable) *@
    @* ========================================== *@
    @if (turnosDelDia.Any())
    {
        <div class="bg-surface-container-low rounded-2xl border border-surface-container-high overflow-hidden shadow-sm">

            @* CABECERA DEL ACORDEÓN *@
            <button @onclick="ToggleFiltros" class="w-full flex items-center justify-between p-3 md:px-4 hover:bg-surface-container-highest/20 transition-colors">
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-on-surface-variant text-[20px]">filter_list</span>
                    <span class="text-xs font-bold text-on-surface-variant uppercase tracking-widest">Filtros Visuales</span>

                    @* Indicador de filtros activos *@
                    @if (!mostrarFiltros && CantidadFiltrosActivos > 0)
                    {
                        <span class="bg-primary text-white text-[9px] font-bold px-2 py-0.5 rounded-full ml-2 animate-pulse">
                            @CantidadFiltrosActivos ACTIVOS
                        </span>
                    }
                </div>

                <div class="flex items-center gap-4">
                    @if (CantidadFiltrosActivos > 0)
                    {
                        <div @onclick:stopPropagation @onclick="LimpiarFiltros" class="text-[10px] font-bold text-error hover:underline cursor-pointer uppercase tracking-wider">
                            Limpiar todo
                        </div>
                    }
                    <span class="material-symbols-outlined text-on-surface-variant transition-transform duration-300 @(mostrarFiltros ? "rotate-180" : "")">
                        expand_more
                    </span>
                </div>
            </button>

            @* CUERPO DEL ACORDEÓN *@
            @if (mostrarFiltros)
            {
                <div class="p-3 md:px-4 pb-4 flex flex-wrap gap-3 items-end border-t border-surface-container-high/50 bg-surface-container-lowest/50 animate-in slide-in-from-top-2 fade-in">

                    @* 1. Búsqueda por Cliente *@
                    <div class="flex flex-col gap-1 w-full md:w-auto md:flex-grow max-w-sm">
                        <label class="text-[9px] font-bold text-on-surface-variant uppercase tracking-widest ml-1">Buscar Cliente</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-3 top-2.5 text-[18px] text-on-surface-variant/50">search</span>
                            <input type="text" @bind="busquedaCliente" @bind:event="oninput" placeholder="Ej: Juan Pérez..."
                                   class="w-full bg-white border border-surface-container-high rounded-xl pl-9 pr-4 py-2 text-sm font-bold text-primary outline-none focus:border-primary shadow-sm transition-all" />
                        </div>
                    </div>

                    @* 2. Estado *@
                    <div class="flex flex-col gap-1 w-full sm:w-auto">
                        <label class="text-[9px] font-bold text-on-surface-variant uppercase tracking-widest ml-1">Estado</label>
                        <select @bind="estadoFiltro" class="bg-white border border-surface-container-high rounded-xl pl-3 pr-8 py-2 text-sm font-bold text-primary outline-none focus:border-primary cursor-pointer shadow-sm min-w-[140px]">
                            <option value="">Todos</option>
                            <option value="@EstadoTurnoEnum.Pendiente.ToString()">Pendientes</option>
                            <option value="@EstadoTurnoEnum.Confirmado.ToString()">Confirmados</option>
                            <option value="@EstadoTurnoEnum.Completado.ToString()">Completados</option>
                            <option value="@EstadoTurnoEnum.Cancelado.ToString()">Cancelados</option>
                        </select>
                    </div>

                    @* 3. Sede (Solo si hay más de 1) *@
                    @if (listaSedesDropdown.Count > 1)
                    {
                        <div class="flex flex-col gap-1 w-full sm:w-auto">
                            <label class="text-[9px] font-bold text-on-surface-variant uppercase tracking-widest ml-1">Sede</label>
                            <select @bind="sedeFiltro" class="bg-white border border-surface-container-high rounded-xl pl-3 pr-8 py-2 text-sm font-bold text-primary outline-none focus:border-primary cursor-pointer shadow-sm max-w-[200px] truncate">
                                <option value="">Todas</option>
                                @foreach (var sede in listaSedesDropdown)
                                {
                                    <option value="@sede">@sede</option>
                                }
                            </select>
                        </div>
                    }

                    @* 4. Profesional (Solo si hay más de 1) *@
                    @if (listaProfesionalesDropdown.Count > 1)
                    {
                        <div class="flex flex-col gap-1 w-full sm:w-auto">
                            <label class="text-[9px] font-bold text-on-surface-variant uppercase tracking-widest ml-1">Profesional</label>
                            <select @bind="profesionalFiltro" class="bg-white border border-surface-container-high rounded-xl pl-3 pr-8 py-2 text-sm font-bold text-primary outline-none focus:border-primary cursor-pointer shadow-sm max-w-[200px] truncate">
                                <option value="">Todos</option>
                                @foreach (var prof in listaProfesionalesDropdown)
                                {
                                    <option value="@prof">@prof</option>
                                }
                            </select>
                        </div>
                    }

                    @* 5. Servicio (Solo si hay más de 1) *@
                    @if (listaServiciosDropdown.Count > 1)
                    {
                        <div class="flex flex-col gap-1 w-full sm:w-auto">
                            <label class="text-[9px] font-bold text-on-surface-variant uppercase tracking-widest ml-1">Servicio</label>
                            <select @bind="servicioFiltro" class="bg-white border border-surface-container-high rounded-xl pl-3 pr-8 py-2 text-sm font-bold text-primary outline-none focus:border-primary cursor-pointer shadow-sm max-w-[200px] truncate">
                                <option value="">Todos</option>
                                @foreach (var serv in listaServiciosDropdown)
                                {
                                    <option value="@serv">@serv</option>
                                }
                            </select>
                        </div>
                    }
                </div>
            }
        </div>
    }

    @* --- ESTADO DE CARGA Y VACÍO --- *@
    @if (cargando)
    {
        <div class="flex flex-col items-center justify-center py-20">
            <div class="animate-spin rounded-full h-10 w-10 border-t-2 border-b-2 border-primary"></div>
        </div>
    }
    else if (!turnosDelDia.Any())
    {
        <div class="bg-white/50 border-2 border-dashed border-outline-variant rounded-4xl p-12 text-center flex flex-col items-center justify-center min-h-[300px]">
            <span class="material-symbols-outlined text-6xl text-on-surface-variant/50 mb-4">coffee</span>
            <h3 class="font-headline font-bold text-xl text-primary mb-2">Día libre</h3>
            <p class="text-on-surface-variant font-body text-sm">No hay turnos programados para la fecha seleccionada.</p>
        </div>
    }
    else
    {
    @* --- CONTENEDOR GRID RESPONSIVO --- *@
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-5 gap-6 items-start">

            @* ITERAMOS SOBRE LA PROPIEDAD FILTRADA *@
            @foreach (var grupo in GruposFiltrados)
            {
                <div class="flex flex-col gap-4">

                    @* CABECERA DEL PROFESIONAL *@
                    <div class="bg-white p-3 rounded-2xl flex items-center justify-between border border-surface-container-high shadow-sm sticky top-0 z-10">
                        <div class="flex items-center gap-2">
                            <div class="w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center text-xs font-black">
                                @(grupo.Key.FirstOrDefault())
                            </div>
                            <span class="font-bold text-primary">@grupo.Key</span>
                        </div>
                        <span class="text-[10px] font-bold bg-surface-container-low text-on-surface-variant px-2 py-1 rounded-lg">
                            @grupo.Value.Count turnos
                        </span>
                    </div>

                    @* LISTA DE TURNOS DEL PROFESIONAL *@
                    <div class="flex flex-col gap-3">
                        @foreach (var turno in grupo.Value.OrderBy(t => t.FechaHoraInicioUtc))
                        {
                            var horaInicio = turno.FechaHoraInicioUtc.ToLocalTime();

                            var colorBorde = turno.Estado == EstadoTurnoEnum.Pendiente ? "border-l-warning" :
                            turno.Estado == EstadoTurnoEnum.Confirmado ? "border-l-success" :
                            turno.Estado == EstadoTurnoEnum.Cancelado ? "border-l-error" : "border-l-surface-container-highest";

                            <div class="bg-white p-3 rounded-xl border border-surface-container-high border-l-[4px] @colorBorde shadow-sm hover:shadow-md transition-shadow relative group">

                                <div class="flex justify-between items-start mb-2">
                                    <div class="flex flex-col">
                                        <div class="flex gap-1.5 items-center">
                                            <span class="font-black text-primary text-lg leading-none">@horaInicio.ToString("HH:mm")</span>
                                            <span class="text-[9px] bg-surface-container-low px-1 py-0.5 rounded text-on-surface-variant font-bold leading-none">@turno.DuracionMinutos min</span>
                                        </div>
                                        @* Badge de Estado *@
                                        <span class="text-[9px] font-black uppercase tracking-tighter @EstadoTurnoExtensions.ObtenerColorEstado(turno.Estado) mt-1 px-1 py-0.5 rounded-sm inline-block w-fit">
                                            @turno.Estado
                                        </span>
                                    </div>

                                    @* Botones rápidos *@
                                    <div class="flex gap-1">
                                        @if (turno.Estado != EstadoTurnoEnum.Completado && turno.Estado != EstadoTurnoEnum.Cancelado)
                                        {
                                            <a href="@GenerarWhatsAppUrl(turno.TelefonoClienteInvitado, turno.NombreClienteInvitado, horaInicio)" target="_blank"
                                               class="w-8 h-8 flex items-center justify-center rounded-lg bg-[#25D366]/10 text-[#25D366] hover:bg-[#25D366] hover:text-white transition-colors" title="WhatsApp">
                                                <i class="fa-brands fa-whatsapp text-[16px]"></i>
                                            </a>

                                            <button @onclick="() => CambiarEstado(turno.Id, EstadoTurnoEnum.Completado)"
                                                    class="w-8 h-8 flex items-center justify-center rounded-lg bg-green-500/10 text-green-700 hover:bg-green-500 hover:text-white transition-colors" title="Cobrar">
                                                <span class="material-symbols-outlined text-[16px]">task_alt</span>
                                            </button>

                                            <button @onclick="() => CambiarEstado(turno.Id, EstadoTurnoEnum.Cancelado)"
                                                    class="w-8 h-8 flex items-center justify-center rounded-lg bg-red-600/10 text-red-600 hover:bg-red-600 hover:text-white transition-colors" title="Cancelar Turno">
                                                <span class="material-symbols-outlined text-[16px]">block</span>
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="material-symbols-outlined text-on-surface-variant/20 text-[20px] p-1">
                                                @(turno.Estado == EstadoTurnoEnum.Completado ? "done_all" : "close")
                                            </span>
                                        }
                                    </div>
                                </div>

                                <h4 class="font-bold text-sm text-primary leading-tight truncate">@turno.NombreClienteInvitado</h4>
                                <p class="text-[11px] text-on-surface-variant truncate mt-0.5">@turno.ServicioNombre</p>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Inject] private NegocioClient _negocioService { get; set; } = default!;
    [Inject] private AppState State { get; set; } = default!;

    private DateTime fechaFiltro = DateTime.Today;
    private bool cargando = true;
    private List<TurnoReadDto> turnosDelDia = new();
    private Dictionary<string, List<TurnoReadDto>> turnosPorProfesional = new();
    private DateTime ultimaActualizacion = DateTime.Now;

    // Variables de UI para los Filtros
    private bool mostrarFiltros = false;
    private string busquedaCliente = "";
    private string estadoFiltro = "";
    private string profesionalFiltro = "";
    private string sedeFiltro = "";
    private string servicioFiltro = "";

    // Listas para poblar los selects
    private List<string> listaProfesionalesDropdown = new();
    private List<string> listaSedesDropdown = new();
    private List<string> listaServiciosDropdown = new();

    // Propiedad calculada que cuenta cuántos filtros están en uso
    private int CantidadFiltrosActivos =>
        (!string.IsNullOrWhiteSpace(busquedaCliente) ? 1 : 0) +
        (!string.IsNullOrEmpty(estadoFiltro) ? 1 : 0) +
        (!string.IsNullOrEmpty(profesionalFiltro) ? 1 : 0) +
        (!string.IsNullOrEmpty(sedeFiltro) ? 1 : 0) +
        (!string.IsNullOrEmpty(servicioFiltro) ? 1 : 0);

    protected override async Task OnInitializedAsync()
    {
        await CargarTurnos(mantenerFiltros: false);
    }

    //metodos de filtrado y actualizacion

    private void ToggleFiltros() => mostrarFiltros = !mostrarFiltros;

    private void LimpiarFiltros()
    {
        busquedaCliente = "";
        estadoFiltro = "";
        profesionalFiltro = "";
        sedeFiltro = "";
        servicioFiltro = "";
    }

    private Dictionary<string, List<TurnoReadDto>> GruposFiltrados
    {
        get
        {
            var filtrados = turnosPorProfesional.AsEnumerable();

            // Filtro de Profesional (oculta columnas enteras)
            if (!string.IsNullOrEmpty(profesionalFiltro))
            {
                filtrados = filtrados.Where(g => g.Key == profesionalFiltro);
            }

            // Filtros internos de las tarjetas
            if (!string.IsNullOrWhiteSpace(busquedaCliente) ||
                !string.IsNullOrEmpty(estadoFiltro) ||
                !string.IsNullOrEmpty(sedeFiltro) ||
                !string.IsNullOrEmpty(servicioFiltro))
            {
                filtrados = filtrados.Select(g => new KeyValuePair<string, List<TurnoReadDto>>(
                    g.Key,
                    g.Value.Where(t =>
                        (string.IsNullOrWhiteSpace(busquedaCliente) || t.NombreClienteInvitado.Contains(busquedaCliente, StringComparison.OrdinalIgnoreCase)) &&
                        (string.IsNullOrEmpty(estadoFiltro) || t.Estado.ToString() == estadoFiltro) &&
                        (string.IsNullOrEmpty(sedeFiltro) || t.SedeNombre == sedeFiltro) &&
                        (string.IsNullOrEmpty(servicioFiltro) || t.ServicioNombre == servicioFiltro)
                    ).ToList()
                ))
                .Where(g => g.Value.Any());
            }

            return filtrados.ToDictionary(g => g.Key, g => g.Value);
        }
    }



    private async Task IrAHoy()
    {
        fechaFiltro = DateTime.Today;
        await CargarTurnos(mantenerFiltros: false); // Al cambiar de día, limpiamos filtros
    }

    private async Task CambiarFecha()
    {
        await CargarTurnos(mantenerFiltros: false); // Al cambiar de día, limpiamos filtros
    }

    // NUEVO MÉTODO: Refresca pero le dice a CargarTurnos que NO borre los filtros
    private async Task RefrescarManual()
    {
        await CargarTurnos(mantenerFiltros: true);
    }

    private async Task CargarTurnos(bool mantenerFiltros)
    {
        cargando = true;
        StateHasChanged();

        try
        {
            turnosDelDia = await TurnoService.GetByFecha(fechaFiltro) ?? new List<TurnoReadDto>();

            listaProfesionalesDropdown = turnosDelDia.Select(t => t.PrestadorNombre).Distinct().OrderBy(n => n).ToList();
            listaSedesDropdown = turnosDelDia.Select(t => t.SedeNombre).Where(s => !string.IsNullOrEmpty(s)).Distinct().OrderBy(n => n).ToList();
            listaServiciosDropdown = turnosDelDia.Select(t => t.ServicioNombre).Distinct().OrderBy(n => n).ToList();

            turnosPorProfesional = turnosDelDia
                .GroupBy(t => t.PrestadorNombre)
                .ToDictionary(g => g.Key, g => g.ToList());

            ultimaActualizacion = DateTime.Now; // Actualizamos la hora visual

            if (!mantenerFiltros)
            {
                LimpiarFiltros();
            }
            else
            {
                // SÚPER DETALLE UX: Si refrescamos y mantenemos los filtros, validamos que los filtros actuales sigan existiendo.
                // Ej: Tenías filtrado a "Martín", pero justo cancelaron el único turno de Martín.
                // Para que la pantalla no quede vacía por un filtro roto, lo limpiamos inteligentemente.
                if (!string.IsNullOrEmpty(profesionalFiltro) && !listaProfesionalesDropdown.Contains(profesionalFiltro)) profesionalFiltro = "";
                if (!string.IsNullOrEmpty(sedeFiltro) && !listaSedesDropdown.Contains(sedeFiltro)) sedeFiltro = "";
                if (!string.IsNullOrEmpty(servicioFiltro) && !listaServiciosDropdown.Contains(servicioFiltro)) servicioFiltro = "";
            }
        }
        catch
        {
            turnosDelDia = new();
            turnosPorProfesional = new();
            listaProfesionalesDropdown = new();
            listaSedesDropdown = new();
            listaServiciosDropdown = new();
        }
        finally
        {
            cargando = false;
        }
    }

    private async Task CambiarEstado(Guid id, EstadoTurnoEnum nuevoEstado)
    {
        try
        {
            var exito = await TurnoService.ActualizarEstado(id, nuevoEstado);
            if (exito)
            {
                var turnoModificado = turnosDelDia.FirstOrDefault(t => t.Id == id);
                if (turnoModificado != null)
                {
                    turnoModificado.Estado = nuevoEstado;
                    StateHasChanged();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cambiar estado: {ex.Message}");
        }
    }

    private string GenerarWhatsAppUrl(string telefono, string nombre, DateTime inicioLocal)
    {
        var nombreNegocio = State.CurrentNegocio?.Nombre ?? "nuestro local";
        var mensaje = $"¡Hola {nombre}! Te escribo de {nombreNegocio} para recordarte tu turno de hoy a las {inicioLocal:HH:mm} hs.";
        var telefonoLimpio = new string(telefono.Where(char.IsDigit).ToArray());
        return $"https://wa.me/{telefonoLimpio}?text={Uri.EscapeDataString(mensaje)}";
    }
}