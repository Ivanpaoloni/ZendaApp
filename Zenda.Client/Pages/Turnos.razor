@page "/turnos"
@using Zenda.Core.DTOs
@using Zenda.Client.Services
@using Zenda.Core.Enums
@inject TurnoClient TurnoService

<div class="space-y-8 animate-in fade-in duration-500 pb-20 relative">

    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
            <h1 class="text-3xl font-bold text-primary tracking-tighter font-headline">Agenda del Día</h1>
            <p class="text-on-surface-variant text-sm">Turnos.</p>
        </div>

        <input type="date" @bind="fechaFiltro" @bind:after="CargarTurnos"
               class="p-4 bg-white rounded-2xl border-none editorial-shadow font-headline font-bold text-primary focus:ring-2 focus:ring-primary outline-none max-w-[200px]" />
    </div>

    @if (cargando)
    {
        <div class="flex flex-col items-center justify-center py-20">
            <div class="animate-spin rounded-full h-10 w-10 border-t-2 border-b-2 border-primary"></div>
        </div>
    }
    else if (!turnosDelDia.Any())
    {
        <div class="bg-white/50 border-2 border-dashed border-outline-variant rounded-4xl p-12 text-center flex flex-col items-center justify-center min-h-[300px]">
            <span class="material-symbols-outlined text-6xl text-on-surface-variant/50 mb-4">coffee</span>
            <h3 class="font-headline font-bold text-xl text-primary mb-2">Agenda libre</h3>
            <p class="text-on-surface-variant font-body text-sm">No hay turnos programados para esta fecha.</p>
        </div>
    }
    else
    {
        <div class="space-y-4">
            @* Ordenamos por la hora de inicio *@
            @foreach (var turno in turnosDelDia.OrderBy(t => t.FechaHoraInicioUtc))
            {
                <div class="bg-white p-6 md:p-8 rounded-3xl editorial-shadow flex flex-col md:flex-row md:items-center justify-between gap-6 border border-transparent hover:border-primary/10 transition-all group">

                    <div class="flex items-center gap-6">
                        @* Bloque de Hora *@
                        <div class="bg-surface-container-low text-primary p-4 rounded-2xl text-center min-w-[100px]">
                            <p class="font-headline font-black text-2xl">@turno.FechaHoraInicioUtc.ToLocalTime().ToString("HH:mm")</p>
                            <p class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mt-1">hs</p>
                        </div>

                        <div>
                            <div class="flex items-center gap-2 mb-1">
                                <h3 class="font-headline font-bold text-xl text-primary">@turno.NombreClienteInvitado</h3>

                                @* Badge de Estado con Color Dinámico *@
                                <span class="px-2 py-0.5 @EstadoTurnoExtensions.ObtenerColorEstado(turno.Estado) text-[9px] font-bold uppercase tracking-wider rounded-lg transition-colors">
                                    @turno.Estado
                                </span>
                            </div>

                            <div class="flex items-center gap-3 text-sm text-on-surface-variant font-body">
                                <span class="flex items-center gap-1">
                                    <span class="material-symbols-outlined text-xs">content_cut</span>
                                    @turno.PrestadorNombre
                                </span>
                                <span class="opacity-20">|</span>
                                <span class="flex items-center gap-1">
                                    <span class="material-symbols-outlined text-xs">phone_iphone</span>
                                    @turno.TelefonoClienteInvitado
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="flex items-center gap-2 border-t border-surface-container-high md:border-t-0 pt-4 md:pt-0">

                        @* Botón de WhatsApp (Siempre visible) *@
                        <a href="@GenerarWhatsAppUrl(turno.TelefonoClienteInvitado, turno.NombreClienteInvitado, turno.FechaHoraInicioUtc.ToLocalTime())"
                           target="_blank"
                           class="w-11 h-11 bg-[#25D366]/10 text-[#25D366] rounded-xl flex items-center justify-center hover:bg-[#25D366] hover:text-white transition-all shadow-sm" title="WhatsApp">
                            <i class="fa-brands fa-whatsapp text-2xl"></i>
                        </a>

                        @* Acciones según estado (Usando el Enum que definimos) *@
                        @if (turno.Estado == EstadoTurnoEnum.Pendiente)
                        {
                            <button @onclick="() => CambiarEstado(turno.Id, EstadoTurnoEnum.Confirmado)"
                                    class="px-4 py-3 bg-primary/10 text-primary rounded-xl font-bold text-[11px] uppercase hover:bg-primary hover:text-white transition-all">
                                Confirmar
                            </button>
                        }

                        @if (turno.Estado == EstadoTurnoEnum.Confirmado || turno.Estado == EstadoTurnoEnum.Pendiente)
                        {
                            <button @onclick="() => CambiarEstado(turno.Id, EstadoTurnoEnum.Completado)"
                                    class="px-4 py-3 bg-green-500/10 text-green-700 rounded-xl font-bold text-[11px] uppercase hover:bg-green-500 hover:text-white transition-all">
                                Finalizar
                            </button>

                            <button @onclick="() => CambiarEstado(turno.Id, EstadoTurnoEnum.Cancelado)"
                                    class="w-11 h-11 text-on-surface-variant/70 bg-surface-container-low hover:bg-error/10 hover:text-error rounded-xl transition-all" title="Cancelar Turno">
                                <span class="material-symbols-outlined">block</span>
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private DateTime fechaFiltro = DateTime.Today;
    private bool cargando = true;
    private List<TurnoReadDto> turnosDelDia = new();

    protected override async Task OnInitializedAsync()
    {
        await CargarTurnos();
    }
    // Método para manejar los clics de los botones
    private async Task CambiarEstado(Guid id, EstadoTurnoEnum nuevoEstado)
    {
        try
        {
            var exito = await TurnoService.ActualizarEstado(id, nuevoEstado);
            if (exito)
            {
                await CargarTurnos(); // Recargamos la lista para ver el cambio
            }
        }
        catch (Exception ex)
        {
            // Aquí podrías usar un Toast o notificación de error
            Console.WriteLine($"Error al cambiar estado: {ex.Message}");
        }
    }

    private async Task CargarTurnos()
    {
        cargando = true;
        try
        {
            // Llamada real al backend!
            turnosDelDia = await TurnoService.GetByFecha(fechaFiltro) ?? new List<TurnoReadDto>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando agenda: {ex.Message}");
            turnosDelDia = new();
        }
        finally
        {
            cargando = false;
        }
    }

    private string GenerarWhatsAppUrl(string telefono, string nombre, DateTime inicioLocal)
    {
        var mensaje = $"¡Hola {nombre}! Te escribo de Zenda para recordarte tu turno de hoy a las {inicioLocal:HH:mm} hs.";
        return $"https://wa.me/{telefono}?text={Uri.EscapeDataString(mensaje)}";
    }
}