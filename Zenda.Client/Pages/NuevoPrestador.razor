@page "/nuevo-prestador"
@using Zenda.Core.DTOs
@inject HttpClient Http
@inject NavigationManager Nav
@inject PrestadorClient PrestadorService
@inject SedeClient SedeService

<div class="mb-12 animate-in fade-in slide-in-from-bottom-4 duration-700">
    <button @onclick="Volver" class="flex items-center gap-2 text-primary font-headline font-bold text-sm mb-6 hover:opacity-70 transition-opacity">
        <span class="material-symbols-outlined">arrow_back</span>
        Volver al equipo
    </button>
    <h1 class="text-4xl font-headline font-extrabold text-primary tracking-tight">Agregar Profesional</h1>
    <p class="text-on-surface-variant mt-2 font-body">Completa el perfil para empezar a recibir turnos.</p>
</div>

<div class="max-w-2xl bg-white p-10 rounded-4xl editorial-shadow border border-surface-container-high">
    @if (sedes == null)
    {
        <div class="flex items-center justify-center py-10">
            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
            <p class="ml-3 text-primary font-body">Cargando sedes...</p>
        </div>
    }
    else
    {
        <EditForm Model="@nuevoPrestador" OnValidSubmit="GuardarPrestador" class="space-y-8">
            <DataAnnotationsValidator />

            <div class="space-y-2">
                <label class="text-xs font-bold tracking-widest uppercase font-body text-on-surface-variant px-1">NOMBRE COMPLETO</label>
                <InputText @bind-Value="nuevoPrestador.Nombre"
                           class="w-full px-6 py-4 bg-surface-container-low border-none rounded-2xl focus:ring-2 focus:ring-primary focus:bg-white transition-all outline-none font-body"
                           placeholder="Ej. Ivan Barber" />
                <ValidationMessage For="@(() => nuevoPrestador.Nombre)" class="text-error text-xs px-1" />
            </div>

            @* 2. Agregamos el Select de Sedes *@
            <div class="space-y-2">
                <label class="text-xs font-bold tracking-widest uppercase font-body text-on-surface-variant px-1">SEDE / SUCURSAL</label>
                <InputSelect @bind-Value="nuevoPrestador.SedeId"
                             class="w-full px-6 py-4 bg-surface-container-low border-none rounded-2xl focus:ring-2 focus:ring-primary focus:bg-white transition-all outline-none font-body appearance-none">
                    <option value="@Guid.Empty">Seleccione una sede...</option>
                    @foreach (var s in sedes)
                    {
                        <option value="@s.Id">@s.Nombre</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => nuevoPrestador.SedeId)" class="text-error text-xs px-1" />
            </div>

            <div class="space-y-2">
                <label class="text-xs font-bold tracking-widest uppercase font-body text-on-surface-variant px-1">DURACIÓN TURNO (MIN)</label>
                <InputNumber @bind-Value="nuevoPrestador.DuracionTurnoMinutos"
                             class="w-full px-6 py-4 bg-surface-container-low border-none rounded-2xl focus:ring-2 focus:ring-primary focus:bg-white transition-all outline-none font-body" />
                <ValidationMessage For="@(() => nuevoPrestador.DuracionTurnoMinutos)" class="text-error text-xs px-1" />
            </div>

            @if (!string.IsNullOrEmpty(mensajeError))
            {
                <div class="p-4 bg-error/10 border border-error/20 text-error rounded-2xl text-sm font-body">
                    @mensajeError
                </div>
            }

            <div class="pt-4">
                <button type="submit" disabled="@enviando"
                        class="w-full py-4 bg-primary text-on-primary rounded-xl font-headline font-bold text-lg scale-100 hover:scale-[1.02] active:scale-95 transition-all editorial-shadow flex items-center justify-center gap-2 disabled:opacity-50">
                    @if (enviando)
                    {
                        <div class="animate-spin rounded-full h-5 w-5 border-b-2 border-white"></div>
                        <span>Guardando...</span>
                    }
                    else
                    {
                        <span>Crear Profesional</span>
                        <span class="material-symbols-outlined">person_add</span>
                    }
                </button>
            </div>
        </EditForm>
    }
</div>

@code {
    private PrestadorCreateDto nuevoPrestador = new() { DuracionTurnoMinutos = 30 };
    private List<SedeReadDto>? sedes;
    private bool enviando = false;
    private string? mensajeError;

    protected override async Task OnInitializedAsync()
    {
        // 3. Cargamos las sedes al iniciar
        try 
        {
            sedes = await SedeService.GetAll();
            
            // Si solo hay una sede, la pre-seleccionamos
            if (sedes.Count == 1)
            {
                nuevoPrestador.SedeId = sedes[0].Id;
            }
        }
        catch (Exception ex)
        {
            mensajeError = "No se pudieron cargar las sedes.";
            sedes = new(); // Evita el loop de carga infinito
        }
    }

    private async Task GuardarPrestador()
    {
        if (nuevoPrestador.SedeId == Guid.Empty)
        {
            mensajeError = "Debes seleccionar una sede válida.";
            return;
        }

        enviando = true;
        mensajeError = null;

        var resultado = await PrestadorService.Create(nuevoPrestador);

        if (resultado.Success)
        {
            Nav.NavigateTo("prestadores");
        }
        else
        {
            mensajeError = resultado.ErrorMessage;
        }

        enviando = false;
    }

    private void Volver() => Nav.NavigateTo("prestadores");
}