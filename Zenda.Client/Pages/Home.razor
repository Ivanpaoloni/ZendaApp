@page "/"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Zenda.Core.DTOs
@using Zenda.Core.Enums

<div class="mb-8 animate-in fade-in slide-in-from-bottom-4 duration-700">
    @* <span class="inline-block px-4 py-1.5 mb-4 bg-secondary-container text-on-secondary-container rounded-full text-[10px] font-bold tracking-widest uppercase font-body">
        RESUMEN DE HOY
    </span> *@
    <h1 class="text-4xl md:text-5xl font-headline font-extrabold text-primary tracking-tight">
        Hola, @nombreUsuario
    </h1>
    <p class="text-on-surface-variant mt-2 font-body">Acá tenés el resumen de tu negocio para el @DateTime.Today.ToString("dd 'de' MMMM").</p>
</div>
@if (ausenciasHoy != null && ausenciasHoy.Any())
{
    <div class="mb-10 bg-warning/10 border-2 border-warning/20 p-6 rounded-3xl animate-in zoom-in duration-500">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-full bg-warning/20 text-warning-dark flex items-center justify-center">
                <span class="material-symbols-outlined text-xl">person_off</span>
            </div>
            <div>
                <h3 class="text-warning-dark font-bold font-headline">Avisos del Equipo</h3>
                <p class="text-warning-dark/80 text-xs">Tenés @(ausenciasHoy.Count) profesional@(ausenciasHoy.Count > 1 ? "es" : "") con licencia hoy.</p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
            @foreach (var ausencia in ausenciasHoy)
            {
                <div class="bg-white/60 p-3 rounded-2xl border border-warning/30 flex items-center gap-3">
                    <span class="material-symbols-outlined text-warning-dark/50 text-2xl">schedule</span>
                    <div>
                        @{
                            var partes = (ausencia.Motivo ?? "").Split(':');
                            var nombre = partes.Length > 0 ? partes[0] : "Profesional";
                            var detalle = partes.Length > 1 ? partes[1].Trim() : "Ausente";

                            // Transformamos a hora local del navegador para que se vea bien
                            var horaInicio = ausencia.InicioLocal.ToLocalTime().ToString("HH:mm");
                            var horaFin = ausencia.FinLocal.ToLocalTime().ToString("HH:mm");
                        }
                        <p class="text-sm font-bold text-warning-dark">@nombre</p>
                        <p class="text-xs text-warning-dark/90 font-medium mt-0.5">De @horaInicio a @horaFin</p>
                        @if (!string.IsNullOrEmpty(detalle) && detalle != "Ausente")
                        {
                            <p class="text-[10px] text-warning-dark/60 uppercase tracking-widest font-bold mt-0.5">@detalle</p>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}
@if (!cargando && (totalPrestadores == 0 || sedesContador == 0 || serviciosContador == 0))
{
    <div class="mb-10 p-8 bg-primary/5 border-2 border-dashed border-primary/20 rounded-4xl animate-in zoom-in duration-500">
        <div class="flex items-center gap-4 mb-6">
            <div class="w-12 h-12 rounded-2xl bg-primary text-white flex items-center justify-center shadow-lg shadow-primary/20">
                <span class="material-symbols-outlined">rocket_launch</span>
            </div>
            <div>
                <h2 class="text-2xl font-headline font-extrabold text-primary">¡Bienvenido a Zendy, @nombreUsuario!</h2>
                <p class="text-on-surface-variant text-sm">Completá estos 3 pasos clave para empezar a recibir reservas.</p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">

            @if (sedesContador == 0)
            {
                <button @onclick='() => Nav.NavigateTo("/sedes")' class="p-6 bg-white rounded-3xl editorial-shadow hover:scale-[1.02] transition-all text-left flex items-center gap-4 group border border-transparent hover:border-orange-200">
                    <div class="w-12 h-12 flex-shrink-0 rounded-xl bg-orange-100 text-orange-600 flex items-center justify-center group-hover:bg-orange-600 group-hover:text-white transition-colors">
                        <span class="material-symbols-outlined">storefront</span>
                    </div>
                    <div>
                        <h4 class="font-bold text-primary leading-tight">1. Creá tu sede</h4>
                        <p class="text-xs text-on-surface-variant mt-1">El lugar físico de tus turnos.</p>
                    </div>
                </button>
            }

            @if (serviciosContador == 0)
            {
                <button @onclick='() => Nav.NavigateTo("/servicios")' class="p-6 bg-white rounded-3xl editorial-shadow hover:scale-[1.02] transition-all text-left flex items-center gap-4 group border border-transparent hover:border-purple-200">
                    <div class="w-12 h-12 flex-shrink-0 rounded-xl bg-purple-100 text-purple-600 flex items-center justify-center group-hover:bg-purple-600 group-hover:text-white transition-colors">
                        <span class="material-symbols-outlined">content_cut</span>
                    </div>
                    <div>
                        <h4 class="font-bold text-primary leading-tight">2. Tus servicios</h4>
                        <p class="text-xs text-on-surface-variant mt-1">Definí qué hacés y sus precios.</p>
                    </div>
                </button>
            }

            @if (totalPrestadores == 0)
            {
                <button @onclick='() => Nav.NavigateTo("/prestadores")' class="p-6 bg-white rounded-3xl editorial-shadow hover:scale-[1.02] transition-all text-left flex items-center gap-4 group border border-transparent hover:border-blue-200">
                    <div class="w-12 h-12 flex-shrink-0 rounded-xl bg-blue-100 text-blue-600 flex items-center justify-center group-hover:bg-blue-600 group-hover:text-white transition-colors">
                        <span class="material-symbols-outlined">person_add</span>
                    </div>
                    <div>
                        <h4 class="font-bold text-primary leading-tight">3. Tu equipo</h4>
                        <p class="text-xs text-on-surface-variant mt-1">Asigná quién hace los servicios.</p>
                    </div>
                </button>
            }
        </div>
    </div>
}

@* --- WIDGETS DE RESUMEN --- *@
@if (dashboardResumen != null && dashboardResumen.Ingresos != null)
{
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6 mb-10 animate-in fade-in slide-in-from-bottom-8 duration-700 delay-150">

        <a href="/caja" class="bg-white p-6 rounded-3xl editorial-shadow border border-transparent hover:border-primary/30 transition-all flex flex-col justify-between group cursor-pointer relative hover:-translate-y-1 active:scale-95 no-underline block">

            <div class="absolute right-4 top-4 p-1.5 text-on-surface-variant opacity-0 group-hover:opacity-100 group-hover:text-primary transition-all translate-x-2 group-hover:translate-x-0">
                <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
            </div>

            <div class="mb-4">
                <h6 class="text-xs font-bold uppercase tracking-widest text-on-surface-variant group-hover:text-primary transition-colors">Ingresos totales</h6>
                <p class="text-sm font-medium text-on-surface-variant/70 capitalize">@dashboardResumen.MesActualNombre</p>
            </div>

            <div>
                <p class="text-4xl font-headline font-black text-primary mb-2 group-hover:scale-[1.02] origin-left transition-transform">
                    @dashboardResumen.Ingresos.ValorActual.ToString("C0")
                </p>
                <div class="flex items-center text-sm">
                    <span class="@(dashboardResumen.Ingresos.EsCrecimientoPositivo ? "text-green-600" : "text-red-500") font-bold flex items-center bg-@(dashboardResumen.Ingresos.EsCrecimientoPositivo ? "green" : "red")-50 px-2 py-0.5 rounded-lg">
                        <span class="material-symbols-outlined text-[16px] mr-1">
                            @(dashboardResumen.Ingresos.EsCrecimientoPositivo ? "trending_up" : "trending_down")
                        </span>
                        @(dashboardResumen.Ingresos.EsCrecimientoPositivo ? "+" : "")@dashboardResumen.Ingresos.PorcentajeCrecimiento%
                    </span>
                    <span class="text-on-surface-variant/70 font-medium ml-2 text-xs">vs @dashboardResumen.MesAnteriorNombre</span>
                </div>
            </div>
        </a>

        <div class="bg-white p-6 rounded-3xl editorial-shadow border border-transparent hover:border-primary/20 transition-all flex flex-col justify-between relative overflow-hidden">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-orange-50 rounded-full opacity-50 pointer-events-none"></div>
            <div class="mb-4 relative z-10">
                <h6 class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">Día más fuerte</h6>
                <p class="text-sm font-medium text-on-surface-variant/70 capitalize">@dashboardResumen.MesActualNombre</p>
            </div>

            <div class="relative z-10">
                <p class="text-4xl font-headline font-black text-orange-600 mb-2">@dashboardResumen.DiaMasFuerte.Dia</p>
                <div class="flex items-center text-sm font-bold text-orange-500">
                    <span class="material-symbols-outlined text-[16px] mr-1">local_fire_department</span>
                    @dashboardResumen.DiaMasFuerte.Mensaje
                </div>
            </div>
        </div>

        <a href="/turnos" class="bg-white p-6 rounded-3xl editorial-shadow border border-transparent hover:border-primary/30 transition-all flex flex-col justify-between group cursor-pointer relative hover:-translate-y-1 active:scale-95 no-underline block">

            @* Flechita que aparece al hacer hover (igual que en caja) *@
            <div class="absolute right-4 top-4 p-1.5 text-on-surface-variant opacity-0 group-hover:opacity-100 group-hover:text-primary transition-all translate-x-2 group-hover:translate-x-0">
                <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
            </div>

            <div class="mb-4 relative z-10">
                <h6 class="text-xs font-bold uppercase tracking-widest text-on-surface-variant group-hover:text-primary transition-colors">Reservas totales</h6>
                <p class="text-sm font-medium text-on-surface-variant/70 capitalize">@dashboardResumen.MesActualNombre</p>
            </div>

            <div class="relative z-10">
                <p class="text-4xl font-headline font-black text-primary mb-2 group-hover:scale-[1.02] origin-left transition-transform">@dashboardResumen.Reservas.ValorActual</p>
                <div class="flex items-center text-sm">
                    <span class="@(dashboardResumen.Reservas.EsCrecimientoPositivo ? "text-green-600" : "text-red-500") font-bold flex items-center bg-@(dashboardResumen.Reservas.EsCrecimientoPositivo ? "green" : "red")-50 px-2 py-0.5 rounded-lg">
                        <span class="material-symbols-outlined text-[16px] mr-1">
                            @(dashboardResumen.Reservas.EsCrecimientoPositivo ? "trending_up" : "trending_down")
                        </span>
                        @(dashboardResumen.Reservas.EsCrecimientoPositivo ? "+" : "")@dashboardResumen.Reservas.PorcentajeCrecimiento%
                    </span>
                    <span class="text-on-surface-variant/70 font-medium ml-2 text-xs">vs @dashboardResumen.MesAnteriorNombre</span>
                </div>
            </div>
        </a>

    </div>
}
@* --- LISTA DE TURNOS Y ACCIONES --- *@
<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 animate-in fade-in slide-in-from-bottom-12 duration-700 delay-300">

    <div class="lg:col-span-2 space-y-6">
        <div class="flex items-center justify-between">
            <h2 class="text-2xl font-headline font-bold text-primary">Próximos en llegar</h2>
            <button @onclick='() => Nav.NavigateTo("/turnos")' class="text-sm font-bold text-primary hover:underline flex items-center gap-1">
                Ver agenda completa <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </button>
        </div>

        <div class="bg-white rounded-4xl editorial-shadow p-2">
            @if (cargando)
            {
                <div class="flex justify-center items-center py-10">
                    <div class="animate-spin rounded-full h-8 w-8 border-t-2 border-b-2 border-primary"></div>
                </div>
            }
            else if (!proximosTurnos.Any())
            {
                <div class="p-8 text-center border-2 border-dashed border-outline-variant rounded-3xl m-2">
                    <span class="material-symbols-outlined text-4xl text-on-surface-variant/50 mb-2">free_cancellation</span>
                    <h4 class="font-headline font-bold text-primary">Día relajado</h4>
                    <p class="text-sm text-on-surface-variant">No hay más turnos programados para hoy.</p>
                </div>
            }
            else
            {
                @foreach (var turno in proximosTurnos)
                {
                    var horaLocal = turno.FechaHoraInicioUtc.ToLocalTime();
                    var tiempoFaltante = CalcularTiempoFaltante(turno.FechaHoraInicioUtc);

                    <div class="p-4 md:p-6 flex items-center gap-4 hover:bg-surface-container-low rounded-3xl transition-colors border-b border-surface-container-high last:border-b-0 group relative">

                        @* Hora *@
                        <div class="w-14 h-14 rounded-2xl bg-surface-container-high text-on-surface flex flex-col items-center justify-center flex-shrink-0 group-hover:bg-primary group-hover:text-on-primary transition-colors shadow-sm group-hover:shadow-primary/20">
                            <span class="font-headline font-black text-lg leading-none">@horaLocal.ToString("HH")</span>
                            <span class="text-[10px] font-bold">@horaLocal.ToString("mm")</span>
                        </div>

                        @* Datos del Turno *@
                        <div class="flex-grow">
                            <div class="flex items-center gap-2">
                                <h4 class="font-headline font-bold text-lg text-primary">@turno.ClienteNombre</h4>
                                <span class="hidden md:inline-block px-2 py-0.5 @EstadoTurnoExtensions.ObtenerColorEstado(turno.Estado) text-[9px] font-bold uppercase tracking-wider rounded-lg">
                                    @turno.Estado
                                </span>
                            </div>

                            <p class="text-sm text-on-surface-variant flex items-center gap-1">
                                <span class="material-symbols-outlined text-[14px]">content_cut</span>
                                @turno.ServicioNombre con @turno.PrestadorNombre
                            </p>
                        </div>

                        @* Acciones Rápidas (WhatsApp) *@
                        <div class="flex items-center gap-2">
                            <span class="hidden lg:inline-block px-3 py-1 bg-secondary-container text-on-secondary-container text-[10px] font-bold rounded-lg uppercase whitespace-nowrap mr-2">
                                @tiempoFaltante
                            </span>

                            <button @onclick="() => AbrirWhatsApp(turno.ClienteTelefono, turno.ClienteNombre)"
                                    title="Contactar por WhatsApp"
                                    class="w-10 h-10 rounded-full bg-green-50 text-green-600 hover:bg-green-500 hover:text-white flex items-center justify-center transition-all shadow-sm">
                                <i class="fa-brands fa-whatsapp text-lg"></i>
                            </button>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <div class="space-y-6">
        <h2 class="text-2xl font-headline font-bold text-primary px-2">Atajos Rápidos</h2>
        @* 1. EL LINK DE RESERVAS (Ahora más compacto para ahorrar espacio) *@
        <div class="bg-primary p-5 rounded-[2.5rem] editorial-shadow text-on-primary relative overflow-hidden group">
            <div class="absolute -right-6 -top-6 w-20 h-20 bg-white/10 rounded-full group-hover:scale-150 transition-transform duration-700"></div>

            <div class="relative z-10 flex flex-col sm:flex-row items-center justify-between gap-4">
                <div>
                    <h3 class="font-headline font-bold text-base text-white">Link de Reservas</h3>
                    <p class="text-[10px] text-white/70 tracking-tight">Compartí este enlace en tu Instagram o WhatsApp para recibir turnos.</p>
                </div>
                <button @onclick="CopiarLink" class="px-4 py-2 bg-white text-primary rounded-xl font-bold text-[11px] hover:scale-105 active:scale-95 transition-all shadow-lg flex items-center gap-2 whitespace-nowrap">
                    <span class="material-symbols-outlined text-sm">@iconoBotonCopiar</span>
                    @textoBotonCopiar
                </button>
            </div>
        </div>

        @* 2. FILA DE 3 BOTONES BREVES (QUICK ACTIONS) *@
        <div class="flex items-center gap-3">

            @* Nuevo Turno *@
            <button @onclick='() => Nav.NavigateTo("/turnos")'
                    class="flex-1 flex flex-col items-center justify-center p-4 bg-white rounded-3xl editorial-shadow border border-transparent hover:border-primary/20 transition-all group hover:-translate-y-1">
                <div class="w-10 h-10 rounded-2xl bg-primary/10 text-primary flex items-center justify-center mb-2 group-hover:bg-primary group-hover:text-white transition-all">
                    <span class="material-symbols-outlined text-[20px]">add_circle</span>
                </div>
                <span class="text-[10px] font-black uppercase tracking-tighter text-primary">Turno</span>
            </button>

            @* Caja *@
            <button @onclick='() => Nav.NavigateTo("/caja")'
                    class="flex-1 flex flex-col items-center justify-center p-4 bg-white rounded-3xl editorial-shadow border border-transparent hover:border-orange-200 transition-all group hover:-translate-y-1">
                <div class="w-10 h-10 rounded-2xl bg-orange-50 text-orange-600 flex items-center justify-center mb-2 group-hover:bg-orange-600 group-hover:text-white transition-all">
                    <span class="material-symbols-outlined text-[20px]">point_of_sale</span>
                </div>
                <span class="text-[10px] font-black uppercase tracking-tighter text-primary">Caja</span>
            </button>

            @* Métricas *@
            @* Botón de Métricas con lógica de Plan *@
            @if (State.CurrentNegocio?.PlanNombre == "Single")
            {
                @* BOTÓN BLOQUEADO VISUALMENTE *@
                <div class="flex-1 flex flex-col items-center justify-center p-4 bg-surface-container-low/50 rounded-3xl border border-dashed border-surface-container-high opacity-70 cursor-not-allowed group relative overflow-hidden">
                    @* Candado sutil *@
                    <div class="absolute top-2 right-2">
                        <span class="material-symbols-outlined text-[12px] text-orange-500 font-bold">lock</span>
                    </div>

                    <div class="w-10 h-10 rounded-2xl bg-gray-200 text-gray-400 flex items-center justify-center mb-2">
                        <span class="material-symbols-outlined text-[20px]">bar_chart</span>
                    </div>
                    <span class="text-[10px] font-black uppercase tracking-tighter text-gray-400">Métricas</span>

                    @* Un overlay invisible que al hacer click pueda llevarlo a ver el mensaje de upgrade *@
                    <button @onclick='() => Nav.NavigateTo("/reportes")' class="absolute inset-0 w-full h-full"></button>
                </div>
            }
            else
            {
                @* BOTÓN NORMAL *@
                <button @onclick='() => Nav.NavigateTo("/reportes")'
                        class="flex-1 flex flex-col items-center justify-center p-4 bg-white rounded-3xl editorial-shadow border border-transparent hover:border-purple-200 transition-all group hover:-translate-y-1">
                    <div class="w-10 h-10 rounded-2xl bg-purple-50 text-purple-600 flex items-center justify-center mb-2 group-hover:bg-purple-600 group-hover:text-white transition-all">
                        <span class="material-symbols-outlined text-[20px]">bar_chart</span>
                    </div>
                    <span class="text-[10px] font-black uppercase tracking-tighter text-primary">Métricas</span>
                </button>
            }

        </div>

        @* 3. ESPACIO EXTRA (OPCIONAL) *@
        @* Acá podrías poner un mini resumen de la caja o el día más fuerte si te queda mucho aire abajo *@
    </div>

</div>