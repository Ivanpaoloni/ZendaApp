@page "/"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Zenda.Core.DTOs
@using Zenda.Core.Enums

<div class="mb-8 animate-in fade-in slide-in-from-bottom-4 duration-700">
    <span class="inline-block px-4 py-1.5 mb-4 bg-secondary-container text-on-secondary-container rounded-full text-[10px] font-bold tracking-widest uppercase font-body">
        RESUMEN DE HOY
    </span>
    <h1 class="text-4xl md:text-5xl font-headline font-extrabold text-primary tracking-tight">
        Hola, @nombreUsuario
    </h1>
    <p class="text-on-surface-variant mt-2 font-body">Acá tenés el resumen de tu negocio para el @DateTime.Today.ToString("dd 'de' MMMM").</p>
</div>
@if (ausenciasHoy != null && ausenciasHoy.Any())
{
    <div class="mb-10 bg-warning/10 border-2 border-warning/20 p-6 rounded-3xl animate-in zoom-in duration-500">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-full bg-warning/20 text-warning-dark flex items-center justify-center">
                <span class="material-symbols-outlined text-xl">person_off</span>
            </div>
            <div>
                <h3 class="text-warning-dark font-bold font-headline">Avisos del Equipo</h3>
                <p class="text-warning-dark/80 text-xs">Tenés @(ausenciasHoy.Count) profesional@(ausenciasHoy.Count > 1 ? "es" : "") con licencia hoy.</p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
            @foreach (var ausencia in ausenciasHoy)
            {
                <div class="bg-white/60 p-3 rounded-2xl border border-warning/30 flex items-center gap-3">
                    <span class="material-symbols-outlined text-warning-dark/50 text-2xl">schedule</span>
                    <div>
                        @{
                            var partes = (ausencia.Motivo ?? "").Split(':');
                            var nombre = partes.Length > 0 ? partes[0] : "Profesional";
                            var detalle = partes.Length > 1 ? partes[1].Trim() : "Ausente";

                            // Transformamos a hora local del navegador para que se vea bien
                            var horaInicio = ausencia.InicioLocal.ToLocalTime().ToString("HH:mm");
                            var horaFin = ausencia.FinLocal.ToLocalTime().ToString("HH:mm");
                        }
                        <p class="text-sm font-bold text-warning-dark">@nombre</p>
                        <p class="text-xs text-warning-dark/90 font-medium mt-0.5">De @horaInicio a @horaFin</p>
                        @if (!string.IsNullOrEmpty(detalle) && detalle != "Ausente")
                        {
                            <p class="text-[10px] text-warning-dark/60 uppercase tracking-widest font-bold mt-0.5">@detalle</p>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}
@if (!cargando && (totalPrestadores == 0 || sedesContador == 0 || serviciosContador == 0))
{
    <div class="mb-10 p-8 bg-primary/5 border-2 border-dashed border-primary/20 rounded-4xl animate-in zoom-in duration-500">
        <div class="flex items-center gap-4 mb-6">
            <div class="w-12 h-12 rounded-2xl bg-primary text-white flex items-center justify-center shadow-lg shadow-primary/20">
                <span class="material-symbols-outlined">rocket_launch</span>
            </div>
            <div>
                <h2 class="text-2xl font-headline font-extrabold text-primary">¡Bienvenido a Zenda, @nombreUsuario!</h2>
                <p class="text-on-surface-variant text-sm">Completá estos 3 pasos clave para empezar a recibir reservas.</p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">

            @if (sedesContador == 0)
            {
                <button @onclick='() => Nav.NavigateTo("/sedes")' class="p-6 bg-white rounded-3xl editorial-shadow hover:scale-[1.02] transition-all text-left flex items-center gap-4 group border border-transparent hover:border-orange-200">
                    <div class="w-12 h-12 flex-shrink-0 rounded-xl bg-orange-100 text-orange-600 flex items-center justify-center group-hover:bg-orange-600 group-hover:text-white transition-colors">
                        <span class="material-symbols-outlined">storefront</span>
                    </div>
                    <div>
                        <h4 class="font-bold text-primary leading-tight">1. Creá tu sede</h4>
                        <p class="text-xs text-on-surface-variant mt-1">El lugar físico de tus turnos.</p>
                    </div>
                </button>
            }

            @if (serviciosContador == 0)
            {
                <button @onclick='() => Nav.NavigateTo("/servicios")' class="p-6 bg-white rounded-3xl editorial-shadow hover:scale-[1.02] transition-all text-left flex items-center gap-4 group border border-transparent hover:border-purple-200">
                    <div class="w-12 h-12 flex-shrink-0 rounded-xl bg-purple-100 text-purple-600 flex items-center justify-center group-hover:bg-purple-600 group-hover:text-white transition-colors">
                        <span class="material-symbols-outlined">content_cut</span>
                    </div>
                    <div>
                        <h4 class="font-bold text-primary leading-tight">2. Tus servicios</h4>
                        <p class="text-xs text-on-surface-variant mt-1">Definí qué hacés y sus precios.</p>
                    </div>
                </button>
            }

            @if (totalPrestadores == 0)
            {
                <button @onclick='() => Nav.NavigateTo("/prestadores")' class="p-6 bg-white rounded-3xl editorial-shadow hover:scale-[1.02] transition-all text-left flex items-center gap-4 group border border-transparent hover:border-blue-200">
                    <div class="w-12 h-12 flex-shrink-0 rounded-xl bg-blue-100 text-blue-600 flex items-center justify-center group-hover:bg-blue-600 group-hover:text-white transition-colors">
                        <span class="material-symbols-outlined">person_add</span>
                    </div>
                    <div>
                        <h4 class="font-bold text-primary leading-tight">3. Tu equipo</h4>
                        <p class="text-xs text-on-surface-variant mt-1">Asigná quién hace los servicios.</p>
                    </div>
                </button>
            }
        </div>
    </div>
}

@* --- WIDGETS DE RESUMEN --- *@
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6 mb-10 animate-in fade-in slide-in-from-bottom-8 duration-700 delay-150">

    <div class="bg-white p-6 rounded-3xl editorial-shadow border border-transparent hover:border-primary/20 transition-all">
        <div class="w-10 h-10 rounded-xl bg-primary/10 text-primary flex items-center justify-center mb-4">
            <span class="material-symbols-outlined">calendar_today</span>
        </div>
        <p class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-1">Turnos Hoy</p>
        <p class="text-3xl font-headline font-black text-primary">@turnosHoy</p>
    </div>

    <div class="bg-white p-6 rounded-3xl editorial-shadow border border-transparent hover:border-primary/20 transition-all">
        <div class="w-10 h-10 rounded-xl bg-green-500/10 text-green-600 flex items-center justify-center mb-4">
            <span class="material-symbols-outlined">check_circle</span>
        </div>
        <p class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-1">Completados</p>
        <p class="text-3xl font-headline font-black text-green-600">@completadosHoy</p>
    </div>

    <div class="bg-white p-6 rounded-3xl editorial-shadow border border-transparent hover:border-primary/20 transition-all">
        <div class="w-10 h-10 rounded-xl bg-blue-500/10 text-blue-600 flex items-center justify-center mb-4">
            <span class="material-symbols-outlined">payments</span>
        </div>
        <p class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-1">Caja Proyectada</p>
        <p class="text-3xl font-headline font-black text-blue-600">@ingresosProyectadosHoy.ToString("C0")</p>
    </div>

    <div class="bg-white p-6 rounded-3xl editorial-shadow border border-transparent hover:border-primary/20 transition-all">
        <div class="w-10 h-10 rounded-xl bg-orange-500/10 text-orange-600 flex items-center justify-center mb-4">
            <span class="material-symbols-outlined">group</span>
        </div>
        <p class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-1">Equipo Activo</p>
        <div class="flex items-baseline gap-1">
            <p class="text-3xl font-headline font-black text-orange-600">@equipoActivoHoy</p>
            <p class="text-sm font-bold text-on-surface-variant/50">/ @totalPrestadores</p>
        </div>
    </div>
</div>

@* --- LISTA DE TURNOS Y ACCIONES --- *@
<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 animate-in fade-in slide-in-from-bottom-12 duration-700 delay-300">

    <div class="lg:col-span-2 space-y-6">
        <div class="flex items-center justify-between">
            <h2 class="text-2xl font-headline font-bold text-primary">Próximos en llegar</h2>
            <button @onclick='() => Nav.NavigateTo("/turnos")' class="text-sm font-bold text-primary hover:underline flex items-center gap-1">
                Ver agenda completa <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </button>
        </div>

        <div class="bg-white rounded-4xl editorial-shadow p-2">
            @if (cargando)
            {
                <div class="flex justify-center items-center py-10">
                    <div class="animate-spin rounded-full h-8 w-8 border-t-2 border-b-2 border-primary"></div>
                </div>
            }
            else if (!proximosTurnos.Any())
            {
                <div class="p-8 text-center border-2 border-dashed border-outline-variant rounded-3xl m-2">
                    <span class="material-symbols-outlined text-4xl text-on-surface-variant/50 mb-2">free_cancellation</span>
                    <h4 class="font-headline font-bold text-primary">Día relajado</h4>
                    <p class="text-sm text-on-surface-variant">No hay más turnos programados para hoy.</p>
                </div>
            }
            else
            {
                @foreach (var turno in proximosTurnos)
                {
                    var horaLocal = turno.FechaHoraInicioUtc.ToLocalTime();
                    var tiempoFaltante = CalcularTiempoFaltante(turno.FechaHoraInicioUtc);

                    <div class="p-4 md:p-6 flex items-center gap-4 hover:bg-surface-container-low rounded-3xl transition-colors border-b border-surface-container-high last:border-b-0 group relative">

                        @* Hora *@
                        <div class="w-14 h-14 rounded-2xl bg-surface-container-high text-on-surface flex flex-col items-center justify-center flex-shrink-0 group-hover:bg-primary group-hover:text-on-primary transition-colors shadow-sm group-hover:shadow-primary/20">
                            <span class="font-headline font-black text-lg leading-none">@horaLocal.ToString("HH")</span>
                            <span class="text-[10px] font-bold">@horaLocal.ToString("mm")</span>
                        </div>

                        @* Datos del Turno *@
                        <div class="flex-grow">
                            <div class="flex items-center gap-2">
                                <h4 class="font-headline font-bold text-lg text-primary">@turno.NombreClienteInvitado</h4>
                                <span class="hidden md:inline-block px-2 py-0.5 @EstadoTurnoExtensions.ObtenerColorEstado(turno.Estado) text-[9px] font-bold uppercase tracking-wider rounded-lg">
                                    @turno.Estado
                                </span>
                            </div>

                            <p class="text-sm text-on-surface-variant flex items-center gap-1">
                                <span class="material-symbols-outlined text-[14px]">content_cut</span>
                                @turno.ServicioNombre con @turno.PrestadorNombre
                            </p>
                        </div>

                        @* Acciones Rápidas (WhatsApp) *@
                        <div class="flex items-center gap-2">
                            <span class="hidden lg:inline-block px-3 py-1 bg-secondary-container text-on-secondary-container text-[10px] font-bold rounded-lg uppercase whitespace-nowrap mr-2">
                                @tiempoFaltante
                            </span>

                            <button @onclick="() => AbrirWhatsApp(turno.TelefonoClienteInvitado, turno.NombreClienteInvitado)"
                                    title="Contactar por WhatsApp"
                                    class="w-10 h-10 rounded-full bg-green-50 text-green-600 hover:bg-green-500 hover:text-white flex items-center justify-center transition-all shadow-sm">
                                <i class="fa-brands fa-whatsapp text-lg"></i>
                            </button>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <div class="space-y-6">
        <h2 class="text-2xl font-headline font-bold text-primary">Acciones Rápidas</h2>

        <div class="bg-primary p-8 rounded-4xl editorial-shadow text-on-primary relative overflow-hidden group">
            <div class="absolute -right-8 -top-8 w-32 h-32 bg-white/10 rounded-full group-hover:scale-150 transition-transform duration-700"></div>

            <h3 class="font-headline font-bold text-xl mb-2 relative z-10">Tu link de reservas</h3>
            <p class="text-sm text-on-primary/80 mb-6 relative z-10">Compartí este enlace en tu Instagram o WhatsApp para recibir turnos.</p>

            <button @onclick="CopiarLink" class="w-full py-4 bg-white text-primary rounded-2xl font-headline font-bold text-sm hover:scale-[1.02] active:scale-95 transition-all shadow-xl flex items-center justify-center gap-2 relative z-10">
                <span class="material-symbols-outlined text-sm">@iconoBotonCopiar</span>
                @textoBotonCopiar
            </button>
        </div>

        <button @onclick='() => Nav.NavigateTo("/sedes")' class="w-full bg-white p-6 rounded-3xl editorial-shadow flex items-center justify-between group hover:border-primary/20 border border-transparent transition-all">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-2xl bg-surface-container-low text-primary flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-colors">
                    <span class="material-symbols-outlined">storefront</span>
                </div>
                <div class="text-left">
                    <h4 class="font-headline font-bold text-primary">Gestionar Sedes</h4>
                    <p class="text-xs text-on-surface-variant">Configurar sucursales</p>
                </div>
            </div>
            <span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary transition-colors">chevron_right</span>
        </button>
    </div>

</div>