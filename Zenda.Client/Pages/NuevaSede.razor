@page "/sedes/nueva"
@using Zenda.Core.DTOs
@inject SedeClient SedeService
@inject NavigationManager Nav

<div class="mb-12 animate-in fade-in slide-in-from-bottom-4 duration-700">
    <button @onclick="Volver" class="flex items-center gap-2 text-primary font-headline font-bold text-sm mb-6 hover:opacity-70 transition-opacity">
        <span class="material-symbols-outlined">arrow_back</span>
        Volver a sedes
    </button>
    <h1 class="text-4xl font-headline font-extrabold text-primary tracking-tight">Nueva Sede</h1>
    <p class="text-on-surface-variant mt-2 font-body">Configura un nuevo punto de atención para tu negocio.</p>
</div>

<div class="max-w-2xl bg-white p-10 rounded-4xl editorial-shadow border border-surface-container-high">
    <EditForm Model="@nuevaSede" OnValidSubmit="GuardarSede" class="space-y-8">
        <DataAnnotationsValidator />

        <div class="space-y-2">
            <label class="text-xs font-bold tracking-widest uppercase font-body text-on-surface-variant px-1">NOMBRE DE LA SEDE</label>
            <InputText @bind-Value="nuevaSede.Nombre"
                       class="w-full px-6 py-4 bg-surface-container-low border-none rounded-2xl focus:ring-2 focus:ring-primary focus:bg-white transition-all outline-none font-body"
                       placeholder="Ej. Sede Palermo, Sucursal Centro..." />
            <ValidationMessage For="@(() => nuevaSede.Nombre)" class="text-error text-xs px-1" />
        </div>

        @if (!string.IsNullOrEmpty(mensajeError))
        {
            <div class="p-4 bg-error/10 border border-error/20 text-error rounded-2xl text-sm font-body animate-in zoom-in duration-300">
                @mensajeError
            </div>
        }

        <div class="pt-4">
            <button type="submit" disabled="@enviando"
                    class="w-full py-4 bg-primary text-on-primary rounded-xl font-headline font-bold text-lg scale-100 hover:scale-[1.02] active:scale-95 transition-all editorial-shadow flex items-center justify-center gap-2 disabled:opacity-50">
                @if (enviando)
                {
                    <div class="animate-spin rounded-full h-5 w-5 border-b-2 border-white"></div>
                    <span>Guardando...</span>
                }
                else
                {
                    <span>Confirmar Sede</span>
                    <span class="material-symbols-outlined">add_location_alt</span>
                }
            </button>
        </div>
    </EditForm>
</div>

@code {
    private SedeCreateDto nuevaSede = new();
    private bool enviando = false;
    private string? mensajeError;

    // Hardcoded por ahora hasta tener Auth
    private readonly Guid NegocioIdPrueba = Guid.Parse("00000000-0000-0000-0000-000000000001");

    private async Task GuardarSede()
    {
        enviando = true;
        mensajeError = null;

        // Asignamos el negocio padre
        nuevaSede.NegocioId = NegocioIdPrueba;

        var resultado = await SedeService.Create(nuevaSede);

        if (resultado.Success)
        {
            Nav.NavigateTo("sedes");
        }
        else
        {
            mensajeError = resultado.ErrorMessage;
        }

        enviando = false;
    }

    private void Volver() => Nav.NavigateTo("sedes");
}