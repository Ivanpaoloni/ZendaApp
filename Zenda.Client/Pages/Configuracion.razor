@page "/configuracion"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Zenda.Core.DTOs

<div class="space-y-8 animate-in fade-in duration-500 pb-20">

    @* Encabezado *@
    <div>
        <h1 class="text-3xl font-bold text-primary tracking-tighter font-headline">Configuración</h1>
        <p class="text-on-surface-variant text-sm">Gestioná tu cuenta personal y las preferencias de tu negocio.</p>
    </div>

    <div class="flex flex-col md:flex-row gap-8 items-start">

        @* --- MENÚ LATERAL (SIDEBAR) --- *@
        <div class="w-full md:w-64 flex-shrink-0 space-y-2">
            <button @onclick='() => CambiarPestaña("perfil")'
                    class="w-full flex items-center gap-3 px-5 py-4 rounded-2xl font-bold transition-all @(pestañaActiva == "perfil" ? "bg-primary text-white shadow-lg shadow-primary/20" : "bg-transparent text-on-surface-variant hover:bg-surface-container-low hover:text-primary")">
                <span class="material-symbols-outlined text-[20px]">person</span>
                Mi Perfil
            </button>

            <button @onclick='() => CambiarPestaña("negocio")'
                    class="w-full flex items-center gap-3 px-5 py-4 rounded-2xl font-bold transition-all @(pestañaActiva == "negocio" ? "bg-primary text-white shadow-lg shadow-primary/20" : "bg-transparent text-on-surface-variant hover:bg-surface-container-low hover:text-primary")">
                <span class="material-symbols-outlined text-[20px]">storefront</span>
                Mi Negocio
            </button>

            @* Placeholder para el futuro (Facturación/Suscripción) *@
            <div class="w-full flex items-center gap-3 px-5 py-4 rounded-2xl font-bold bg-transparent text-on-surface-variant/40 cursor-not-allowed">
                <span class="material-symbols-outlined text-[20px]">credit_card</span>
                Facturación <span class="text-[9px] bg-surface-container-high px-2 py-0.5 rounded-md ml-auto">PRONTO</span>
            </div>
        </div>

        @* --- ÁREA DE CONTENIDO PRINCIPAL --- *@
        <div class="flex-grow w-full bg-white rounded-[2.5rem] editorial-shadow border border-surface-container-high p-8 min-h-[400px]">

            @if (cargando)
            {
                <div class="h-full flex items-center justify-center py-20">
                    <div class="animate-spin rounded-full h-10 w-10 border-t-2 border-b-2 border-primary"></div>
                </div>
            }
            else
            {
                @if (!string.IsNullOrEmpty(mensajeExito))
                {
                    <div class="mb-6 p-4 bg-green-50 text-green-700 border border-green-200 rounded-2xl text-sm font-bold flex items-center gap-2 animate-in slide-in-from-top-2">
                        <span class="material-symbols-outlined">check_circle</span>
                        @mensajeExito
                    </div>
                }

                @if (!string.IsNullOrEmpty(mensajeError))
                {
                    <div class="mb-6 p-4 bg-red-50 text-red-600 border border-red-100 rounded-2xl text-sm font-bold flex items-center gap-2 animate-in slide-in-from-top-2">
                        <span class="material-symbols-outlined">error</span>
                        @mensajeError
                    </div>
                }

                @* ---------------------------------------------------- *@
                @* 📌 PESTAÑA: MI PERFIL                                *@
                @* ---------------------------------------------------- *@
                @if (pestañaActiva == "perfil")
                {
                    <div class="animate-in fade-in slide-in-from-bottom-4 duration-500">
                        <div class="mb-8 flex items-center gap-4">
                            <div class="w-16 h-16 rounded-full bg-secondary-container text-primary flex items-center justify-center font-headline font-black text-2xl">
                                @ObtenerIniciales()
                            </div>
                            <div>
                                <h2 class="text-2xl font-headline font-bold text-primary">Tus datos personales</h2>
                                <p class="text-on-surface-variant text-sm">Actualizá tu información de acceso.</p>
                            </div>
                        </div>

                        <EditForm Model="perfilUsuario" OnValidSubmit="GuardarPerfil">
                            <DataAnnotationsValidator />

                            <div class="space-y-5">
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                                    <div class="flex flex-col gap-2">
                                        <label class="text-[10px] font-bold text-primary px-1 uppercase tracking-wider">Nombre</label>
                                        <InputText @bind-Value="perfilUsuario.Nombre" class="input-zenda" placeholder="Tu nombre" />
                                        <ValidationMessage For="@(() => perfilUsuario.Nombre)" class="text-error text-[10px] font-bold px-1" />
                                    </div>
                                    <div class="flex flex-col gap-2">
                                        <label class="text-[10px] font-bold text-primary px-1 uppercase tracking-wider">Apellido</label>
                                        <InputText @bind-Value="perfilUsuario.Apellido" class="input-zenda" placeholder="Tu apellido" />
                                    </div>
                                </div>

                                <div class="flex flex-col gap-2">
                                    <label class="text-[10px] font-bold text-primary px-1 uppercase tracking-wider">Teléfono</label>
                                    <InputText @bind-Value="perfilUsuario.Telefono" class="input-zenda" placeholder="Ej: +54 11 1234 5678" />
                                </div>

                                @* El Email suele ser de solo lectura porque está atado al proveedor de Auth (Supabase/Identity) *@
                                <div class="flex flex-col gap-2">
                                    <label class="text-[10px] font-bold text-on-surface-variant px-1 uppercase tracking-wider flex items-center gap-1">
                                        Email de acceso <span class="material-symbols-outlined text-[14px]">lock</span>
                                    </label>
                                    <input value="@emailUsuario" disabled class="input-zenda opacity-60 cursor-not-allowed bg-surface-container-low" />
                                    <p class="text-[10px] text-on-surface-variant px-1">Para cambiar tu email, contactá a soporte.</p>
                                </div>

                                <div class="pt-6 border-t border-surface-container-high flex justify-end">
                                    <button type="submit" disabled="@guardando"
                                            class="px-8 py-4 bg-primary text-white font-bold rounded-2xl hover:brightness-110 active:scale-95 transition-all flex justify-center items-center gap-2 disabled:opacity-50">
                                        @if (guardando)
                                        {
                                            <div class="animate-spin rounded-full h-5 w-5 border-b-2 border-white"></div>
                                            <span>Guardando...</span>
                                        }
                                        else
                                        {
                                            <span>Guardar Cambios</span>
                                        }
                                    </button>
                                </div>
                            </div>
                        </EditForm>
                    </div>
                }

                @* ---------------------------------------------------- *@
                @* 📌 PESTAÑA: MI NEGOCIO (PREPARADA PARA LA ETAPA 2)   *@
                @* ---------------------------------------------------- *@
                @if (pestañaActiva == "negocio")
                {
                    <div class="animate-in fade-in slide-in-from-bottom-4 duration-500 text-center py-10">
                        <span class="material-symbols-outlined text-6xl text-primary/30 mb-4">construction</span>
                        <h2 class="text-2xl font-headline font-bold text-primary mb-2">Configuración del Negocio</h2>
                        <p class="text-on-surface-variant">Acá vamos a configurar tu Logo y tu link zenda.app/slug.</p>
                    </div>
                }

            }
        </div>
    </div>
</div>

<style>
    /* Reutilizamos la clase que armamos para Sedes para mantener consistencia visual */
    .input-zenda {
        width: 100%;
        padding: 1rem 1.25rem;
        border-radius: 1.25rem;
        background-color: #f1f5f0;
        border: 2px solid transparent;
        font-size: 0.9rem;
        transition: all 0.2s;
        color: #1a1a1a;
        outline: none;
    }

        .input-zenda:focus {
            border-color: #166534; /* Tu color primary */
            background-color: white;
        }
</style>