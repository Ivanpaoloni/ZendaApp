@page "/admin/monitoreo"
@layout AdminLayout
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

@inject IConfiguration Config

<PageTitle>Monitoreo del Sistema - Zendy</PageTitle>

<div class="space-y-6 animate-in fade-in duration-500 pb-10">
    
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
            <div>
                <h1 class="text-3xl font-bold text-white font-headline">Estado del Sistema</h1>
                <p class="text-slate-400 mt-1">Monitoreo en tiempo real de la base de datos, APIs externas y memoria.</p>
        </div>
    </div>

    @* Contenedor del Dashboard *@
    <div class="w-full h-[800px] bg-white rounded-[2.5rem] border border-surface-container-high editorial-shadow overflow-hidden relative">
        
        @* Animación de carga de fondo por si el iframe tarda un segundo *@
        <div class="absolute inset-0 flex items-center justify-center -z-10 bg-surface-container-lowest">
            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
        </div>

        @* El iframe que carga la UI que ya tienes en el backend *@
        <iframe src="@($"{Config["BaseApiUrl"]!.TrimEnd('/')}/health-dash")" 
                class="w-full h-full border-0 z-10 bg-transparent"
                title="Panel de Monitoreo Zendy">
        </iframe>
        
    </div>
</div>