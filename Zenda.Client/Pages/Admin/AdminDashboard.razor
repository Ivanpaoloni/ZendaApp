@page "/admin"
@layout AdminLayout
@using Microsoft.AspNetCore.Components.Authorization
@using Zenda.Core.DTOs.Admin
@using Zenda.Client.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject AdminClient AdminClient
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<PageTitle>Zendy Admin - Negocios</PageTitle>

<div class="flex items-end justify-between mb-8">
    <div>
        <h1 class="text-3xl font-bold text-white font-headline">Negocios Registrados</h1>
        <p class="text-slate-400 mt-1">Gestión integral de clientes y suscripciones.</p>
    </div>

    <div class="bg-slate-900 border border-slate-800 rounded-2xl px-4 py-2 flex items-center gap-3">
        <span class="material-symbols-outlined text-slate-400">search</span>
        <input type="text" placeholder="Buscar negocio..." @bind="filtroBusqueda" @bind:event="oninput"
               class="bg-transparent border-none text-white focus:outline-none focus:ring-0 text-sm w-48 placeholder-slate-600" />
    </div>
</div>

@if (Cargando)
{
    <div class="flex justify-center py-20">
        <div class="animate-spin rounded-full h-10 w-10 border-t-2 border-b-2 border-blue-500"></div>
    </div>
}
else if (NegociosFiltrados == null || !NegociosFiltrados.Any())
{
    <div class="bg-slate-900 border border-slate-800 rounded-3xl p-12 text-center">
        <span class="material-symbols-outlined text-5xl text-slate-600 mb-4">sentiment_dissatisfied</span>
        <h3 class="text-lg font-bold text-white">No se encontraron negocios</h3>
        <p class="text-slate-400">Aún no hay clientes registrados o tu búsqueda no dio resultados.</p>
    </div>
}
else
{
    <div class="bg-slate-900 border border-slate-800 rounded-3xl overflow-hidden shadow-2xl">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead class="bg-slate-800/50">
                    <tr>
                        <th @onclick='() => OrdenarPor("Nombre")' class="px-4 py-3 text-left text-xs font-bold text-slate-400 uppercase tracking-wider cursor-pointer hover:text-white transition-colors">
                            <div class="flex items-center gap-1">Negocio @(columnaOrden == "Nombre" ? (ordenAscendente ? "↑" : "↓") : "")</div>
                        </th>
                        <th @onclick='() => OrdenarPor("Plan")' class="px-4 py-3 text-left text-xs font-bold text-slate-400 uppercase tracking-wider cursor-pointer hover:text-white transition-colors">
                            <div class="flex items-center gap-1">Plan @(columnaOrden == "Plan" ? (ordenAscendente ? "↑" : "↓") : "")</div>
                        </th>
                        <th @onclick='() => OrdenarPor("Monto")' class="px-4 py-3 text-left text-xs font-bold text-slate-400 uppercase tracking-wider cursor-pointer hover:text-white transition-colors">
                            <div class="flex items-center gap-1">Mensualidad @(columnaOrden == "Monto" ? (ordenAscendente ? "↑" : "↓") : "")</div>
                        </th>
                        <th @onclick='() => OrdenarPor("Vencimiento")' class="px-4 py-3 text-left text-xs font-bold text-slate-400 uppercase tracking-wider cursor-pointer hover:text-white transition-colors">
                            <div class="flex items-center gap-1">Vencimiento @(columnaOrden == "Vencimiento" ? (ordenAscendente ? "↑" : "↓") : "")</div>
                        </th>
                        <th @onclick='() => OrdenarPor("Estado")' class="px-4 py-3 text-center text-xs font-bold text-slate-400 uppercase tracking-wider cursor-pointer hover:text-white transition-colors">
                            <div class="flex items-center justify-center gap-1">Estado @(columnaOrden == "Estado" ? (ordenAscendente ? "↑" : "↓") : "")</div>
                        </th>
                        <th class="px-4 py-3 text-right text-xs font-bold text-slate-400 uppercase tracking-wider">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-800/50 text-sm">
                    @foreach (var n in NegociosFiltrados)
                    {
                        <tr class="hover:bg-slate-800/50 transition-colors group">
                            @* 1. Negocio *@
                            <td class="p-5 font-bold text-white flex items-center gap-3">
                                <div class="w-8 h-8 rounded-full bg-slate-800 flex items-center justify-center text-blue-500 text-xs shadow-inner">
                                    @(n.NombreNegocio.FirstOrDefault())
                                </div>
                                @n.NombreNegocio
                            </td>

                            @* 2. Plan *@
                            <td class="p-5">
                                <span class="bg-slate-800 text-slate-300 px-3 py-1 rounded-lg text-xs font-bold border border-slate-700">
                                    @n.PlanNombre
                                </span>
                            </td>

                            @* 3. Mensualidad (Corregido: ahora es la 3era columna) *@
                            <td class="p-5 font-mono text-emerald-400 font-bold">
                                $@n.MontoMensual.ToString("N0")
                            </td>

                            @* 4. Vencimiento *@
                            <td class="p-5 text-slate-300">
                                @if (n.FechaVencimiento == DateTime.MinValue)
                                {
                                    <span class="text-slate-500 italic">Sin suscripción</span>
                                }
                                else
                                {
                                    @n.FechaVencimiento.ToShortDateString()
                                }
                            </td>

                            @* 5. Estado (Corregido: ahora es la 5ta columna) *@
                            <td class="p-5">
                                <div class="flex justify-center">
                                    @if (n.IsActive)
                                    {
                                        <span class="text-emerald-400 flex items-center gap-1 text-xs font-bold bg-emerald-400/10 w-fit px-2 py-1 rounded-md">
                                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span> Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-red-400 flex items-center gap-1 text-xs font-bold bg-red-400/10 w-fit px-2 py-1 rounded-md">
                                            <span class="w-1.5 h-1.5 rounded-full bg-red-400"></span> Suspendido
                                        </span>
                                    }
                                </div>
                            </td>

                            @* 6. Acciones *@
                            <td class="p-5 text-right">
                                <div class="flex justify-end gap-2">
                                    <button @onclick="() => AbrirModal(n)" class="w-8 h-8 flex items-center justify-center rounded-lg bg-slate-800 text-slate-400 hover:text-blue-400 hover:bg-slate-700 transition-all" title="Gestionar Cliente">
                                        <span class="material-symbols-outlined text-[20px]">settings</span>
                                    </button>
                                    <button @onclick="() => AbrirModalInfo(n)" class="w-8 h-8 flex items-center justify-center rounded-lg bg-slate-800 text-slate-400 hover:text-emerald-400 hover:bg-slate-700 transition-all" title="Ver Info del Cliente">
                                        <span class="material-symbols-outlined text-[20px]">info</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
@if (mostrarModal)
{
    <div class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4">
        <div class="bg-slate-900 border border-slate-700 rounded-3xl p-6 w-full max-w-md shadow-2xl">
            <h3 class="text-xl font-bold text-white mb-6">Gestionar Cliente</h3>

            @if (negocioEnEdicion != null)
            {
                <div class="space-y-5">
                    @* Toggle Activo / Suspendido *@
                    <div class="flex items-center justify-between bg-slate-800 p-4 rounded-xl">
                        <div>
                            <p class="text-white font-bold text-sm">Estado de la cuenta</p>
                            <p class="text-slate-400 text-xs">Si se suspende, se cierra su sesión.</p>
                        </div>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" class="sr-only peer" @bind="negocioEnEdicion.IsActive">
                            <div class="w-11 h-6 bg-slate-700 rounded-full peer peer-checked:bg-blue-500 after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:after:translate-x-full"></div>
                        </label>
                    </div>

                    @* Select de Plan *@
                    <div class="bg-slate-800 p-4 rounded-xl">
                        <label class="block text-slate-400 text-xs font-bold mb-2">Plan Suscripción</label>
                        <select @bind="negocioEnEdicion.PlanSuscripcionId" class="bg-slate-900 border border-slate-700 text-white rounded-lg block w-full p-2.5 focus:border-blue-500 focus:ring-blue-500">
                            @if (PlanesDisponibles != null)
                            {
                                @foreach (var plan in PlanesDisponibles)
                                {
                                    <option value="@plan.Id">@plan.Nombre</option>
                                }
                            }
                        </select>
                    </div>

                    @* Fecha de Vencimiento *@
                    <div class="bg-slate-800 p-4 rounded-xl">
                        <label class="block text-slate-400 text-xs font-bold mb-2">Fecha de Vencimiento</label>
                        <input type="date" @bind="negocioEnEdicion.FechaVencimiento" @bind:format="yyyy-MM-dd"
                               class="bg-slate-900 border border-slate-700 text-white rounded-lg block w-full p-2.5 focus:border-blue-500 focus:ring-blue-500" />
                    </div>

                    @* Precio Personalizado *@
                    <div class="bg-slate-800 p-4 rounded-xl">
                        <label class="block text-slate-400 text-xs font-bold mb-2">Precio Mensual Personalizado</label>
                        <div class="flex items-center gap-2">
                            <span class="text-slate-400">$</span>
                            <input type="number" @bind="negocioEnEdicion.PrecioMensualPersonalizado" class="bg-transparent border-b border-slate-600 text-white focus:outline-none focus:border-blue-500 w-full p-1" placeholder="Ej: 5000 (Dejar vacío para tarifa normal)" />
                        </div>
                    </div>
                </div>

                @* Botones *@
                <div class="flex gap-3 mt-8">
                    <button @onclick="CerrarModal" class="flex-1 py-3 text-sm font-bold text-slate-400 hover:text-white transition-colors">Cancelar</button>
                    <button @onclick="GuardarCambios" disabled="@guardando" class="flex-1 py-3 bg-blue-600 hover:bg-blue-500 text-white text-sm font-bold rounded-xl transition-colors disabled:opacity-50">
                        @(guardando ? "Guardando..." : "Guardar Cambios")
                    </button>
                </div>
            }
        </div>
    </div>
}

@* MODAL DE INFORMACIÓN DEL CLIENTE *@
@if (mostrarModalInfo && negocioInfoSeleccionado != null)
{
    <div class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4">
        <div class="bg-slate-900 border border-slate-700 rounded-3xl p-6 w-full max-w-md shadow-2xl relative">

            <button @onclick="CerrarModalInfo" class="absolute top-4 right-4 text-slate-400 hover:text-white">
                <span class="material-symbols-outlined">close</span>
            </button>

            <h3 class="text-xl font-bold text-white mb-1">@negocioInfoSeleccionado.NombreNegocio</h3>
            <a target="_blank"
               href="@($"https://app.zendy.com.ar/{negocioInfoSeleccionado.Slug}")"
               class="text-sm text-slate-400 mb-6 hover:text-blue-400 transition-colors">
                app.zendy.com.ar/@negocioInfoSeleccionado.Slug
            </a>
            <div class="space-y-4">
                @* Info del Dueño *@
                <div class="bg-slate-800 p-4 rounded-xl">
                    <p class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-3">Datos del Dueño</p>

                    <div class="flex items-center gap-3 mb-3">
                        <span class="material-symbols-outlined text-slate-400 text-[20px]">person</span>
                        <span class="text-white font-medium">@negocioInfoSeleccionado.OwnerName</span>
                    </div>

                    <div class="flex items-center gap-3 mb-3">
                        <span class="material-symbols-outlined text-slate-400 text-[20px]">mail</span>
                        <a href="mailto:@negocioInfoSeleccionado.OwnerEmail" class="text-blue-400 hover:underline">@negocioInfoSeleccionado.OwnerEmail</a>
                    </div>

                    <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-slate-400 text-[20px]">call</span>
                        <span class="text-white">@(string.IsNullOrEmpty(negocioInfoSeleccionado.OwnerPhone) ? "No registrado" : negocioInfoSeleccionado.OwnerPhone)</span>
                    </div>
                </div>

                @* Botón de WhatsApp *@
                @if (!string.IsNullOrEmpty(negocioInfoSeleccionado.OwnerPhone))
                {
                    <a href="@GetWhatsAppLink(negocioInfoSeleccionado.OwnerPhone)" target="_blank"
                       class="w-full flex items-center justify-center gap-2 py-3 bg-[#25D366] hover:bg-[#20b858] text-white rounded-xl font-bold transition-all shadow-lg">
                        <i class="fa-brands fa-whatsapp text-xl"></i>
                        Contactar por WhatsApp
                    </a>
                }
                else
                {
                    <div class="w-full text-center py-3 bg-slate-800 text-slate-500 rounded-xl text-sm italic">
                        El dueño no registró un número telefónico.
                    </div>
                }
            </div>
        </div>
    </div>
}
@code {
    private bool Cargando = true;
    private List<NegocioAdminListDto>? TodosLosNegocios;
    private string filtroBusqueda = "";
    private bool mostrarModal = false;
    private bool guardando = false;
    private bool mostrarModalInfo = false;
    private NegocioAdminListDto? negocioInfoSeleccionado;

    // Variables de Ordenamiento
    private string columnaOrden = "Nombre";
    private bool ordenAscendente = true;

    // Un DTO temporal para editar sin afectar la tabla hasta que se guarde
    private AdminUpdateNegocioDto? negocioEnEdicion;
    private Guid negocioIdEditando;
    private NegocioAdminListDto? itemOriginal;
    private List<PlanAdminDto>? PlanesDisponibles;


    private IEnumerable<NegocioAdminListDto>? NegociosFiltrados
    {
        get
        {
            var query = string.IsNullOrWhiteSpace(filtroBusqueda)
                ? TodosLosNegocios
                : TodosLosNegocios?.Where(n => n.NombreNegocio.Contains(filtroBusqueda, StringComparison.OrdinalIgnoreCase) ||
                                               n.OwnerName.Contains(filtroBusqueda, StringComparison.OrdinalIgnoreCase));

            if (query == null) return null;

            // Aplicamos el ordenamiento dinámico
            return columnaOrden switch
            {
                "Nombre" => ordenAscendente ? query.OrderBy(x => x.NombreNegocio) : query.OrderByDescending(x => x.NombreNegocio),
                "Plan" => ordenAscendente ? query.OrderBy(x => x.PlanNombre) : query.OrderByDescending(x => x.PlanNombre),
                "Monto" => ordenAscendente ? query.OrderBy(x => x.MontoMensual) : query.OrderByDescending(x => x.MontoMensual),
                "Vencimiento" => ordenAscendente ? query.OrderBy(x => x.FechaVencimiento) : query.OrderByDescending(x => x.FechaVencimiento),
                "Estado" => ordenAscendente ? query.OrderByDescending(x => x.IsActive) : query.OrderBy(x => x.IsActive),
                _ => query
            };
        }
    }
    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 🔥 Validación manual "a prueba de Blazor"
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var esSuperAdmin = authState.User.Claims.Any(c => c.Value == "SuperAdmin");

            if (!esSuperAdmin)
            {
                // Si un cliente normal escribe /admin en la URL, lo pateamos a su panel
                Nav.NavigateTo("/");
                return;
            }

            // Si pasa la prueba, cargamos los datos
            TodosLosNegocios = await AdminClient.GetNegociosAsync();
            PlanesDisponibles = await AdminClient.GetPlanesAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando admin: {ex.Message}");
        }
        finally
        {
            Cargando = false;
        }
    }
    private void AbrirModal(NegocioAdminListDto n)
    {
        itemOriginal = n;
        negocioIdEditando = n.NegocioId;

        negocioEnEdicion = new AdminUpdateNegocioDto
        {
            IsActive = n.IsActive,
            PrecioMensualPersonalizado = n.MontoMensual,
            PlanSuscripcionId = n.PlanSuscripcionId,

            // SI ES FECHA CERO, SUGERIMOS HOY + 1 MES
            FechaVencimiento = n.FechaVencimiento == DateTime.MinValue
                               ? DateTime.Today.AddMonths(1)
                               : n.FechaVencimiento
        };

        mostrarModal = true;
    }

    private void CerrarModal()
    {
        mostrarModal = false;
        negocioEnEdicion = null;
    }

    private async Task GuardarCambios()
    {
        if (negocioEnEdicion == null || itemOriginal == null) return;

        guardando = true;
        try
        {
            // Opcional: Si el monto es 0, lo mandamos como null para que tome el precio de lista
            if (negocioEnEdicion.PrecioMensualPersonalizado <= 0)
                negocioEnEdicion.PrecioMensualPersonalizado = null;

            var exito = await AdminClient.UpdateNegocioAsync(negocioIdEditando, negocioEnEdicion);

            if (exito)
            {
                // Actualizamos la tabla visualmente sin tener que recargar la página
                itemOriginal.IsActive = negocioEnEdicion.IsActive;
                itemOriginal.MontoMensual = negocioEnEdicion.PrecioMensualPersonalizado ?? itemOriginal.MontoMensual; // Reflejaría el precio normal si es null, ideal recargar la lista

                // Recargar toda la lista para estar 100% sincronizados
                TodosLosNegocios = await AdminClient.GetNegociosAsync();

                CerrarModal();
            }
        }
        finally
        {
            guardando = false;
        }
    }

    // modal de info negocio
    private void OrdenarPor(string columna)
    {
        if (columnaOrden == columna)
            ordenAscendente = !ordenAscendente;
        else
        {
            columnaOrden = columna;
            ordenAscendente = true;
        }
    }

    private void AbrirModalInfo(NegocioAdminListDto n)
    {
        negocioInfoSeleccionado = n;
        mostrarModalInfo = true;
    }

    private void CerrarModalInfo() => mostrarModalInfo = false;

    // Limpia el número para el link de WhatsApp
    private string GetWhatsAppLink(string telefono)
    {
        if (string.IsNullOrWhiteSpace(telefono)) return "";
        var numeroLimpio = new string(telefono.Where(char.IsDigit).ToArray());
        return $"https://wa.me/{numeroLimpio}";
    }
}