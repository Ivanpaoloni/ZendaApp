@page "/reportes"
@using Zenda.Core.DTOs
@using Zenda.Client.Services
@inject ReporteClient ReporteClient

<PageTitle>Reportes y Métricas - Zenda</PageTitle>

<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 gap-4">
    <h2 class="text-2xl font-bold text-primary tracking-tight">Métricas del Negocio</h2>

    <div class="flex flex-wrap items-center gap-2 bg-white/50 backdrop-blur-sm p-2 rounded-2xl border border-surface-container-high shadow-sm">
        <input type="date" class="bg-transparent px-3 py-2 rounded-xl text-sm font-medium text-gray-700 focus:outline-none focus:ring-2 focus:ring-primary/50 transition-all border border-transparent hover:border-surface-container-high" @bind="FechaInicio" />
        <span class="text-on-surface-variant font-bold">-</span>
        <input type="date" class="bg-transparent px-3 py-2 rounded-xl text-sm font-medium text-gray-700 focus:outline-none focus:ring-2 focus:ring-primary/50 transition-all border border-transparent hover:border-surface-container-high" @bind="FechaFin" />

        <button class="bg-primary text-white px-4 py-2 rounded-xl text-sm font-bold flex items-center gap-2 hover:bg-primary/90 transition-all shadow-sm" @onclick="CargarDatos">
            <span class="material-symbols-outlined text-[18px]">search</span> Filtrar
        </button>

        @* BOTÓN DE EXPORTAR EXCEL (Estilo Cliente) *@
        @if (Metricas != null)
        {
            <button @onclick="ExportarExcel" disabled="@exportando"
                    class="flex items-center justify-center gap-2 px-4 py-2 bg-white text-green-700 border border-surface-container-high rounded-xl font-bold hover:bg-green-50 hover:border-green-200 transition-all disabled:opacity-50 shadow-sm group ml-auto md:ml-0">
                @if (exportando)
                {
                    <div class="animate-spin rounded-full h-4 w-4 border-t-2 border-b-2 border-green-700"></div>
                    <span class="text-sm hidden sm:inline text-on-surface-variant">Generando...</span>
                }
                else
                {
                    <svg class="w-4 h-4 text-green-600 group-hover:text-green-700 transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                        <polyline points="14 2 14 8 20 8"></polyline>
                        <line x1="8" y1="13" x2="16" y2="13"></line>
                        <line x1="8" y1="17" x2="16" y2="17"></line>
                        <polyline points="10 9 9 9 8 9"></polyline>
                    </svg>
                    <span class="text-sm hidden sm:inline">Exportar</span>
                }
            </button>
        }
    </div>
</div>

@if (Cargando)
{
    <div class="flex flex-col items-center justify-center py-20">
        <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-primary mb-4"></div>
        <p class="text-on-surface-variant font-medium text-sm animate-pulse">Calculando métricas en tiempo real...</p>
    </div>
}
else if (Metricas != null)
{
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">

        <div class="bg-primary text-white rounded-[2rem] p-6 shadow-sm flex flex-col justify-between relative overflow-hidden group">
            <div class="absolute -right-4 -top-4 opacity-10 group-hover:scale-110 transition-transform">
                <span class="material-symbols-outlined text-[100px]">payments</span>
            </div>
            <h6 class="text-[10px] uppercase tracking-widest font-bold opacity-80 mb-2 relative z-10">Ingresos Totales</h6>
            <h3 class="text-3xl md:text-4xl font-black truncate relative z-10">$@Metricas.IngresosTotales.ToString("N0")</h3>
        </div>

        <div class="bg-[#059669] text-white rounded-[2rem] p-6 shadow-sm flex flex-col justify-between relative overflow-hidden group">
            <div class="absolute -right-4 -top-4 opacity-10 group-hover:scale-110 transition-transform">
                <span class="material-symbols-outlined text-[100px]">receipt_long</span>
            </div>
            <h6 class="text-[10px] uppercase tracking-widest font-bold opacity-80 mb-2 relative z-10">Ticket Promedio</h6>
            <h3 class="text-3xl md:text-4xl font-black truncate relative z-10">$@Metricas.TicketPromedio.ToString("N0")</h3>
        </div>

        <div class="bg-[#0284c7] text-white rounded-[2rem] p-6 shadow-sm flex flex-col justify-between relative overflow-hidden group">
            <div class="absolute -right-4 -top-4 opacity-10 group-hover:scale-110 transition-transform">
                <span class="material-symbols-outlined text-[100px]">check_circle</span>
            </div>
            <h6 class="text-[10px] uppercase tracking-widest font-bold opacity-80 mb-2 relative z-10">Turnos Completados</h6>
            <h3 class="text-3xl md:text-4xl font-black truncate relative z-10">@Metricas.TurnosCompletados</h3>
        </div>

        <div class="bg-[#f59e0b] text-white rounded-[2rem] p-6 shadow-sm flex flex-col justify-between relative overflow-hidden group">
            <div class="absolute -right-4 -top-4 opacity-10 group-hover:scale-110 transition-transform">
                <span class="material-symbols-outlined text-[100px]">event_busy</span>
            </div>
            <h6 class="text-[10px] uppercase tracking-widest font-bold opacity-80 mb-2 relative z-10">Turnos Cancelados</h6>
            <h3 class="text-3xl md:text-4xl font-black truncate relative z-10">@Metricas.TurnosCancelados</h3>
            <small class="text-xs opacity-90 mt-1 relative z-10 font-medium">Reservas dadas de baja en el periodo</small>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

        <div class="bg-white/80 backdrop-blur-xl border border-surface-container-high rounded-[2rem] p-6 shadow-sm flex flex-col">
            <div class="flex items-center gap-2 mb-6">
                <span class="material-symbols-outlined text-primary text-[24px]">inventory_2</span>
                <h5 class="text-lg font-bold text-primary mb-0">Servicios más solicitados</h5>
            </div>

            <div class="flex-1">
                @if (!Metricas.TopServicios.Any())
                {
                    <div class="h-full flex flex-col items-center justify-center text-on-surface-variant opacity-60">
                        <span class="material-symbols-outlined text-[40px] mb-2">query_stats</span>
                        <p class="text-sm font-medium">No hay datos en este periodo.</p>
                    </div>
                }
                else
                {
                    var maxServicios = Metricas.TopServicios.Max(x => x.Valor);
                    foreach (var item in Metricas.TopServicios)
                    {
                        var porcentaje = maxServicios > 0 ? (item.Valor / maxServicios) * 100 : 0;
                        <div class="mb-4">
                            <div class="flex justify-between items-end mb-1 text-sm">
                                <span class="font-bold text-gray-700">@item.Etiqueta</span>
                                <span class="font-black text-primary">@item.Valor</span>
                            </div>
                            <div class="w-full bg-surface-container-high rounded-full h-2.5 overflow-hidden">
                                <div class="bg-primary h-full rounded-full transition-all duration-1000 ease-out" style="width: @porcentaje.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="bg-white/80 backdrop-blur-xl border border-surface-container-high rounded-[2rem] p-6 shadow-sm flex flex-col">
            <div class="flex items-center gap-2 mb-6">
                <span class="material-symbols-outlined text-[#059669] text-[24px]">content_cut</span>
                <h5 class="text-lg font-bold text-primary mb-0">Facturación por Profesional</h5>
            </div>

            <div class="flex-1">
                @if (!Metricas.IngresosPorPrestador.Any())
                {
                    <div class="h-full flex flex-col items-center justify-center text-on-surface-variant opacity-60">
                        <span class="material-symbols-outlined text-[40px] mb-2">query_stats</span>
                        <p class="text-sm font-medium">No hay datos en este periodo.</p>
                    </div>
                }
                else
                {
                    var maxIngreso = Metricas.IngresosPorPrestador.Max(x => x.Valor);
                    foreach (var item in Metricas.IngresosPorPrestador)
                    {
                        var porcentaje = maxIngreso > 0 ? (item.Valor / maxIngreso) * 100 : 0;
                        <div class="mb-4">
                            <div class="flex justify-between items-end mb-1 text-sm">
                                <span class="font-bold text-gray-700">@item.Etiqueta</span>
                                <span class="font-black text-[#059669]">$@item.Valor.ToString("N0")</span>
                            </div>
                            <div class="w-full bg-surface-container-high rounded-full h-2.5 overflow-hidden">
                                <div class="bg-[#059669] h-full rounded-full transition-all duration-1000 ease-out" style="width: @porcentaje.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
}

@code {
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private DateTime FechaInicio { get; set; } = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1); // Por defecto inicio de mes
    private DateTime FechaFin { get; set; } = DateTime.Today;
    private bool Cargando { get; set; } = true;
    private bool exportando = false;
    private ReporteDashboardDto? Metricas;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        Cargando = true;
        try
        {
            Metricas = await ReporteClient.GetDashboardMetricsAsync(FechaInicio, FechaFin);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar métricas: {ex.Message}");
        }
        finally
        {
            Cargando = false;
        }
    }

    private async Task ExportarExcel()
    {
        exportando = true;
        StateHasChanged();

        try
        {
            var stream = await ReporteClient.GetExcelStreamAsync(FechaInicio, FechaFin);
            if (stream != null)
            {
                using var streamRef = new DotNetStreamReference(stream);
                // Tu script global se encarga de la magia
                await JS.InvokeVoidAsync("downloadFileFromStream", $"Metricas_Zendy_{DateTime.Now:yyyyMMdd}.xlsx", streamRef);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error exportando Excel: {ex.Message}");
        }
        finally
        {
            exportando = false;
            StateHasChanged();
        }
    }
}