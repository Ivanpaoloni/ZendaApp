@page "/sedes"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Zenda.Core.DTOs
@using Zenda.Client.Components

<div class="space-y-8 animate-in fade-in duration-500 pb-20 relative">

    @* Encabezado *@
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
            <h1 class="text-3xl font-bold text-primary tracking-tighter font-headline">Mis Sedes</h1>
            <p class="text-on-surface-variant text-sm">Gestioná las ubicaciones físicas de tu negocio.</p>
        </div>

        <button @onclick="ManejarClickNuevo"
                class="px-6 py-3 @(puedeAgregarMas ? "bg-primary text-white shadow-primary/20 hover:scale-[1.02] active:scale-[0.98]" : "bg-surface-container-high text-on-surface-variant/80 border border-surface-container-highest hover:bg-surface-container-highest hover:text-primary") font-bold rounded-2xl shadow-lg transition-all flex items-center gap-2 cursor-pointer">
            <span class="material-symbols-outlined">@(puedeAgregarMas ? "add_circle" : "lock")</span>
            @(puedeAgregarMas ? "Nueva Sede" : "Límite alcanzado")
        </button>
    </div>

    @* Mensaje de error general de la pantalla *@
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="bg-red-50 text-red-600 p-4 rounded-2xl border border-red-100 flex items-center justify-between animate-in zoom-in duration-300">
            <div class="flex items-center gap-3">
                <span class="material-symbols-outlined">error</span>
                <p class="font-bold text-sm">@errorMessage</p>
            </div>
            <button @onclick="LimpiarError" class="hover:opacity-70 text-red-600 flex items-center justify-center p-1">
                <span class="material-symbols-outlined text-sm">close</span>
            </button>
        </div>
    }

    @* Lista de Sedes *@
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        @if (sedes == null)
        {
            <div class="col-span-full py-12 text-center animate-pulse text-on-surface-variant font-bold">Cargando tus sedes...</div>
        }
        else if (!sedes.Any())
        {
            <div class="col-span-full py-16 text-center bg-surface-container-low rounded-[3rem] border-2 border-dashed border-surface-container-high animate-in fade-in zoom-in duration-500">
                <div class="w-20 h-20 bg-white rounded-3xl flex items-center justify-center mx-auto mb-6 shadow-sm">
                    <span class="material-symbols-outlined text-5xl text-primary/30">storefront</span>
                </div>
                <h3 class="text-xl font-headline font-bold text-primary mb-2">Aún no tenés sedes</h3>
                <p class="text-on-surface-variant font-body text-sm max-w-xs mx-auto mb-8">
                    Comenzá creando tu primera ubicación física para que tus clientes sepan a dónde ir.
                </p>
                <button @onclick="() => AbrirModalSede()"
                        class="px-8 py-4 bg-primary text-white font-bold rounded-2xl shadow-xl shadow-primary/20 hover:scale-105 transition-all inline-flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm">add</span>
                    Crear mi primera sede
                </button>
            </div>
        }
        else
        {
            @foreach (var sede in sedes)
            {
                <div class="bg-white p-6 rounded-[2.5rem] border border-surface-container-high editorial-shadow group hover:border-primary/20 transition-all relative overflow-hidden flex flex-col h-full">

                    <div class="flex justify-between items-start mb-4">
                        <div class="flex items-center gap-4">
                            <div class="w-14 h-14 rounded-2xl bg-secondary-container/50 text-primary flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-colors duration-300">
                                <span class="material-symbols-outlined text-[28px]">location_on</span>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg text-primary leading-tight mb-1">@sede.Nombre</h3>
                                <p class="text-on-surface-variant text-xs line-clamp-1">@sede.Direccion</p>
                            </div>
                        </div>

                        <div class="flex items-center gap-1">
                            <button @onclick="() => AbrirModalSede(sede)" class="p-1.5 text-on-surface-variant hover:text-primary hover:bg-primary/10 rounded-lg transition-all" title="Editar">
                                <span class="material-symbols-outlined text-[18px]">edit</span>
                            </button>
                            <button @onclick="() => PrepararEliminarSede(sede)" class="p-1.5 text-on-surface-variant hover:text-error hover:bg-error/10 rounded-lg transition-all" title="Eliminar">
                                <span class="material-symbols-outlined text-[18px]">delete</span>
                            </button>
                        </div>
                    </div>

                    <div class="mt-auto pt-4 flex gap-2">
                        <span class="px-3 py-1.5 bg-surface-container-low text-[10px] font-bold rounded-xl text-on-surface-variant flex items-center gap-1 border border-surface-container-high">
                            <span class="material-symbols-outlined text-[14px]">schedule</span>
                            @sede.ZonaHorariaId
                        </span>
                    </div>
                </div>
            }
        }
    </div>


</div>
@* Modal de Formulario (Crear/Editar) *@
@if (mostrarModalSede)
{
    <div class="fixed inset-0 bg-black/40 backdrop-blur-sm z-50 flex items-center justify-center p-4 animate-in fade-in duration-200">
        <div class="bg-white rounded-[2rem] p-8 max-w-md w-full editorial-shadow animate-in zoom-in-95 duration-300">
            <h3 class="font-headline font-bold text-xl text-primary mb-4">@(sedeEnEdicionId == null ? "Nueva Sede" : "Editar Sede")</h3>

            <EditForm Model="nuevaSede" OnValidSubmit="GuardarSede">
                <DataAnnotationsValidator />

                <div class="space-y-4">
                    <div class="flex flex-col gap-2">
                        <label class="block text-[10px] font-bold uppercase tracking-widest text-on-surface-variant ml-1">Nombre de la Sede</label>
                        <InputText @bind-Value="nuevaSede.Nombre" placeholder="Ej: Sucursal Centro"
                                    class="w-full p-4 bg-surface-container-low rounded-2xl outline-none focus:ring-2 focus:ring-primary font-body text-primary" />
                        <ValidationMessage For="@(() => nuevaSede.Nombre)" class="text-error text-[10px] font-bold px-1" />
                    </div>

                    <div class="flex flex-col gap-2">
                        <label class="block text-[10px] font-bold uppercase tracking-widest text-on-surface-variant ml-1">Dirección Exacta</label>
                        <InputText @bind-Value="nuevaSede.Direccion" placeholder="Ej: Av. Corrientes 1234, CABA"
                                    class="w-full p-4 bg-surface-container-low rounded-2xl outline-none focus:ring-2 focus:ring-primary font-body text-primary" />
                        <ValidationMessage For="@(() => nuevaSede.Direccion)" class="text-error text-[10px] font-bold px-1" />
                    </div>

                    <div class="flex flex-col gap-2">
                        <label class="block text-[10px] font-bold uppercase tracking-widest text-on-surface-variant ml-1">Zona Horaria del Local</label>
                        <InputSelect @bind-Value="nuevaSede.ZonaHorariaId"
                                        class="w-full p-4 bg-surface-container-low rounded-2xl outline-none focus:ring-2 focus:ring-primary font-body text-primary appearance-none cursor-pointer">
                            @foreach (var tz in zonasHorarias)
                            {
                                <option value="@tz.Id">@tz.DisplayName</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => nuevaSede.ZonaHorariaId)" class="text-error text-[10px] font-bold px-1" />
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(mensajeErrorModal))
                {
                    <p class="text-error text-xs mt-4 font-bold text-center">@mensajeErrorModal</p>
                }

                <div class="flex gap-3 mt-8">
                    <button type="button" @onclick="CerrarModalSede" class="flex-1 py-4 bg-surface-container-low text-primary font-bold rounded-2xl hover:brightness-95 transition-all">Cancelar</button>
                    <button type="submit" disabled="@isSubmitting"
                            class="flex-1 py-4 bg-primary text-white font-bold rounded-2xl hover:brightness-110 transition-all flex justify-center items-center gap-2">
                        @if (isSubmitting)
                        {
                            <div class="animate-spin rounded-full h-4 w-4 border-b-2 border-white"></div>
                        }
                        else
                        {
                            <span>Guardar</span>
                        }
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

<ConfirmDialog Visible="@mostrarConfirmacion"
               Titulo="@tituloConfirmacion"
               Mensaje="@mensajeConfirmacion"
               OnRespuesta="ManejarRespuestaConfirmacion" />

<AlertDialog Visible="@mostrarAlerta"
             Titulo="@tituloAlerta"
             Mensaje="@mensajeAlerta"
             OnCerrar="CerrarAlerta" />

<UpgradeModal @bind-Visible="mostrarModalUpgrade"
              Titulo="¡Expandí tus fronteras!"
              Icono="storefront">
    Has alcanzado el límite de <strong>@State.CurrentNegocio?.MaxSedes sedes</strong> de tu plan <strong>@State.CurrentNegocio?.PlanNombre</strong>. Subí de nivel para abrir más sucursales.
</UpgradeModal>