@page "/sedes/nueva"
@inject SedeClient SedeService
@inject NavigationManager Nav
@using Zenda.Core.DTOs

<div class="max-w-xl mx-auto mb-8 animate-in fade-in slide-in-from-bottom-4 duration-700">
    <button @onclick='() => Nav.NavigateTo("/sedes")' class="text-[10px] font-bold uppercase tracking-widest text-primary hover:underline flex items-center gap-1 mb-6 ml-2">
        <span class="material-symbols-outlined text-xs">arrow_back</span> Volver a Sedes
    </button>

    <h1 class="text-4xl md:text-5xl font-headline font-extrabold text-primary tracking-tight mb-2">
        Nueva Sede
    </h1>
    <p class="text-on-surface-variant font-body mt-2">Agregá una nueva sucursal con su ubicación exacta.</p>
</div>

<div class="max-w-xl mx-auto bg-white p-8 md:p-10 rounded-[2.5rem] editorial-shadow animate-in zoom-in-95 duration-500 delay-150">
    <EditForm Model="nuevaSede" OnValidSubmit="GuardarSede">
        <DataAnnotationsValidator />

        <div class="space-y-6">
            <div>
                <label class="block text-[10px] font-bold uppercase tracking-[0.2em] text-on-surface-variant mb-3 ml-2">Nombre del Local</label>
                <InputText @bind-Value="nuevaSede.Nombre" placeholder="Ej: Zenda Barber - Centro"
                           class="w-full p-5 bg-surface-container-low rounded-3xl outline-none focus:ring-2 focus:ring-primary font-headline font-bold text-primary placeholder:text-on-surface-variant/40 transition-all" />
                <ValidationMessage For="@(() => nuevaSede.Nombre)" class="text-error text-xs mt-2 ml-2 font-bold font-body" />
            </div>

            <div>
                <label class="block text-[10px] font-bold uppercase tracking-[0.2em] text-on-surface-variant mb-3 ml-2">Dirección Exacta</label>
                <div class="relative">
                    <span class="absolute left-5 top-5 material-symbols-outlined text-on-surface-variant/50">location_on</span>
                    <InputText @bind-Value="nuevaSede.Direccion" placeholder="Ej: Av. Corrientes 1234, CABA"
                               class="w-full p-5 pl-14 bg-surface-container-low rounded-3xl outline-none focus:ring-2 focus:ring-primary font-headline font-bold text-primary placeholder:text-on-surface-variant/40 transition-all" />
                </div>
                <ValidationMessage For="@(() => nuevaSede.Direccion)" class="text-error text-xs mt-2 ml-2 font-bold font-body" />
            </div>

            <div>
                <label class="block text-[10px] font-bold uppercase tracking-[0.2em] text-on-surface-variant mb-3 ml-2">Zona Horaria del Local</label>
                <div class="relative">
                    <span class="absolute left-5 top-5 material-symbols-outlined text-on-surface-variant/50">schedule</span>
                    <select @bind="nuevaSede.ZonaHorariaId" class="w-full p-5 pl-14 bg-surface-container-low rounded-3xl outline-none focus:ring-2 focus:ring-primary font-body text-primary transition-all appearance-none cursor-pointer border-r-[20px] border-transparent">
                        @foreach (var tz in zonasHorarias)
                        {
                            <option value="@tz.Id">@tz.DisplayName</option>
                        }
                    </select>
                </div>
            </div>
            <div class="pt-6">
                <button type="submit" disabled="@guardando"
                        class="w-full py-5 bg-primary text-on-primary rounded-2xl font-headline font-bold text-lg shadow-xl shadow-primary/20 hover:brightness-110 active:scale-95 transition-all flex items-center justify-center gap-3">
                    @if (guardando)
                    {
                        <div class="animate-spin rounded-full h-6 w-6 border-t-2 border-b-2 border-white"></div>
                        <span>Registrando...</span>
                    }
                    else
                    {
                        <span class="material-symbols-outlined">add_business</span>
                        <span>Crear Sede</span>
                    }
                </button>
            </div>
        </div>
    </EditForm>
</div>

@code {
    private SedeCreateDto nuevaSede = new();
    private bool guardando = false;
    private IReadOnlyCollection<TimeZoneInfo> zonasHorarias = new List<TimeZoneInfo>();

    protected override void OnInitialized()
    {
        // Temporal: asignamos un ID de negocio estático hasta tener el Auth/Login.
        nuevaSede.NegocioId = Guid.Parse("00000000-0000-0000-0000-000000000001");
        zonasHorarias = TimeZoneInfo.GetSystemTimeZones();
        // Establecemos el valor por defecto en el DTO para el dropdown
        nuevaSede.ZonaHorariaId = "America/Argentina/Buenos_Aires";
    }

    private async Task GuardarSede()
    {
        guardando = true;
        try
        {
            await SedeService.Create(nuevaSede);
            Nav.NavigateTo("/sedes");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error guardando sede: {ex.Message}");
            // Acá podrías mostrar un toast de error en el futuro
        }
        finally
        {
            guardando = false;
        }
    }
}