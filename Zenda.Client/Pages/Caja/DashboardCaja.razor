@page "/caja"
@attribute [Authorize]
@inject CajaClient CajaClient
@inject SedeClient SedeClient
@inject NavigationManager Nav
@using Microsoft.AspNetCore.Authorization
@using Zenda.Client.Services
@using Zenda.Core.DTOs
@using Zenda.Core.Enums

<PageTitle>Caja Diaria - Zenda</PageTitle>

<div class="space-y-10 animate-in fade-in slide-in-from-bottom-4 duration-700 pb-20 relative">
    
    @* 1. ENCABEZADO *@
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
            <h1 class="text-3xl font-bold text-primary tracking-tighter font-headline">Caja Diaria</h1>
            <p class="text-on-surface-variant text-sm">Controlá los ingresos y egresos de tu jornada.</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="flex justify-center items-center py-20">
            <div class="animate-spin rounded-full h-12 w-12 border-t-2 border-b-2 border-primary"></div>
        </div>
    }
    else if (cajaActual == null)
    {
        @* ESTADO: CAJA CERRADA (Rediseñado como Card Premium) *@
        <div class="bg-white rounded-[3rem] p-8 md:p-12 editorial-shadow text-center max-w-2xl mx-auto border border-surface-container-high animate-in zoom-in duration-500">
            <div class="w-24 h-24 bg-primary/5 text-primary rounded-full flex items-center justify-center mx-auto mb-6 shadow-inner">
                <span class="material-symbols-outlined text-5xl">point_of_sale</span>
            </div>
            <h2 class="font-headline font-black text-3xl text-primary mb-3">La caja está cerrada</h2>
            <p class="text-on-surface-variant text-base mb-10 max-w-sm mx-auto">Ingresá el monto inicial en efectivo para comenzar a registrar movimientos hoy.</p>

            <div class="max-w-xs mx-auto space-y-6">
                <div class="relative group">
                    <span class="absolute left-5 top-1/2 -translate-y-1/2 text-primary font-black text-xl">$</span>
                    <input type="number" @bind="montoApertura" placeholder="0.00"
                           class="w-full bg-surface-container-lowest border-2 border-surface-container-high focus:border-primary focus:bg-white rounded-3xl pl-12 pr-6 py-5 font-headline text-2xl text-primary font-black transition-all outline-none shadow-sm" />
                </div>

                <button @onclick="AbrirCaja" disabled="@isSubmitting"
                        class="w-full py-5 bg-primary text-white font-headline font-bold text-lg rounded-[2rem] hover:scale-[1.02] active:scale-95 transition-all shadow-xl shadow-primary/20 flex items-center justify-center gap-2">
                    @if (isSubmitting)
                    {
                        <div class="animate-spin rounded-full h-5 w-5 border-2 border-white/30 border-t-white"></div>
                    }
                    Aperturar Caja
                </button>
            </div>
        </div>
    }
    else
    {
        @* ESTADO: CAJA ABIERTA - DASHBOARD *@
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 animate-in fade-in slide-in-from-bottom-6 duration-700">

            @* Tarjeta: Ingresos *@
            <div class="bg-white rounded-3xl p-7 editorial-shadow border border-transparent hover:border-green-500/30 transition-all flex flex-col justify-between group hover:-translate-y-1">
                <div class="mb-4">
                    <h6 class="text-xs font-bold uppercase tracking-widest text-on-surface-variant group-hover:text-green-600 transition-colors">Ingresos</h6>
                    <p class="text-[10px] font-medium text-on-surface-variant/70 uppercase">Entradas del día</p>
                </div>
                <div>
                    <p class="text-4xl font-headline font-black text-primary mb-2">$@cajaActual.TotalIngresos.ToString("N0")</p>
                    <div class="flex items-center text-[10px] font-bold text-green-600 bg-green-50 px-2 py-0.5 rounded-lg w-fit">
                        <span class="material-symbols-outlined text-[14px] mr-1">arrow_upward</span>
                        POSITIVO
                    </div>
                </div>
            </div>

            @* Tarjeta: Egresos *@
            <div class="bg-white rounded-3xl p-7 editorial-shadow border border-transparent hover:border-error/30 transition-all flex flex-col justify-between group hover:-translate-y-1">
                <div class="mb-4">
                    <h6 class="text-xs font-bold uppercase tracking-widest text-on-surface-variant group-hover:text-error transition-colors">Egresos / Gastos</h6>
                    <p class="text-[10px] font-medium text-on-surface-variant/70 uppercase">Salidas del día</p>
                </div>
                <div>
                    <p class="text-4xl font-headline font-black text-primary mb-2">$@cajaActual.TotalEgresos.ToString("N0")</p>
                    <div class="flex items-center text-[10px] font-bold text-error bg-error/5 px-2 py-0.5 rounded-lg w-fit">
                        <span class="material-symbols-outlined text-[14px] mr-1">arrow_downward</span>
                        DESCUENTO
                    </div>
                </div>
            </div>

            @* Tarjeta: Saldo Final (Estilo Destacado como el Link de Reservas) *@
            <div class="bg-primary rounded-3xl p-7 editorial-shadow text-on-primary hover:-translate-y-1 transition-all relative overflow-hidden group">
                <div class="absolute -right-6 -bottom-6 w-32 h-32 bg-white/10 rounded-full group-hover:scale-125 transition-transform duration-700"></div>

                <div class="relative z-10 flex flex-col h-full justify-between">
                    <div>
                        <h6 class="text-xs font-bold uppercase tracking-widest opacity-80">Saldo Total en Caja</h6>
                        <p class="text-[10px] font-medium opacity-60 uppercase">+ $@cajaActual.MontoInicial.ToString("N0") Inicial</p>
                    </div>
                    <div class="mt-4">
                        <p class="text-4xl font-headline font-black">$@cajaActual.SaldoActual.ToString("N0")</p>
                        <span class="inline-block mt-2 px-3 py-1 bg-white/10 rounded-lg text-[10px] font-bold uppercase tracking-widest">Efectivo + Digital</span>
                    </div>
                </div>
            </div>
        </div>

        @* Historial de Movimientos (Estilo "Próximos en llegar") *@
        <div class="space-y-4 animate-in fade-in slide-in-from-bottom-10 duration-700 delay-200">
            <h2 class="text-2xl font-headline font-bold text-primary px-2">Historial de Movimientos</h2>

            <div class="bg-white rounded-4xl editorial-shadow p-2 overflow-hidden border border-surface-container-high">
                @if (!cajaActual.Movimientos.Any())
                {
                    <div class="p-16 text-center text-on-surface-variant opacity-50 italic">
                        <span class="material-symbols-outlined text-4xl block mb-2">history</span>
                        No hay movimientos registrados hoy.
                    </div>
                }
                else
                {
                    @foreach (var mov in cajaActual.Movimientos.OrderByDescending(x => x.CreatedAtUtc))
                    {
                        var esIngreso = mov.Tipo == TipoMovimientoEnum.Ingreso;

                        <div class="p-5 flex items-center gap-5 hover:bg-surface-container-low transition-colors border-b border-surface-container last:border-b-0 group">
                            @* Hora con Estilo *@
                            <div class="w-16 h-16 rounded-2xl bg-surface-container-high text-primary flex flex-col items-center justify-center flex-shrink-0 group-hover:bg-primary group-hover:text-white transition-all shadow-sm font-headline">
                                <span class="text-lg font-black leading-none">@mov.CreatedAtUtc.ToLocalTime().ToString("HH")</span>
                                <span class="text-[10px] font-bold">@mov.CreatedAtUtc.ToLocalTime().ToString("mm")</span>
                            </div>

                            @* Detalle *@
                            <div class="flex-grow">
                                <h4 class="font-headline font-bold text-lg text-primary leading-tight">@mov.Detalle</h4>
                                <div class="flex items-center gap-2 mt-1">
                                    <span class="px-2 py-0.5 bg-secondary-container text-primary text-[10px] font-black uppercase tracking-widest rounded-md">
                                        @mov.MedioPago
                                    </span>
                                </div>
                            </div>

                            @* Monto *@
                            <div class="text-right">
                                <p class="text-xl font-headline font-black @(esIngreso ? "text-green-600" : "text-error")">
                                    @(esIngreso ? "+" : "-") $@mov.Monto.ToString("N0")
                                </p>
                                <span class="text-[9px] font-bold uppercase tracking-tighter text-on-surface-variant/50">
                                    @(esIngreso ? "Ingreso" : "Egreso")
                                </span>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }
</div>

@code {
    private CajaDiariaDto? cajaActual;
    private bool isLoading = true;
    private bool isSubmitting = false;
    private decimal montoApertura = 0;
    private Guid sedePrincipalId; // Asumiremos por ahora que usamos la primera sede

    protected override async Task OnInitializedAsync()
    {
        // Usamos GetAll() que es el método real de tu SedeClient
        var sedes = await SedeClient.GetAll();

        if (sedes != null && sedes.Any())
        {
            sedePrincipalId = sedes.First().Id;
            await CargarCaja();
        }
        else
        {
            isLoading = false;
        }
    }

    private async Task CargarCaja()
    {
        isLoading = true;
        cajaActual = await CajaClient.GetCajaHoyAsync(sedePrincipalId);
        isLoading = false;
    }

    private async Task AbrirCaja()
    {
        isSubmitting = true;
        try
        {
            await CajaClient.AbrirCajaAsync(sedePrincipalId, montoApertura);
            await CargarCaja(); // Recarga la UI mostrando el dashboard
        }
        catch (Exception ex)
        {
            // Mostrar error (puedes usar tu componente AlertDialog)
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isSubmitting = false;
        }
    }
}