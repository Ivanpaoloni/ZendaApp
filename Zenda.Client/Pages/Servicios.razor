@page "/servicios"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Zenda.Core.DTOs
@using Zenda.Client.Services
@inject ServicioClient _servicioClient

<div class="space-y-8 animate-in fade-in duration-500 pb-20 relative">

    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
            <h1 class="text-3xl font-bold text-primary tracking-tighter font-headline">Catálogo de Servicios</h1>
            <p class="text-on-surface-variant text-sm">Definí qué hacés, cuánto dura y qué valor tiene.</p>
        </div>
        <button @onclick="() => AbrirModalCategoria()"
                class="px-6 py-3 bg-primary text-white font-bold rounded-2xl shadow-lg shadow-primary/20 hover:scale-[1.02] active:scale-[0.98] transition-all flex items-center gap-2">
            <span class="material-symbols-outlined">add_circle</span>
            Nueva Categoría
        </button>
    </div>

    @if (cargando)
    {
        <div class="flex justify-center py-20">
            <div class="animate-spin rounded-full h-10 w-10 border-t-2 border-b-2 border-primary"></div>
        </div>
    }
    else if (!string.IsNullOrEmpty(mensajeError))
    {
        <div class="bg-red-50 text-red-600 p-4 rounded-2xl border border-red-100 flex items-center gap-3">
            <span class="material-symbols-outlined">error</span>
            <p class="font-bold text-sm">@mensajeError</p>
        </div>
    }
    else if (!categorias.Any())
    {
        <div class="bg-surface-container-low border border-dashed border-outline p-12 rounded-[2rem] text-center">
            <span class="material-symbols-outlined text-4xl text-on-surface-variant mb-4">inventory_2</span>
            <h3 class="font-headline font-bold text-lg text-primary">Tu catálogo está vacío</h3>
            <p class="text-sm text-on-surface-variant mb-6 mt-1">Comenzá creando tu primera categoría (ej: Barbería, Estética).</p>
            <button @onclick="() => AbrirModalCategoria()" class="text-primary font-bold hover:underline">Crear mi primera categoría</button>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            @foreach (var categoria in categorias)
            {
                <div class="bg-white rounded-[2rem] editorial-shadow overflow-hidden border border-surface-container-high h-fit">

                    <div class="p-6 bg-surface-container-low border-b border-surface-container-high flex justify-between items-center group/cat">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl bg-primary/10 text-primary flex items-center justify-center">
                                <span class="material-symbols-outlined">folder</span>
                            </div>
                            <h2 class="font-headline font-bold text-xl text-primary">@categoria.Nombre</h2>

                            <div class="opacity-0 group-hover/cat:opacity-100 transition-opacity flex gap-1 ml-2">
                                <button @onclick="() => AbrirModalCategoria(categoria)" class="p-1.5 text-on-surface-variant hover:text-primary hover:bg-primary/10 rounded-lg transition-all" title="Editar">
                                    <span class="material-symbols-outlined text-[18px]">edit</span>
                                </button>
                                <button @onclick="() => EliminarCategoria(categoria.Id)" class="p-1.5 text-on-surface-variant hover:text-error hover:bg-error/10 rounded-lg transition-all" title="Eliminar">
                                    <span class="material-symbols-outlined text-[18px]">delete</span>
                                </button>
                            </div>
                        </div>
                        <button @onclick="() => AbrirModalServicio(categoria.Id)"
                                class="text-xs font-bold text-primary hover:bg-primary/10 px-3 py-2 rounded-xl transition-colors flex items-center gap-1">
                            <span class="material-symbols-outlined text-[16px]">add</span> Servicio
                        </button>
                    </div>

                    <div class="p-2">
                        @if (!categoria.Servicios.Any())
                        {
                            <p class="text-xs text-on-surface-variant text-center p-4 italic">No hay servicios en esta categoría.</p>
                        }

                        @foreach (var servicio in categoria.Servicios)
                        {
                            <div class="p-4 hover:bg-surface-container-low rounded-2xl transition-colors flex items-center justify-between group cursor-pointer border-b border-surface-container-high last:border-0">

                                @* Lado Izquierdo: Nombre y Duración *@
                                <div>
                                    <h3 class="font-bold text-primary text-sm">@servicio.Nombre</h3>
                                    <p class="text-xs text-on-surface-variant flex items-center gap-1 mt-1">
                                        <span class="material-symbols-outlined text-[14px]">schedule</span> @servicio.DuracionMinutos min
                                    </p>
                                </div>

                                @* Lado Derecho: Precio y Botones de Acción *@
                                <div class="flex items-center gap-4">
                                    <span class="font-headline font-black text-primary">@servicio.Precio.ToString("C0")</span>

                                    <div class="opacity-0 group-hover:opacity-100 transition-opacity flex gap-1">
                                        @* Botón Editar *@
                                        <button @onclick="() => AbrirModalServicio(categoria.Id, servicio)"
                                                class="p-1.5 text-on-surface-variant hover:text-primary hover:bg-primary/10 rounded-lg transition-all" title="Editar">
                                            <span class="material-symbols-outlined text-[18px]">edit</span>
                                        </button>

                                        @* Botón Eliminar *@
                                        <button @onclick="() => EliminarServicio(categoria.Id, servicio.Id)"
                                                class="p-1.5 text-on-surface-variant hover:text-error hover:bg-error/10 rounded-lg transition-all" title="Eliminar">
                                            <span class="material-symbols-outlined text-[18px]">delete</span>
                                        </button>
                                    </div>
                                </div>

                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }

    @if (mostrarModalCategoria)
    {
        <div class="fixed inset-0 bg-black/40 backdrop-blur-sm z-50 flex items-center justify-center p-4 animate-in fade-in duration-200">
            <div class="bg-white rounded-[2rem] p-8 max-w-sm w-full editorial-shadow animate-in zoom-in-95 duration-300">
                <h3 class="font-headline font-bold text-xl text-primary mb-4">Nueva Categoría</h3>

                <div class="space-y-4">
                    <div>
                        <label class="block text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-2 ml-1">Nombre</label>
                        <input @bind="nuevaCategoria.Nombre" placeholder="Ej: Barbería Clásica"
                               class="w-full p-4 bg-surface-container-low rounded-2xl outline-none focus:ring-2 focus:ring-primary font-body text-primary" />
                    </div>
                </div>

                <div class="flex gap-3 mt-8">
                    <button @onclick="CerrarModalCategoria" class="flex-1 py-4 bg-surface-container-low text-primary font-bold rounded-2xl hover:brightness-95 transition-all">Cancelar</button>
                    <button @onclick="GuardarCategoria" disabled="@guardando"
                            class="flex-1 py-4 bg-primary text-white font-bold rounded-2xl hover:brightness-110 transition-all flex justify-center items-center gap-2">
                        @if (guardando)
                        {
                            <div class="animate-spin rounded-full h-4 w-4 border-b-2 border-white"></div>
                        }
                        else
                        {

                            <span>Guardar</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    }

    @if (mostrarModalServicio)
    {
        <div class="fixed inset-0 bg-black/40 backdrop-blur-sm z-50 flex items-center justify-center p-4 animate-in fade-in duration-200">
            <div class="bg-white rounded-[2rem] p-8 max-w-md w-full editorial-shadow animate-in zoom-in-95 duration-300">
                <h3 class="font-headline font-bold text-xl text-primary mb-4">Nuevo Servicio</h3>

                <div class="space-y-4">
                    <div>
                        <label class="block text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-2 ml-1">Nombre del Servicio</label>
                        <input @bind="nuevoServicio.Nombre" placeholder="Ej: Corte + Barba"
                               class="w-full p-4 bg-surface-container-low rounded-2xl outline-none focus:ring-2 focus:ring-primary font-body text-primary" />
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-2 ml-1">Duración (Min)</label>
                            <input @bind="nuevoServicio.DuracionMinutos" type="number" min="5" step="5"
                                   class="w-full p-4 bg-surface-container-low rounded-2xl outline-none focus:ring-2 focus:ring-primary font-body text-primary" />
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-2 ml-1">Precio ($)</label>
                            <input @bind="nuevoServicio.Precio" type="number" min="0" step="100"
                                   class="w-full p-4 bg-surface-container-low rounded-2xl outline-none focus:ring-2 focus:ring-primary font-body text-primary" />
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(mensajeErrorModal))
                {
                    <p class="text-red-500 text-xs mt-4 text-center">@mensajeErrorModal</p>
                }

                <div class="flex gap-3 mt-8">
                    <button @onclick="CerrarModalServicio" class="flex-1 py-4 bg-surface-container-low text-primary font-bold rounded-2xl hover:brightness-95 transition-all">Cancelar</button>
                    <button @onclick="GuardarServicio" disabled="@guardando"
                            class="flex-1 py-4 bg-primary text-white font-bold rounded-2xl hover:brightness-110 transition-all flex justify-center items-center gap-2">
                        @if (guardando)
                        {
                            <div class="animate-spin rounded-full h-4 w-4 border-b-2 border-white"></div>
                        }
                        else
                        {

                            <span>Guardar</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    }

</div>

@code {
    // --- ESTADO DE LA PÁGINA ---
    private List<CategoriaServicioReadDto> categorias = new();
    private bool cargando = true;
    private bool guardando = false;
    private string? mensajeError;
    private string? mensajeErrorModal;

    // --- ESTADO DE LOS MODALES ---
    private bool mostrarModalCategoria = false;
    private bool mostrarModalServicio = false;

    // --- MODELOS DE FORMULARIO ---
    private CategoriaServicioCreateDto nuevaCategoria = new();
    private ServicioCreateDto nuevoServicio = new() { DuracionMinutos = 30, Precio = 0 };

    /// <summary>
    /// Se ejecuta al cargar la página. Obtiene el catálogo completo desde la API.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        await CargarCatalogo();
    }

    private async Task CargarCatalogo()
    {
        try
        {
            cargando = true;
            mensajeError = null;
            categorias = await _servicioClient.GetCatalogo();
        }
        catch (Exception ex)
        {
            mensajeError = "No pudimos cargar tu catálogo. Por favor, intentá de nuevo.";
            Console.WriteLine($"Error GetCatalogo: {ex.Message}");
        }
        finally
        {
            cargando = false;
        }
    }

    // ==========================================
    // LÓGICA DE CATEGORÍAS
    // ==========================================
    // 🎯 NUEVA VARIABLE
    private Guid? categoriaEnEdicionId = null;

    // 🎯 ACTUALIZADO: Maneja la apertura para Crear o Editar
    private void AbrirModalCategoria(CategoriaServicioReadDto? catEditar = null)
    {
        if (catEditar == null)
        {
            categoriaEnEdicionId = null;
            nuevaCategoria = new CategoriaServicioCreateDto();
        }
        else
        {
            categoriaEnEdicionId = catEditar.Id;
            nuevaCategoria = new CategoriaServicioCreateDto { Nombre = catEditar.Nombre };
        }
        mostrarModalCategoria = true;
    }

    // 🎯 ACTUALIZADO: Guarda la nueva o actualiza la existente
    private async Task GuardarCategoria()
    {
        if (string.IsNullOrWhiteSpace(nuevaCategoria.Nombre)) return;

        try
        {
            guardando = true;

            if (categoriaEnEdicionId == null)
            {
                var catCreada = await _servicioClient.CreateCategoria(nuevaCategoria);
                if (catCreada != null)
                {
                    categorias.Add(catCreada);
                    CerrarModalCategoria();
                }
            }
            else
            {
                var exito = await _servicioClient.UpdateCategoria(categoriaEnEdicionId.Value, nuevaCategoria);
                if (exito)
                {
                    var catLocal = categorias.FirstOrDefault(c => c.Id == categoriaEnEdicionId.Value);
                    if (catLocal != null) catLocal.Nombre = nuevaCategoria.Nombre;
                    CerrarModalCategoria();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al guardar categoría: {ex.Message}");
        }
        finally
        {
            guardando = false;
        }
    }

    // 🎯 NUEVO: Lógica de eliminación con manejo de errores visual
    private async Task EliminarCategoria(Guid id)
    {
        try
        {
            var exito = await _servicioClient.DeleteCategoria(id);
            if (exito)
            {
                categorias.RemoveAll(c => c.Id == id);
                mensajeError = null; // Limpiamos errores previos
            }
        }
        catch (Exception ex)
        {
            // Atrapamos la excepción (ej: la trava de seguridad) y la mostramos en la alerta roja superior
            mensajeError = ex.Message;
        }
    }

    private void CerrarModalCategoria() => mostrarModalCategoria = false;

    // ==========================================
    // LÓGICA DE SERVICIOS
    // ==========================================
    private Guid? servicioEnEdicionId = null;
    private void AbrirModalServicio(Guid categoriaId)
    {
        nuevoServicio = new ServicioCreateDto
        {
            CategoriaId = categoriaId,
            DuracionMinutos = 30,
            Precio = 0
        };
        mensajeErrorModal = null;
        mostrarModalServicio = true;
    }


    private void AbrirModalServicio(Guid categoriaId, ServicioReadDto? servicioEditar = null)
    {
        if (servicioEditar == null)
        {
            // MODO CREAR NUEVO
            servicioEnEdicionId = null;
            nuevoServicio = new ServicioCreateDto
            {
                CategoriaId = categoriaId,
                DuracionMinutos = 30,
                Precio = 0
            };
        }
        else
        {
            // MODO EDITAR
            servicioEnEdicionId = servicioEditar.Id;
            nuevoServicio = new ServicioCreateDto
            {
                CategoriaId = categoriaId,
                Nombre = servicioEditar.Nombre,
                DuracionMinutos = servicioEditar.DuracionMinutos,
                Precio = servicioEditar.Precio
            };
        }

        mensajeErrorModal = null;
        mostrarModalServicio = true;
    }

    private void CerrarModalServicio() => mostrarModalServicio = false;

    private async Task GuardarServicio()
    {
        if (string.IsNullOrWhiteSpace(nuevoServicio.Nombre))
        {
            mensajeErrorModal = "El nombre es obligatorio.";
            return;
        }

        try
        {
            guardando = true;
            mensajeErrorModal = null;

            if (servicioEnEdicionId == null)
            {
                // MODO CREAR
                var servCreado = await _servicioClient.CreateServicio(nuevoServicio);
                if (servCreado != null)
                {
                    var categoriaPadre = categorias.FirstOrDefault(c => c.Id == servCreado.CategoriaId);
                    categoriaPadre?.Servicios.Add(servCreado);
                    CerrarModalServicio();
                }
            }
            else
            {
                // MODO ACTUALIZAR
                var exito = await _servicioClient.UpdateServicio(servicioEnEdicionId.Value, nuevoServicio);
                if (exito)
                {
                    // Actualizamos la UI localmente sin pegarle de nuevo a la base de datos
                    var categoriaPadre = categorias.FirstOrDefault(c => c.Id == nuevoServicio.CategoriaId);
                    var servicioLocal = categoriaPadre?.Servicios.FirstOrDefault(s => s.Id == servicioEnEdicionId.Value);

                    if (servicioLocal != null)
                    {
                        servicioLocal.Nombre = nuevoServicio.Nombre;
                        servicioLocal.DuracionMinutos = nuevoServicio.DuracionMinutos;
                        servicioLocal.Precio = nuevoServicio.Precio;
                    }
                    CerrarModalServicio();
                }
                else
                {
                    mensajeErrorModal = "No se pudo actualizar el servicio.";
                }
            }
        }
        catch (Exception ex)
        {
            mensajeErrorModal = "Ocurrió un error al guardar. Intentá nuevamente.";
            Console.WriteLine($"Error al guardar servicio: {ex.Message}");
        }
        finally
        {
            guardando = false;
        }
    }

    private async Task EliminarServicio(Guid categoriaId, Guid servicioId)
    {
        // En una V2 podrías agregar un modal de "Estás seguro?".
        // Por ahora lo borramos directo al hacer clic en el tacho.
        try
        {
            var exito = await _servicioClient.DeleteServicio(servicioId);
            if (exito)
            {
                // Lo removemos visualmente de la lista al instante
                var categoria = categorias.FirstOrDefault(c => c.Id == categoriaId);
                if (categoria != null)
                {
                    var servicio = categoria.Servicios.FirstOrDefault(s => s.Id == servicioId);
                    if (servicio != null)
                    {
                        categoria.Servicios.Remove(servicio);
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al eliminar servicio: {ex.Message}");
        }
    }

}