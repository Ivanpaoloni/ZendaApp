@page "/servicios"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Zenda.Core.DTOs
@using Zenda.Client.Components @* Asumiendo que guardaste ConfirmDialog acá *@

<div class="space-y-8 animate-in fade-in duration-500 pb-20 relative">

    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
            <h1 class="text-3xl font-bold text-primary tracking-tighter font-headline">Catálogo de Servicios</h1>
            <p class="text-on-surface-variant text-sm">Definí qué hacés, cuánto dura y qué valor tiene.</p>
        </div>
        <button @onclick="() => AbrirModalCategoria()"
                class="px-6 py-3 bg-primary text-white font-bold rounded-2xl shadow-lg shadow-primary/20 hover:scale-[1.02] active:scale-[0.98] transition-all flex items-center gap-2">
            <span class="material-symbols-outlined">add_circle</span>
            Nueva Categoría
        </button>
    </div>

    @if (cargando)
    {
        <div class="flex justify-center py-20">
            <div class="animate-spin rounded-full h-10 w-10 border-t-2 border-b-2 border-primary"></div>
        </div>
    }
    else if (!string.IsNullOrEmpty(mensajeError))
    {
        <div class="bg-red-50 text-red-600 p-4 rounded-2xl border border-red-100 flex items-center gap-3">
            <span class="material-symbols-outlined">error</span>
            <p class="font-bold text-sm">@mensajeError</p>
        </div>
    }
    else if (!categorias.Any())
    {
        <div class="bg-surface-container-low border border-dashed border-outline p-12 rounded-[2rem] text-center">
            <span class="material-symbols-outlined text-4xl text-on-surface-variant mb-4">inventory_2</span>
            <h3 class="font-headline font-bold text-lg text-primary">Tu catálogo está vacío</h3>
            <p class="text-sm text-on-surface-variant mb-6 mt-1">Comenzá creando tu primera categoría (ej: Barbería, Estética).</p>
            <button @onclick="() => AbrirModalCategoria()" class="text-primary font-bold hover:underline">Crear mi primera categoría</button>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            @foreach (var categoria in categorias)
            {
                <div class="bg-white rounded-[2rem] editorial-shadow overflow-hidden border border-surface-container-high h-fit">

                    <div class="p-6 bg-surface-container-low border-b border-surface-container-high flex justify-between items-center group/cat">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl bg-primary/10 text-primary flex items-center justify-center">
                                <span class="material-symbols-outlined">folder</span>
                            </div>
                            <h2 class="font-headline font-bold text-xl text-primary">@categoria.Nombre</h2>

                            <div class="flex gap-1 ml-2">
                                <button @onclick="() => AbrirModalCategoria(categoria)" class="p-1.5 text-on-surface-variant hover:text-primary hover:bg-primary/10 rounded-lg transition-all" title="Editar">
                                    <span class="material-symbols-outlined text-[18px]">edit</span>
                                </button>
                                @* 🎯 ACTUALIZADO: Llama a PrepararEliminarCategoria *@
                                <button @onclick="() => PrepararEliminarCategoria(categoria)" class="p-1.5 text-on-surface-variant hover:text-error hover:bg-error/10 rounded-lg transition-all" title="Eliminar">
                                    <span class="material-symbols-outlined text-[18px]">delete</span>
                                </button>
                            </div>
                        </div>
                        <button @onclick="() => AbrirModalServicio(categoria.Id)"
                                class="text-xs font-bold text-primary hover:bg-primary/10 px-3 py-2 rounded-xl transition-colors flex items-center gap-1">
                            <span class="material-symbols-outlined text-[16px]">add</span> Servicio
                        </button>
                    </div>

                    <div class="p-2">
                        @if (!categoria.Servicios.Any())
                        {
                            <p class="text-xs text-on-surface-variant text-center p-4 italic">No hay servicios en esta categoría.</p>
                        }

                        @foreach (var servicio in categoria.Servicios)
                        {
                            <div class="p-4 hover:bg-surface-container-low rounded-2xl transition-colors flex items-center justify-between group cursor-pointer border-b border-surface-container-high last:border-0">

                                <div>
                                    <h3 class="font-bold text-primary text-sm">@servicio.Nombre</h3>
                                    <p class="text-xs text-on-surface-variant flex items-center gap-1 mt-1">
                                        <span class="material-symbols-outlined text-[14px]">schedule</span> @servicio.DuracionMinutos min
                                    </p>
                                </div>

                                <div class="flex items-center gap-4">
                                    <span class="font-headline font-black text-primary">@servicio.Precio.ToString("C0")</span>

                                    <div class="flex gap-1 ml-4">
                                        <button @onclick="() => AbrirModalServicio(categoria.Id, servicio)"
                                                class="p-1.5 text-on-surface-variant hover:text-primary hover:bg-primary/10 rounded-lg transition-all" title="Editar">
                                            <span class="material-symbols-outlined text-[18px]">edit</span>
                                        </button>

                                        @* 🎯 ACTUALIZADO: Llama a PrepararEliminarServicio *@
                                        <button @onclick="() => PrepararEliminarServicio(categoria.Id, servicio)"
                                                class="p-1.5 text-on-surface-variant hover:text-error hover:bg-error/10 rounded-lg transition-all" title="Eliminar">
                                            <span class="material-symbols-outlined text-[18px]">delete</span>
                                        </button>
                                    </div>
                                </div>

                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }

    @* Modales de Creación/Edición *@
    @if (mostrarModalCategoria)
    {
        <div class="fixed inset-0 bg-black/40 backdrop-blur-sm z-50 flex items-center justify-center p-4 animate-in fade-in duration-200">
            <div class="bg-white rounded-[2rem] p-8 max-w-sm w-full editorial-shadow animate-in zoom-in-95 duration-300">
                <h3 class="font-headline font-bold text-xl text-primary mb-4">@(categoriaEnEdicionId == null ? "Nueva Categoría" : "Editar Categoría")</h3>

                <div class="space-y-4">
                    <div>
                        <label class="block text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-2 ml-1">Nombre</label>
                        <input @bind="nuevaCategoria.Nombre" placeholder="Ej: Barbería Clásica"
                               class="w-full p-4 bg-surface-container-low rounded-2xl outline-none focus:ring-2 focus:ring-primary font-body text-primary" />
                    </div>
                </div>

                <div class="flex gap-3 mt-8">
                    <button @onclick="CerrarModalCategoria" class="flex-1 py-4 bg-surface-container-low text-primary font-bold rounded-2xl hover:brightness-95 transition-all">Cancelar</button>
                    <button @onclick="GuardarCategoria" disabled="@guardando"
                            class="flex-1 py-4 bg-primary text-white font-bold rounded-2xl hover:brightness-110 transition-all flex justify-center items-center gap-2">
                        @if (guardando)
                        {
                            <div class="animate-spin rounded-full h-4 w-4 border-b-2 border-white"></div>
                        }
                        else
                        {
                            <span>Guardar</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    }

    @if (mostrarModalServicio)
    {
        <div class="fixed inset-0 bg-black/40 backdrop-blur-sm z-50 flex items-center justify-center p-4 animate-in fade-in duration-200">
            <div class="bg-white rounded-[2rem] p-8 max-w-md w-full editorial-shadow animate-in zoom-in-95 duration-300">
                <h3 class="font-headline font-bold text-xl text-primary mb-4">@(servicioEnEdicionId == null ? "Nuevo Servicio" : "Editar Servicio")</h3>

                <div class="space-y-4">
                    <div>
                        <label class="block text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-2 ml-1">Nombre del Servicio</label>
                        <input @bind="nuevoServicio.Nombre" placeholder="Ej: Corte + Barba"
                               class="w-full p-4 bg-surface-container-low rounded-2xl outline-none focus:ring-2 focus:ring-primary font-body text-primary" />
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-2 ml-1">Duración (Min)</label>
                            <input @bind="nuevoServicio.DuracionMinutos" type="number" min="5" step="5"
                                   class="w-full p-4 bg-surface-container-low rounded-2xl outline-none focus:ring-2 focus:ring-primary font-body text-primary" />
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-2 ml-1">Precio ($)</label>
                            <input @bind="nuevoServicio.Precio" type="number" min="0" step="100"
                                   class="w-full p-4 bg-surface-container-low rounded-2xl outline-none focus:ring-2 focus:ring-primary font-body text-primary" />
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(mensajeErrorModal))
                {
                    <p class="text-red-500 text-xs mt-4 text-center">@mensajeErrorModal</p>
                }

                <div class="flex gap-3 mt-8">
                    <button @onclick="CerrarModalServicio" class="flex-1 py-4 bg-surface-container-low text-primary font-bold rounded-2xl hover:brightness-95 transition-all">Cancelar</button>
                    <button @onclick="GuardarServicio" disabled="@guardando"
                            class="flex-1 py-4 bg-primary text-white font-bold rounded-2xl hover:brightness-110 transition-all flex justify-center items-center gap-2">
                        @if (guardando)
                        {
                            <div class="animate-spin rounded-full h-4 w-4 border-b-2 border-white"></div>
                        }
                        else
                        {
                            <span>Guardar</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    }


</div>
    <ConfirmDialog Visible="@mostrarConfirmacion"
                   Titulo="@tituloConfirmacion"
                   Mensaje="@mensajeConfirmacion"
                   OnRespuesta="ManejarRespuestaConfirmacion" />