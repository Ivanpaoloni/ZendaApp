@page "/prestadores/agenda"
@using Microsoft.AspNetCore.Authorization
@using Zenda.Core.DTOs
@attribute [Authorize]
@inject DisponibilidadClient AgendaService
@inject Zenda.Client.Services.AppState State
@inject NavigationManager Nav

<div class="max-w-2xl mx-auto space-y-6">
    <div class="text-center mb-8">
        <h1 class="text-3xl font-bold text-primary tracking-tighter">Horarios de @State.PrestadorEnEdicion?.Nombre</h1>
        <p class="text-on-surface-variant text-sm">Definí los bloques de tiempo para reservas online.</p>
    </div>

    <div class="bg-white rounded-[2.5rem] border border-surface-container-high editorial-shadow overflow-hidden">
        @foreach (var dia in dias)
        {
            <div class="flex items-center justify-between p-6 border-b border-surface-container last:border-0 hover:bg-secondary-container/10 transition-colors">
                <div class="flex items-center gap-4">
                    <div class="relative inline-flex items-center cursor-pointer">
                        <input type="checkbox" @bind="dia.Activo" class="sr-only peer">
                        <div class="w-11 h-6 bg-surface-container-highest peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                    </div>
                    <span class="font-bold text-primary w-24">@dia.Nombre</span>
                </div>

                @if (dia.Activo)
                {
                    <div class="flex items-center gap-2 animate-in fade-in zoom-in duration-200">
                        <input type="time" @bind="dia.Inicio" class="p-2 bg-surface-container-low rounded-lg text-xs font-bold outline-none border-0" />
                        <span class="text-[10px] font-black opacity-20">-</span>
                        <input type="time" @bind="dia.Fin" class="p-2 bg-surface-container-low rounded-lg text-xs font-bold outline-none border-0" />
                    </div>
                }
                else
                {
                    <span class="text-[10px] font-bold text-on-surface-variant/30 uppercase tracking-widest italic">Cerrado</span>
                }
            </div>
        }
    </div>

    <button @onclick="Guardar" class="w-full py-4 bg-primary text-white font-bold rounded-2xl shadow-xl shadow-primary/20 hover:scale-[1.01] active:scale-95 transition-all">
        Actualizar Agenda Semanal
    </button>
</div>

@code {
    private List<DiaVM> dias = new() {
        new(1, "Lunes"), new(2, "Martes"), new(3, "Miércoles"),
        new(4, "Jueves"), new(5, "Viernes"), new(6, "Sábado"), new(0, "Domingo")
    };

    protected override async Task OnInitializedAsync()
    {
        if (State.PrestadorEnEdicion == null) Nav.NavigateTo("prestadores");

        var actual = await AgendaService.GetByPrestador(State.PrestadorEnEdicion!.Id);
        foreach (var disp in actual)
        {
            var d = dias.FirstOrDefault(x => x.Num == disp.DiaSemana);
            if (d != null)
            {
                d.Activo = true;
                d.Inicio = DateTime.Today.Add(TimeOnly.Parse(disp.HoraInicio).ToTimeSpan());
                d.Fin = DateTime.Today.Add(TimeOnly.Parse(disp.HoraFin).ToTimeSpan());
            }
        }
    }

    private async Task Guardar()
    {
        var agenda = dias.Where(d => d.Activo).Select(d => new DisponibilidadCreateDto
        {
            PrestadorId = State.PrestadorEnEdicion!.Id,
            DiaSemana = d.Num,
            HoraInicio = TimeOnly.FromDateTime(d.Inicio),
            HoraFin = TimeOnly.FromDateTime(d.Fin)
        }).ToList();

        if (await AgendaService.Upsert(State.PrestadorEnEdicion!.Id, agenda)) Nav.NavigateTo("prestadores");
    }

    public class DiaVM(int num, string nombre)
    {
        public int Num = num; public string Nombre = nombre; public bool Activo;
        public DateTime Inicio = DateTime.Today.AddHours(9); public DateTime Fin = DateTime.Today.AddHours(18);
    }
}