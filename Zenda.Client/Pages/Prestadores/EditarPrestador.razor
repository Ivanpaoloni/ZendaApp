@page "/prestadores/editar/{Id:guid}"
@using Microsoft.AspNetCore.Authorization
@using Zenda.Client.Services
@using Zenda.Core.DTOs
@using System.Net.Http.Json
@attribute [Authorize]
@inject PrestadorClient PrestadorService
@inject SedeClient SedeService
@inject ServicioClient ServicioService
@inject NavigationManager Nav
@inject HttpClient Http
@inject IJSRuntime JS

<div class="max-w-2xl mx-auto space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-500 pb-20">
    <button @onclick='() => Nav.NavigateTo("prestadores")' class="text-primary font-bold text-xs uppercase tracking-widest flex items-center gap-2 opacity-50 hover:opacity-100 transition-opacity">
        <span class="material-symbols-outlined text-sm">arrow_back</span> Volver al equipo
    </button>

    <div class="bg-white p-10 rounded-[3rem] editorial-shadow border border-surface-container-high">
        <h2 class="text-3xl font-bold text-primary tracking-tighter mb-8 text-center">Editar Profesional</h2>

        @if (model == null)
        {
            <div class="flex justify-center py-10">
                <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
            </div>
        }
        else
        {
            <EditForm Model="model" OnValidSubmit="HandleUpdate" class="space-y-6">
                <DataAnnotationsValidator />

                <div class="flex flex-col gap-2">
                    <label class="text-[10px] font-black text-primary/50 tracking-widest uppercase px-1">Nombre</label>
                    <InputText @bind-Value="model.Nombre" class="input-zenda" />
                </div>

                <div class="flex flex-col gap-2">
                    <label class="text-[10px] font-black text-primary/50 tracking-widest uppercase px-1">Sede Principal</label>
                    <InputSelect @bind-Value="model.SedeId" class="input-zenda appearance-none">
                        @foreach (var s in sedes)
                        {
                            <option value="@s.Id">@s.Nombre</option>
                        }
                    </InputSelect>
                </div>

                <hr class="border-surface-container-high my-6" />

                <div>
                    <label class="text-[10px] font-black text-primary/50 tracking-widest uppercase px-1 mb-4 block">Servicios que realiza</label>

                    @if (catalogo == null)
                    {
                        <p class="text-sm text-on-surface-variant">Cargando catálogo...</p>
                    }
                    else
                    {
                        <div class="space-y-4 max-h-60 overflow-y-auto pr-2 custom-scrollbar">
                            @foreach (var categoria in catalogo)
                            {
                                <div class="bg-surface-container-low rounded-2xl p-4">
                                    <h4 class="font-bold text-primary mb-3">@categoria.Nombre</h4>
                                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                                        @foreach (var servicio in categoria.Servicios)
                                        {
                                            <label class="flex items-center gap-3 cursor-pointer group">
                                                <input type="checkbox"
                                                       checked="@model.ServiciosIds.Contains(servicio.Id)"
                                                       @onchange="@(e => ToggleServicio(servicio.Id, e.Value))"
                                                       class="w-5 h-5 rounded-lg border-2 border-primary/30 text-primary focus:ring-primary focus:ring-offset-0 bg-white transition-all cursor-pointer" />
                                                <span class="text-sm font-body text-on-surface group-hover:text-primary transition-colors">@servicio.Nombre</span>
                                            </label>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <hr class="border-surface-container-high my-6" />

                <!-- SECCIÓN GOOGLE CALENDAR -->
                <div>
                    <label class="text-[10px] font-black text-primary/50 tracking-widest uppercase px-1 mb-4 block">Google Calendar</label>

                    @if (tieneCalendarioVinculado)
                    {
                        <div class="bg-[#f1f5f0] border border-[#166534]/30 rounded-2xl p-4 flex items-center justify-between gap-3">
                            <div class="flex items-center gap-3">
                                <span class="material-symbols-outlined text-[#166534] fs-4">check_circle</span>
                                <div>
                                    <strong class="text-primary block text-sm">Sincronización Activa</strong>
                                    <p class="mb-0 text-xs text-on-surface-variant">Los turnos se sincronizan automáticamente.</p>
                                </div>
                            </div>
                            <button type="button" class="text-xs font-bold text-red-600 hover:text-red-800 transition-colors uppercase tracking-widest px-3 py-2 rounded-xl hover:bg-red-50" disabled="@procesandoCalendario" @onclick="DesvincularCalendario">
                                Desvincular
                            </button>
                        </div>
                    }
                    else
                    {
                        <p class="text-xs text-on-surface-variant mb-4 px-1">Evita choques de horarios sincronizando la agenda de Zendy con el Google Calendar de este profesional.</p>

                        <div class="flex flex-col sm:flex-row gap-3">
                            <button type="button" class="flex-1 py-3 px-4 bg-primary text-white text-sm font-bold rounded-xl shadow-md shadow-primary/20 hover:scale-[1.02] active:scale-95 transition-all flex justify-center items-center gap-2" disabled="@procesandoCalendario" @onclick="VincularDirecto">
                                <span class="material-symbols-outlined text-sm">calendar_month</span> Vincular mi cuenta
                            </button>

                            <button type="button" class="flex-1 py-3 px-4 bg-surface-container-low text-primary text-sm font-bold rounded-xl hover:bg-surface-container-high transition-all flex justify-center items-center gap-2 border border-primary/10" disabled="@procesandoCalendario" @onclick="GenerarLinkDelegado">
                                <span class="material-symbols-outlined text-sm">link</span> Generar enlace
                            </button>
                        </div>

                        @if (!string.IsNullOrEmpty(linkGenerado))
                        {
                            <div class="mt-4 p-4 bg-surface-container-low border border-primary/10 rounded-2xl animate-in fade-in slide-in-from-top-2">
                                <label class="text-[10px] font-black text-primary/50 tracking-widest uppercase px-1 mb-2 block">Enlace de integración (Expira 24hs)</label>
                                <div class="flex gap-2">
                                    <input type="text" class="input-zenda text-sm py-2 px-3 flex-1" readonly value="@linkGenerado" />
                                    <button class="bg-primary text-white px-4 py-2 rounded-xl font-bold hover:scale-[1.02] transition-all flex items-center gap-2" type="button" @onclick="CopiarAlPortapapeles">
                                        <span class="material-symbols-outlined text-sm">content_copy</span> Copiar
                                    </button>
                                </div>
                            </div>
                        }
                    }
                </div>

                <hr class="border-surface-container-high my-6" />

                <button type="submit" disabled="@guardando" class="w-full py-4 bg-primary text-white font-bold rounded-2xl shadow-xl shadow-primary/20 hover:scale-[1.01] active:scale-95 transition-all flex justify-center items-center gap-2">
                    @if (guardando)
                    {
                        <div class="animate-spin rounded-full h-5 w-5 border-b-2 border-white"></div>
                    }
                    else
                    {
                        <span>Guardar Cambios</span>
                    }
                </button>
            </EditForm>
        }
    </div>
</div>

<style>
    .input-zenda {
        width: 100%;
        padding: 1rem 1.25rem;
        border-radius: 1.25rem;
        background-color: #f1f5f0;
        border: 2px solid transparent;
        outline: none;
        transition: all 0.2s;
    }

        .input-zenda:focus {
            border-color: #166534;
            background-color: white;
        }

    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }

    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
        background-color: #d1d5db;
        border-radius: 10px;
    }
</style>

@code {
    [Parameter] public Guid Id { get; set; }
    private PrestadorUpdateDto? model;
    private List<SedeReadDto> sedes = new();
    private List<CategoriaServicioReadDto>? catalogo;

    // Estado General
    private bool guardando = false;

    // Estado Google Calendar
    private bool tieneCalendarioVinculado = false;
    private bool procesandoCalendario = false;
    private string? linkGenerado;

    protected override async Task OnInitializedAsync()
    {
        var taskSedes = SedeService.GetAll();
        var taskCatalogo = ServicioService.GetCatalogo();
        var taskPrestador = PrestadorService.GetById(Id);

        await Task.WhenAll(taskSedes, taskCatalogo, taskPrestador);

        sedes = taskSedes.Result ?? new();
        catalogo = taskCatalogo.Result ?? new();
        var p = taskPrestador.Result;

        if (p != null)
        {
            // Asignamos el estado de vinculación (Asegúrate de agregar TieneCalendarioVinculado en el DTO de retorno de tu API)
            // tieneCalendarioVinculado = p.TieneCalendarioVinculado;

            model = new PrestadorUpdateDto
            {
                Id = p.Id,
                Nombre = p.Nombre,
                SedeId = p.SedeId,
                DuracionTurnoMinutos = p.DuracionTurnoMinutos,
                ServiciosIds = p.Servicios?.Select(s => s.Id).ToList() ?? new()
            };
        }
    }

    private void ToggleServicio(Guid servicioId, object? checkedValue)
    {
        if (model == null) return;

        bool isChecked = (bool)(checkedValue ?? false);

        if (isChecked && !model.ServiciosIds.Contains(servicioId))
        {
            model.ServiciosIds.Add(servicioId);
        }
        else if (!isChecked && model.ServiciosIds.Contains(servicioId))
        {
            model.ServiciosIds.Remove(servicioId);
        }
    }

    private async Task HandleUpdate()
    {
        if (model == null) return;

        guardando = true;
        var res = await PrestadorService.Update(Id, model);
        guardando = false;

        if (res.Success) Nav.NavigateTo("prestadores");
    }

    // --- LÓGICA DE GOOGLE CALENDAR ---

    private async Task VincularDirecto()
    {
        procesandoCalendario = true;
        try
        {
            var response = await Http.GetFromJsonAsync<UrlResponse>($"api/calendar/conectar-directo/{Id}");
            if (response != null && !string.IsNullOrEmpty(response.Url))
            {
                Nav.NavigateTo(response.Url, forceLoad: true);
            }
        }
        finally
        {
            procesandoCalendario = false;
        }
    }

    private async Task GenerarLinkDelegado()
    {
        procesandoCalendario = true;
        try
        {
            var response = await Http.GetFromJsonAsync<UrlResponse>($"api/calendar/generar-link/{Id}");
            if (response != null && !string.IsNullOrEmpty(response.Url))
            {
                linkGenerado = response.Url;
            }
        }
        finally
        {
            procesandoCalendario = false;
        }
    }

    private async Task DesvincularCalendario()
    {
        procesandoCalendario = true;
        try
        {
            // var res = await Http.DeleteAsync($"api/calendar/desvincular/{Id}");
            // if (res.IsSuccessStatusCode) tieneCalendarioVinculado = false;
        }
        finally
        {
            procesandoCalendario = false;
        }
    }

    private async Task CopiarAlPortapapeles()
    {
        if (!string.IsNullOrEmpty(linkGenerado))
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", linkGenerado);
            // Aquí puedes agregar un toast o alerta indicando que se copió correctamente
        }
    }

    // Clase auxiliar para mapear la respuesta de la API
    public class UrlResponse
    {
        public string Url { get; set; } = string.Empty;
    }
}