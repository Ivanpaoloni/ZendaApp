@page "/prestadores"
@using Zenda.Core.DTOs
@inject NavigationManager Nav
@inject PrestadorClient PrestadorService
@inject IJSRuntime JS
@inject Zenda.Client.Services.AppState State

<div class="mb-12 animate-in fade-in slide-in-from-bottom-4 duration-700">
    <span class="inline-block px-4 py-1.5 mb-4 bg-secondary-container text-on-secondary-container rounded-full text-[10px] font-bold tracking-widest uppercase font-body">
        EQUIPO PROFESIONAL
    </span>
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <h1 class="text-4xl md:text-5xl font-headline font-extrabold text-primary tracking-tight">
            Gestionar Prestadores
        </h1>

        <button @onclick='() => Nav.NavigateTo("nuevo-prestador")'
                class="flex items-center justify-center gap-2 bg-primary text-on-primary px-6 py-4 rounded-2xl font-headline font-bold text-sm hover:scale-[1.02] active:scale-95 transition-all editorial-shadow w-full md:w-auto">
            Nuevo Prestador
            <span class="material-symbols-outlined text-sm">add</span>
        </button>
    </div>
    <p class="text-on-surface-variant mt-2 font-body">Administra los profesionales y sus tiempos de atención.</p>
</div>

@if (prestadores == null)
{
    <div class="flex flex-col items-center justify-center py-20">
        <div class="animate-spin rounded-full h-10 w-10 border-t-2 border-b-2 border-primary"></div>
        <p class="mt-4 text-primary font-medium animate-pulse">Sincronizando con Zenda...</p>
    </div>
}
else
{
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        @foreach (var p in prestadores)
        {
            <div class="bg-white p-8 rounded-4xl editorial-shadow border border-transparent hover:border-outline-variant transition-all duration-300 group flex flex-col h-full">
                <div class="flex justify-between items-start mb-8">
                    <div class="w-14 h-14 rounded-2xl bg-surface-container-low flex items-center justify-center group-hover:bg-secondary-container transition-colors duration-300">
                        <span class="material-symbols-outlined text-primary text-3xl">person</span>
                    </div>
                    <span class="bg-surface-container-high text-on-surface px-3 py-1 rounded-lg text-[11px] font-bold font-body tracking-tight">
                        @p.DuracionTurnoMinutos min
                    </span>
                </div>

                <div class="flex-grow">
                    <h3 class="text-2xl font-headline font-bold text-primary mb-1">@p.Nombre</h3>
                    <p class="text-on-surface-variant font-body text-sm flex items-center gap-2">
                        <span class="material-symbols-outlined text-xs">fingerprint</span>
                        ID: @p.Id.ToString()?[..8]
                    </p>

                    @* Botón de Copiar Link movido aquí para mejor UI *@
                    <button @onclick="() => CopiarLink(p)" class="mt-4 text-primary text-[10px] font-bold uppercase tracking-widest flex items-center gap-2 hover:opacity-70 transition-opacity">
                        <span class="material-symbols-outlined text-sm">link</span>
                        Copiar link de reserva
                    </button>
                </div>

                <div class="mt-8 pt-6 border-t border-surface-container-high space-y-3">
                    <button @onclick="() => IrAAgenda(p)"
                            class="w-full py-4 bg-primary text-on-primary rounded-xl font-headline font-bold text-sm scale-100 hover:scale-[1.02] active:scale-95 transition-all editorial-shadow flex items-center justify-center gap-2">
                        Configurar Disponibilidad
                        <span class="material-symbols-outlined text-sm">calendar_month</span>
                    </button>

                    <button @onclick="() => VerTurnos(p)"
                            class="w-full py-3 bg-surface-container-low text-primary rounded-xl font-headline font-bold text-xs hover:bg-secondary-container transition-colors flex items-center justify-center gap-2">
                        Ver Turnos Ocupados
                        <span class="material-symbols-outlined text-sm">event_available</span>
                    </button>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<PrestadorReadDto>? prestadores;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            prestadores = await PrestadorService.GetAll();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando prestadores: {ex.Message}");
            prestadores = new List<PrestadorReadDto>();
        }
    }

    // Nueva función para manejar la navegación limpia
    private void IrAAgenda(PrestadorReadDto p)
    {
        Console.WriteLine($"Intentando ir a la agenda de: {p.Nombre}"); // Esto DEBE aparecer en F12

        try
        {
            State.PrestadorEnEdicion = p;
            Nav.NavigateTo("prestadores/agenda"); // Sin la barra inicial a veces ayuda en Blazor WebAssembly
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al navegar: {ex.Message}");
        }
    }

    private void VerTurnos(PrestadorReadDto p)
    {
        State.PrestadorEnEdicion = p;
        Nav.NavigateTo("prestadores/agenda-turnos");
    }

    private async Task CopiarLink(PrestadorReadDto p)
    {
        try
        {
            // Generamos la URL pública
            var url = $"{Nav.BaseUri}book/{p.Id}";
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", url);

            // Opcional: Podrías usar un Toast aquí para avisar que se copió
            Console.WriteLine($"Link copiado: {url}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al copiar: {ex.Message}");
        }
    }
}