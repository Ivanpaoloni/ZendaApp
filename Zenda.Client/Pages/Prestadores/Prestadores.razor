@page "/prestadores"
@using Microsoft.AspNetCore.Authorization
@using Zenda.Core.DTOs
@using Zenda.Client.Components
@attribute [Authorize]

<div class="space-y-8 animate-in fade-in duration-500 pb-20 relative">

    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
            <h1 class="text-3xl font-bold text-primary tracking-tighter font-headline">Equipo</h1>
            <p class="text-on-surface-variant text-sm">Gestioná quiénes atienden en tu negocio.</p>
        </div>

        @* --- UN SOLO BOTÓN DINÁMICO --- *@
        <button @onclick="ManejarClickNuevo"
                class="px-6 py-3 @(puedeAgregarMas ? "bg-primary text-white shadow-primary/20 hover:scale-[1.02] active:scale-[0.98]" : "bg-surface-container-high text-on-surface-variant/80 border border-surface-container-highest hover:bg-surface-container-highest hover:text-primary") font-bold rounded-2xl shadow-lg transition-all flex items-center gap-2 cursor-pointer">
            <span class="material-symbols-outlined">@(puedeAgregarMas ? "add_circle" : "lock")</span>
            @(puedeAgregarMas ? "Nuevo Profesional" : "Límite alcanzado")
        </button>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="p-4 bg-error/10 text-error border border-error/20 rounded-2xl text-sm font-bold flex items-center justify-between animate-in zoom-in duration-300">
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined">warning</span>
                <span>@errorMessage</span>
            </div>
            <button @onclick="LimpiarError" class="hover:opacity-70">
                <span class="material-symbols-outlined text-sm">close</span>
            </button>
        </div>
    }

    @if (prestadores == null)
    {
        <div class="py-20 text-center animate-pulse text-primary font-bold">Sincronizando equipo...</div>
    }
    else if (!prestadores.Any())
    {
        <div class="col-span-full py-16 text-center bg-surface-container-low rounded-[3rem] border-2 border-dashed border-surface-container-high animate-in fade-in zoom-in duration-500">
            <div class="w-20 h-20 bg-white rounded-3xl flex items-center justify-center mx-auto mb-6 shadow-sm">
                <span class="material-symbols-outlined text-5xl text-primary/30">person_add</span>
            </div>
            <h3 class="text-xl font-headline font-bold text-primary mb-2">Tu equipo está vacío</h3>
            <p class="text-on-surface-variant font-body text-sm max-w-xs mx-auto mb-8">
                Agregá a los profesionales que brindan servicios para empezar a gestionar la agenda.
            </p>

            <button @onclick="ManejarClickNuevo"
                    class="px-8 py-4 @(puedeAgregarMas ? "bg-primary text-white shadow-primary/20 hover:scale-105" : "bg-surface-container-high text-on-surface-variant/80 hover:bg-surface-container-highest hover:text-primary") font-bold rounded-2xl shadow-xl transition-all inline-flex items-center gap-2 cursor-pointer">
                <span class="material-symbols-outlined text-sm">@(puedeAgregarMas ? "add" : "lock")</span>
                @(puedeAgregarMas ? "Sumar mi primer profesional" : "Límite de plan alcanzado")
            </button>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var p in prestadores)
            {
                <div class="bg-white p-6 rounded-[2.5rem] border border-surface-container-high editorial-shadow group hover:border-primary/20 transition-all relative overflow-hidden flex flex-col h-full">

                    <div class="flex justify-between items-start mb-4">
                        @* AVATAR (Con soporte para foto en el futuro) *@
                        <div class="w-14 h-14 rounded-2xl bg-secondary-container/30 text-primary flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-all duration-500 overflow-hidden shrink-0">
                            @* Si tuvieras p.FotoUrl harías un <img> acá. Por ahora dejamos tu ícono: *@
                            <span class="material-symbols-outlined text-3xl">person</span>
                        </div>

                        @* BOTONES DE ACCIÓN *@
                        <div class="flex items-center gap-1">
                            <button @onclick='() => Nav.NavigateTo($"/prestadores/editar/{p.Id}")'
                                    class="p-1.5 text-on-surface-variant hover:text-primary hover:bg-primary/10 rounded-lg transition-all" title="Editar">
                                <span class="material-symbols-outlined text-[18px]">edit</span>
                            </button>
                            <button @onclick="() => PrepararEliminar(p)"
                                    class="p-1.5 text-on-surface-variant hover:text-error hover:bg-error/10 rounded-lg transition-all" title="Eliminar">
                                <span class="material-symbols-outlined text-[18px]">delete</span>
                            </button>
                        </div>
                    </div>

                    @* INFO PRINCIPAL *@
                    <div class="mb-4 flex-1">
                        <h3 class="text-xl font-bold text-primary leading-tight">@p.Nombre</h3>

                        @if (p.Servicios != null && p.Servicios.Any())
                        {
                            @* string.Join une todos los nombres con una coma y un espacio *@
                            <p class="text-sm text-on-surface-variant font-medium mt-1 line-clamp-2" title="@string.Join(", ", p.Servicios.Select(s => s.Nombre))">
                                @string.Join(", ", p.Servicios.Select(s => s.Nombre))
                            </p>
                        }
                        else
                        {
                            <p class="text-sm text-on-surface-variant/50 italic mt-1">Sin servicios asignados</p>
                        }

                        <div class="mt-4 space-y-2">
                            @* EJEMPLO: Sede (Badge) *@
                            @if (!string.IsNullOrEmpty(p.SedeNombre))
                            {
                                <div class="inline-flex items-center gap-1 px-2.5 py-1 rounded-md bg-surface-container-low border border-surface-container-high text-xs font-bold text-on-surface-variant">
                                    <span class="material-symbols-outlined text-[14px]">location_on</span>
                                    @p.SedeNombre
                                </div>
                            }

                        </div>
                    </div>

                    @* BOTÓN CONFIGURAR AGENDA (Empujado hacia abajo con mt-auto gracias al flex-col del padre) *@
                    <div class="mt-auto pt-2">
                        <button @onclick="() => IrAAgenda(p)" class="w-full py-3 bg-primary/5 text-primary rounded-xl font-bold text-xs hover:bg-primary hover:text-white transition-all flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined text-sm">calendar_month</span> Configurar Agenda
                        </button>
                    </div>

                </div>
            }
        </div>
    }
</div>

<UpgradeModal Visible="mostrarModalUpgrade"
              VisibleChanged="(val) => mostrarModalUpgrade = val"
              Titulo="¡Hacé crecer tu equipo!"
              Icono="group_add">

    <p class="mb-6">Llegaste al límite de personal de tu plan <strong>@State.CurrentNegocio?.PlanNombre</strong>. Subí de nivel para sumar más profesionales y potenciar tus reservas.</p>

    <button @onclick="IrAFacturacion" class="w-full py-4 bg-primary text-white rounded-2xl font-bold hover:brightness-110 transition-all flex justify-center items-center gap-2">
        <span class="material-symbols-outlined">arrow_forward</span>
        Ir a ver Planes
    </button>

</UpgradeModal>

<ConfirmDialog Visible="@mostrarConfirmacion"
               Titulo="@tituloConfirmacion"
               Mensaje="@mensajeConfirmacion"
               OnRespuesta="ManejarRespuestaConfirmacion" />