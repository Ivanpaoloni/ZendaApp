@page "/configuracion/plan"
@using Zenda.Client.Services
@inject AppState State
@inject NavigationManager Nav
@inject HttpClient Http
@inject NegocioClient NegocioClient

<div class="max-w-2xl mx-auto space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-500">

    @* Cabecera *@
    <div>
        <h1 class="text-3xl font-bold text-primary tracking-tighter font-headline">Mi Suscripción</h1>
        <p class="text-on-surface-variant text-sm">Gestioná los límites y el nivel de tu cuenta.</p>
    </div>

    @if (State.CurrentNegocio != null)
    {
        @* Card de Plan Actual *@
        <div class="bg-white p-8 rounded-[2.5rem] border border-surface-container-high editorial-shadow">
            <div class="flex justify-between items-start mb-8">
                <div>
                    <span class="px-3 py-1 bg-primary/10 text-primary text-xs font-bold rounded-full uppercase tracking-widest">
                        Plan @State.CurrentNegocio.PlanNombre
                    </span>
                    <h2 class="text-4xl font-black text-primary mt-4 font-headline tracking-tighter">
                        @(State.CurrentNegocio.PlanNombre == "Single" ? "Gratis" : "$15.000 / mes")
                    </h2>
                </div>
                <div class="w-16 h-16 bg-surface-container-low rounded-3xl flex items-center justify-center">
                    <span class="material-symbols-outlined text-3xl text-primary">verified_user</span>
                </div>
            </div>

            @* Progress Bars de Límites *@
            <div class="space-y-6">
                @* Profesionales *@
                <div class="space-y-2">
                    <div class="flex justify-between text-sm font-bold">
                        <span class="text-on-surface-variant">Profesionales</span>
                        <span class="text-primary">Límite: @State.CurrentNegocio.MaxProfesionales</span>
                    </div>
                    <div class="h-3 bg-surface-container-high rounded-full overflow-hidden">
                        <div class="bg-primary h-full transition-all duration-1000"
                             style="width: 100%"></div> @* Aquí luego calcularemos el % real *@
                    </div>
                </div>

                @* Sedes *@
                <div class="space-y-2">
                    <div class="flex justify-between text-sm font-bold">
                        <span class="text-on-surface-variant">Sedes / Sucursales</span>
                        <span class="text-primary">Límite: @State.CurrentNegocio.MaxSedes</span>
                    </div>
                    <div class="h-3 bg-surface-container-high rounded-full overflow-hidden">
                        <div class="bg-primary h-full transition-all duration-1000"
                             style="width: 100%"></div>
                    </div>
                </div>
            </div>
        </div>

        @* Sección de Upsell *@
        <div class="bg-secondary-container/30 p-8 rounded-[2.5rem] border border-secondary-container/50 flex flex-col md:flex-row items-center gap-6">
            <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center shadow-sm shrink-0">
                <span class="material-symbols-outlined text-primary text-3xl">rocket_launch</span>
            </div>
            <div class="flex-1">
                <h3 class="font-bold text-primary text-lg">¿Necesitás más potencia?</h3>
                <p class="text-on-surface-variant text-sm">Pasate al plan <strong>Business</strong> para automatizar recordatorios por WhatsApp y sumar hasta 5 profesionales.</p>
            </div>
            @* CORRECCIÓN AQUÍ: Se agregaron comillas al Guid y se envolvió la función en @(...) *@
            <button class="btn btn-primary" @onclick="@(() => IrAPagar(Guid.Parse("33333333-3333-3333-3333-333333333333"), "Pro", 15000))">
                Contratar Plan Pro
            </button>
        </div>
    }
</div>

@code {
    private async Task IrAPagar(Guid planId, string nombrePlan, decimal precio)
    {
        // Llamamos al método de nuestro Client (este SÍ manda tu sesión/token)
        var urlCheckout = await NegocioClient.GenerarLinkPagoAsync(planId, nombrePlan, precio);

        if (!string.IsNullOrEmpty(urlCheckout))
        {
            // Redirigimos al usuario a Mercado Pago
            Nav.NavigateTo(urlCheckout);
        }
        else
        {
            // TODO: Mostrar un toast de error (por ejemplo, con un servicio de notificaciones)
            Console.WriteLine("Error: La API rebotó la petición.");
        }
    }

    private class CheckoutResponse
    {
        public string? UrlCheckout { get; set; }
    }
}