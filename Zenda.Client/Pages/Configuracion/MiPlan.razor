@page "/configuracion/plan"
@using Zenda.Client.Services
@using Zenda.Core.DTOs
@inject AppState State
@inject NavigationManager Nav
@inject HttpClient Http
@inject NegocioClient NegocioClient

<div class="max-w-2xl mx-auto space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-500 mt-8">

    @* 1. ALERTA DE PAGO EXITOSO (Solo visible si vuelve de MercadoPago) *@
    @if (Status == "approved")
    {
        <div class="bg-green-50 border-2 border-green-500 rounded-3xl p-6 text-center shadow-lg animate-in zoom-in-95">
            <div class="w-12 h-12 bg-green-500 text-white rounded-full flex items-center justify-center mx-auto mb-3 shadow-md">
                <span class="material-symbols-outlined text-3xl">check</span>
            </div>
            <h2 class="text-xl font-headline font-black text-green-700 mb-1">¡Pago Confirmado!</h2>
            <p class="text-green-800 text-sm font-medium">Tu suscripción se actualizó correctamente. Ya podés disfrutar de los beneficios.</p>
            @if (!string.IsNullOrEmpty(PaymentId))
            {
                <p class="text-[10px] text-green-600 mt-3 uppercase tracking-widest font-bold">Ref: #@PaymentId</p>
            }
        </div>
    }

    @* 2. CABECERA *@
    <div>
        <h1 class="text-3xl font-bold text-primary tracking-tighter font-headline">Mi Suscripción</h1>
        <p class="text-on-surface-variant text-sm">Gestioná los límites y el nivel de tu cuenta.</p>
    </div>

    @if (State.CurrentNegocio != null)
    {
        @* 3. CARD DE PLAN ACTUAL *@
        <div class="bg-white p-8 rounded-[2.5rem] border-[3px] border-primary shadow-xl ring-4 ring-primary/5">
            <div class="flex justify-between items-start mb-8 relative">

                @* Cartelito flotante *@
                <div class="absolute -top-12 left-0 bg-primary text-white text-[10px] font-black uppercase tracking-widest px-4 py-1.5 rounded-full shadow-md">
                    Tu Plan Actual
                </div>

                <div>
                    <span class="px-3 py-1 bg-primary/10 text-primary text-xs font-bold rounded-full uppercase tracking-widest">
                        Plan @State.CurrentNegocio.PlanNombre
                    </span>
                    <h2 class="text-4xl font-black text-primary mt-4 font-headline tracking-tighter">
                        @(State.CurrentNegocio.PlanNombre == "Single" ? "Gratis" :
                                            State.CurrentNegocio.PlanNombre == "Pro" ? "$15.000 / mes" : "$25.000 / mes")
                </h2>
            </div>
            <div class="w-16 h-16 bg-surface-container-low rounded-3xl flex items-center justify-center shadow-inner">
                <span class="material-symbols-outlined text-3xl text-primary">verified_user</span>
            </div>
        </div>

            @* Progress Bars de Límites *@
            <div class="space-y-6">
                @* Profesionales *@
                <div class="space-y-2">
                    <div class="flex justify-between text-sm font-bold">
                        <span class="text-on-surface-variant">Profesionales</span>
                        <span class="text-primary">Límite: @State.CurrentNegocio.MaxProfesionales</span>
                    </div>
                    <div class="h-3 bg-surface-container-high rounded-full overflow-hidden">
                        <div class="bg-primary h-full transition-all duration-1000" style="width: 100%"></div>
                    </div>
                </div>

                @* Sedes *@
                <div class="space-y-2">
                    <div class="flex justify-between text-sm font-bold">
                        <span class="text-on-surface-variant">Sedes / Sucursales</span>
                        <span class="text-primary">Límite: @State.CurrentNegocio.MaxSedes</span>
                    </div>
                    <div class="h-3 bg-surface-container-high rounded-full overflow-hidden">
                        <div class="bg-primary h-full transition-all duration-1000" style="width: 100%"></div>
                    </div>
                </div>
            </div>
        </div>

        @* 4. SECCIÓN DE UPSELL DINÁMICA *@
        @if (State.CurrentNegocio.PlanNombre == "Single")
        {
            <div class="bg-blue-50 border border-blue-200 p-8 rounded-[2.5rem] flex flex-col md:flex-row items-center gap-6 shadow-sm">
                <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center shadow-sm shrink-0">
                    <span class="material-symbols-outlined text-blue-500 text-3xl">rocket_launch</span>
                </div>
                <div class="flex-1 text-center md:text-left">
                    <h3 class="font-bold text-primary text-lg">¿Necesitás más potencia?</h3>
                    <p class="text-on-surface-variant text-sm">Pasate al plan <strong>Pro</strong> para sumar hasta <strong>5 profesionales</strong> y abrir una <strong>2da sede</strong>.</p>
                </div>
                @* 🔥 CAMBIO: Ahora llama a IrAFacturacion *@
                <button class="bg-primary text-white font-bold py-3 px-6 rounded-xl hover:brightness-110 active:scale-95 transition-all shrink-0 shadow-md" 
                        @onclick="IrAFacturacion">
                    Mejorar a Pro
                </button>
            </div>
        }
        else if (State.CurrentNegocio.PlanNombre == "Pro")
        {
            <div class="bg-orange-50 border border-orange-200 p-8 rounded-[2.5rem] flex flex-col md:flex-row items-center gap-6 shadow-sm">
                <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center shadow-sm shrink-0">
                    <span class="material-symbols-outlined text-orange-500 text-3xl">diamond</span>
                </div>
                <div class="flex-1 text-center md:text-left">
                    <h3 class="font-bold text-primary text-lg">Escalá al máximo nivel</h3>
                    <p class="text-on-surface-variant text-sm">Pasate al plan <strong>Business</strong> para automatizar <strong>recordatorios por WhatsApp</strong>, sumar hasta <strong>25 profesionales</strong> y <strong>5 sedes</strong>.</p>
                </div>
                @* 🔥 CAMBIO: Ahora llama a IrAFacturacion *@
                <button class="bg-orange-500 text-white font-bold py-3 px-6 rounded-xl hover:bg-orange-600 active:scale-95 transition-all shrink-0 shadow-md" 
                        @onclick="IrAFacturacion">
                    Mejorar a Business
                </button>
            </div>
        }
        else
        {
            <div class="bg-amber-50 border border-amber-200 p-8 rounded-[2.5rem] flex flex-col md:flex-row items-center gap-6 shadow-sm">
                <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center shadow-sm shrink-0">
                    <span class="material-symbols-outlined text-amber-500 text-3xl">workspace_premium</span>
                </div>
                <div class="flex-1 text-center md:text-left">
                    <h3 class="font-bold text-primary text-lg">¡Tenés el plan más completo!</h3>
                    <p class="text-on-surface-variant text-sm">Estás usando el plan <strong>Business</strong> con todas las características premium desbloqueadas.</p>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter][SupplyParameterFromQuery(Name = "status")] public string? Status { get; set; }
    [Parameter][SupplyParameterFromQuery(Name = "payment_id")] public string? PaymentId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (State.CurrentNegocio == null)
        {
            await State.LoadCurrentNegocioAsync();
        }

        if (Status == "approved")
        {
            await State.LoadCurrentNegocioAsync();
        }
    }

    private void IrAFacturacion()
    {
        Nav.NavigateTo("/configuracion?tab=facturacion");
    }
}