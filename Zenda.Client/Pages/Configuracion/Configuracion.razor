@page "/configuracion"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Zenda.Client.Components
@using Zenda.Core.DTOs

<div class="space-y-8 animate-in fade-in duration-500 pb-20">

    <div>
        <h1 class="text-3xl font-bold text-primary tracking-tighter font-headline">Configuración</h1>
        <p class="text-on-surface-variant text-sm">Gestioná tu cuenta personal y las preferencias de tu negocio.</p>
    </div>

    <div class="flex flex-col md:flex-row gap-8 items-start">

        <div class="w-full md:w-64 flex-shrink-0 space-y-2">
            <button @onclick='() => CambiarPestaña("perfil")'
                    class="w-full flex items-center gap-3 px-5 py-4 rounded-2xl font-bold transition-all @(pestañaActiva == "perfil" ? "bg-primary text-white shadow-lg shadow-primary/20" : "bg-transparent text-on-surface-variant hover:bg-surface-container-low hover:text-primary")">
                <span class="material-symbols-outlined text-[20px]">person</span>
                Mi Perfil
            </button>

            <button @onclick='() => CambiarPestaña("negocio")'
                    class="w-full flex items-center gap-3 px-5 py-4 rounded-2xl font-bold transition-all @(pestañaActiva == "negocio" ? "bg-primary text-white shadow-lg shadow-primary/20" : "bg-transparent text-on-surface-variant hover:bg-surface-container-low hover:text-primary")">
                <span class="material-symbols-outlined text-[20px]">storefront</span>
                Mi Negocio
            </button>

            <button @onclick='() => CambiarPestaña("facturacion")'
                    class="w-full flex items-center gap-3 px-5 py-4 rounded-2xl font-bold transition-all @(pestañaActiva == "facturacion" ? "bg-primary text-white shadow-lg shadow-primary/20" : "bg-transparent text-on-surface-variant hover:bg-surface-container-low hover:text-primary")">
                <span class="material-symbols-outlined text-[20px]">credit_card</span>
                Facturación
            </button>
        </div>

        <div class="flex-grow w-full min-w-0 bg-white rounded-[2rem] md:rounded-[2.5rem] editorial-shadow border border-surface-container-high p-5 md:p-8 min-h-[400px]">

            @if (cargando)
            {
                <div class="h-full flex items-center justify-center py-20">
                    <div class="animate-spin rounded-full h-10 w-10 border-t-2 border-b-2 border-primary"></div>
                </div>
            }
            else
            {
                @if (!string.IsNullOrEmpty(mensajeExito))
                {
                    <div class="mb-6 p-4 bg-green-50 text-green-700 border border-green-200 rounded-2xl text-sm font-bold flex items-center gap-2 animate-in slide-in-from-top-2">
                        <span class="material-symbols-outlined">check_circle</span>
                        @mensajeExito
                    </div>
                }

                @if (!string.IsNullOrEmpty(mensajeError))
                {
                    <div class="mb-6 p-4 bg-red-50 text-red-600 border border-red-100 rounded-2xl text-sm font-bold flex items-center gap-2 animate-in slide-in-from-top-2">
                        <span class="material-symbols-outlined">error</span>
                        @mensajeError
                    </div>
                }

                @if (pestañaActiva == "perfil")
                {
                    <div class="animate-in fade-in slide-in-from-bottom-4 duration-500">
                        <div class="mb-8 flex items-center gap-4">
                            <div class="w-16 h-16 rounded-full bg-secondary-container text-primary flex items-center justify-center font-headline font-black text-2xl">
                                @ObtenerIniciales()
                            </div>
                            <div>
                                <h2 class="text-2xl font-headline font-bold text-primary">Tus datos personales</h2>
                                <p class="text-on-surface-variant text-sm">Actualizá tu información de acceso.</p>
                            </div>
                        </div>

                        <EditForm Model="perfilUsuario" OnValidSubmit="GuardarPerfil">
                            <DataAnnotationsValidator />

                            <div class="space-y-5">
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                                    <div class="flex flex-col gap-2">
                                        <label class="text-[10px] font-bold text-primary px-1 uppercase tracking-wider">Nombre</label>
                                        <InputText @bind-Value="perfilUsuario.Nombre" class="input-zenda" placeholder="Tu nombre" />
                                        <ValidationMessage For="@(() => perfilUsuario.Nombre)" class="text-error text-[10px] font-bold px-1" />
                                    </div>
                                    <div class="flex flex-col gap-2">
                                        <label class="text-[10px] font-bold text-primary px-1 uppercase tracking-wider">Apellido</label>
                                        <InputText @bind-Value="perfilUsuario.Apellido" class="input-zenda" placeholder="Tu apellido" />
                                    </div>
                                </div>

                                <div class="flex flex-col gap-2">
                                    <label class="text-[10px] font-bold text-primary px-1 uppercase tracking-wider">Teléfono</label>
                                    <InputText @bind-Value="perfilUsuario.Telefono" class="input-zenda" placeholder="Ej: +54 11 1234 5678" />
                                </div>

                                <div class="flex flex-col gap-2">
                                    <label class="text-[10px] font-bold text-on-surface-variant px-1 uppercase tracking-wider flex items-center gap-1">
                                        Email de acceso <span class="material-symbols-outlined text-[14px]">lock</span>
                                    </label>
                                    <input value="@emailUsuario" disabled class="input-zenda opacity-60 cursor-not-allowed bg-surface-container-low" />
                                    <p class="text-[10px] text-on-surface-variant px-1">Para cambiar tu email, contactá a soporte.</p>
                                </div>

                                <div class="pt-6 border-t border-surface-container-high flex justify-end">
                                    <button type="submit" disabled="@guardando"
                                            class="px-8 py-4 bg-primary text-white font-bold rounded-2xl hover:brightness-110 active:scale-95 transition-all flex justify-center items-center gap-2 disabled:opacity-50">
                                        @if (guardando)
                                        {
                                            <div class="animate-spin rounded-full h-5 w-5 border-b-2 border-white"></div>
                                            <span>Guardando...</span>
                                        }
                                        else
                                        {
                                            <span>Guardar Cambios</span>
                                        }
                                    </button>
                                </div>
                            </div>
                        </EditForm>
                    </div>
                }

                @if (pestañaActiva == "negocio")
                {
                    <div class="animate-in fade-in slide-in-from-bottom-4 duration-500">
                        <div class="mb-8 flex items-center gap-4">
                            <div class="relative group cursor-pointer">
                                @* Si hay una imagen (preview local o URL de la base de datos), la mostramos *@
                                @if (!string.IsNullOrEmpty(logoPreviewUrl) || !string.IsNullOrEmpty(perfilNegocio.LogoUrl))
                                {
                                    <img src="@(logoPreviewUrl ?? perfilNegocio.LogoUrl)" alt="Logo Negocio"
                                         class="w-20 h-20 rounded-full object-cover border-2 border-surface-container-high group-hover:brightness-75 transition-all shadow-sm" />
                                }
                                else
                                {
                                    <div class="w-20 h-20 rounded-full bg-surface-container-low text-on-surface-variant flex items-center justify-center border-2 border-dashed border-surface-container-high group-hover:bg-primary/5 transition-all">
                                        <span class="material-symbols-outlined text-3xl">add_photo_alternate</span>
                                    </div>
                                }

                                @* Overlay al pasar el mouse *@
                                <div class="absolute inset-0 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-black/40">
                                    <span class="material-symbols-outlined text-white">upload</span>
                                </div>

                                @* Input invisible que cubre toda la zona circular *@
                                <InputFile OnChange="CargarPreviewLogo" accept=".jpg,.jpeg,.png,.webp"
                                           class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" />
                            </div>

                            @if (subiendoLogo)
                            {
                                <div class="text-[10px] text-primary font-bold flex items-center gap-1 mt-2 animate-pulse">
                                    <span class="material-symbols-outlined text-[14px]">cloud_upload</span> Subiendo...
                                </div>
                            }
                            <div>
                                <h2 class="text-2xl font-headline font-bold text-primary">Tu Negocio</h2>
                                <p class="text-on-surface-variant text-sm">Gestioná tu marca y tu enlace de reservas.</p>
                            </div>
                        </div>

                        <EditForm Model="perfilNegocio" OnValidSubmit="GuardarNegocio">
                            <DataAnnotationsValidator />

                            <div class="space-y-6">
                                <div class="flex flex-col gap-2">
                                    <label class="text-[10px] font-bold text-primary px-1 uppercase tracking-wider">Nombre del Negocio</label>
                                    <InputText @bind-Value="perfilNegocio.Nombre" class="input-zenda" placeholder="Ej: Zenda Barber" />
                                </div>

                                <div class="flex flex-col gap-2">
                                    <label class="text-[10px] font-bold text-primary px-1 uppercase tracking-wider">Tu Enlace (Slug)</label>
                                    <div class="relative flex items-center">
                                        <div class=" left-4 text-on-surface-variant/50 font-bold pointer-events-none">
                                            zenda.app/
                                        </div>

                                        <input value="@perfilNegocio.Slug" @oninput="OnSlugInput"
                                               class="input-zenda pl-[100px] font-bold text-primary" placeholder="tu-negocio" />

                                        @* Iconos de validación en tiempo real *@
                                        <div class="absolute right-4 flex items-center">
                                            @if (validandoSlug)
                                            {
                                                <div class="animate-spin rounded-full h-5 w-5 border-t-2 border-b-2 border-primary"></div>
                                            }
                                            else if (slugDisponible == true)
                                            {
                                                <span class="material-symbols-outlined text-green-600 font-bold" title="¡Enlace disponible!">check_circle</span>
                                            }
                                            else if (slugDisponible == false)
                                            {
                                                <span class="material-symbols-outlined text-error font-bold" title="Enlace no disponible">cancel</span>
                                            }
                                        </div>
                                    </div>

                                    @* Mensaje de ayuda debajo del input *@
                                    @if (slugDisponible == false)
                                    {
                                        <p class="text-error text-[10px] font-bold px-1 flex items-center gap-1">
                                            <span class="material-symbols-outlined text-[14px]">warning</span>
                                            Este enlace ya está siendo usado por otro negocio. Elegí otro.
                                        </p>
                                    }
                                    else
                                    {
                                        <p class="text-on-surface-variant text-[10px] px-1">
                                            Solo se permiten letras minúsculas, números y guiones.
                                        </p>
                                    }
                                </div>

                                @* ... (Código anterior de Nombre y Slug) ... *@

                                <hr class="border-surface-container-high my-6" />

                                <div>
                                    <h3 class="text-lg font-headline font-bold text-primary mb-1">Operativa del Negocio</h3>
                                    <p class="text-on-surface-variant text-xs mb-4">Configurá cómo funciona tu sistema de reservas.</p>
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                                    @* Selector de Rubro *@
                                    <div class="flex flex-col gap-2">
                                        <label class="text-[10px] font-bold text-primary px-1 uppercase tracking-wider">Rubro Principal</label>
                                        <select @bind="perfilNegocio.RubroId" class="input-zenda cursor-pointer appearance-none bg-white">
                                            <option value="" disabled>Seleccioná un rubro...</option>
                                            @foreach (var rubro in rubrosDisponibles)
                                            {
                                                <option value="@rubro.Id">@rubro.Nombre</option>
                                            }
                                        </select>
                                    </div>

                                    @* Selector de Grilla de Turnos (Intervalo) *@
                                    <div class="flex flex-col gap-2">
                                        <label class="text-[10px] font-bold text-primary px-1 uppercase tracking-wider">Intervalo de la Agenda</label>
                                        <select @bind="perfilNegocio.IntervaloTurnosMinutos" class="input-zenda cursor-pointer appearance-none bg-white">
                                            <option value="15">Cada 15 minutos</option>
                                            <option value="20">Cada 20 minutos</option>
                                            <option value="30">Cada 30 minutos (Recomendado)</option>
                                            <option value="60">Cada 1 hora</option>
                                        </select>
                                        <p class="text-on-surface-variant text-[10px] px-1">Define cómo se divide visualmente tu grilla.</p>
                                    </div>

                                    @* Selector de Anticipación Mínima *@
                                    <div class="flex flex-col gap-2">
                                        <label class="text-[10px] font-bold text-primary px-1 uppercase tracking-wider">Límite de Reserva Anticipada</label>
                                        <select @bind="perfilNegocio.AnticipacionMinimaHoras" class="input-zenda cursor-pointer appearance-none bg-white">
                                            <option value="0">Sin límite (Hasta el último minuto)</option>
                                            <option value="1">Al menos 1 hora antes</option>
                                            <option value="2">Al menos 2 horas antes</option>
                                            <option value="12">Al menos 12 horas antes</option>
                                            <option value="24">Al menos 1 día antes</option>
                                        </select>
                                    </div>

                                </div>

                                @* ... (El botón de Guardar Cambios queda igual abajo) ... *@

                                <div class="pt-6 border-t border-surface-container-high flex justify-end">
                                    @* Deshabilitamos si está guardando, validando o si el slug está ocupado *@
                                    <button type="submit" disabled="@(guardando || validandoSlug || slugDisponible == false)"
                                            class="px-8 py-4 bg-primary text-white font-bold rounded-2xl hover:brightness-110 active:scale-95 transition-all flex justify-center items-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed">
                                        @if (guardando)
                                        {
                                            <div class="animate-spin rounded-full h-5 w-5 border-b-2 border-white"></div>
                                            <span>Guardando...</span>
                                        }
                                        else
                                        {
                                            <span>Guardar Negocio</span>
                                        }
                                    </button>
                                </div>
                            </div>
                        </EditForm>
                    </div>
                }
                @if (pestañaActiva == "facturacion")
                {
                    <div class="animate-in fade-in slide-in-from-bottom-4 duration-500">
                        <div class="mb-8">
                            <h2 class="text-2xl font-headline font-bold text-primary">Suscripción y Facturación</h2>
                            <p class="text-on-surface-variant text-sm">Gestioná tu plan, límites y revisá tus pagos.</p>
                        </div>

                        @* 1. ESTADO ACTUAL Y USO *@
                        <div class="bg-surface-container-low p-6 rounded-3xl border border-surface-container-high mb-8 flex flex-col md:flex-row justify-between items-center gap-6">
                            <div>
                                <p class="text-[10px] font-bold text-on-surface-variant uppercase tracking-wider">Plan Actual</p>
                                <div class="flex items-center gap-2 mt-1">
                                    <span class="text-2xl font-black text-primary font-headline">@resumenFacturacion.PlanActualNombre</span>
                                    <span class="px-2 py-1 bg-green-100 text-green-700 text-[10px] font-bold rounded-md">@resumenFacturacion.Estado</span>
                                </div>
                                @if (resumenFacturacion.PlanActualNombre != "Single")
                                {
                                    <p class="text-xs text-on-surface-variant mt-1">Próximo vencimiento: <strong>@resumenFacturacion.FechaVencimiento.ToString("dd/MM/yyyy")</strong></p>
                                }
                            </div>

                            <div class="flex justify-center md:justify-end gap-4 md:gap-6 w-full md:w-auto">
                                <div class="text-center md:text-right">
                                    <p class="text-[10px] font-bold text-on-surface-variant uppercase tracking-wider mb-1">Sedes Usadas</p>
                                    <p class="text-lg font-bold text-primary">@resumenFacturacion.SedesUsadas <span class="text-sm text-on-surface-variant font-normal">/ @resumenFacturacion.SedesMaximas</span></p>
                                </div>
                                <div class="w-px bg-surface-container-high"></div>
                                <div class="text-center md:text-right">
                                    <p class="text-[10px] font-bold text-on-surface-variant uppercase tracking-wider mb-1">Profesionales</p>
                                    <p class="text-lg font-bold text-primary">@resumenFacturacion.ProfesionalesUsados <span class="text-sm text-on-surface-variant font-normal">/ @resumenFacturacion.ProfesionalesMaximos</span></p>
                                </div>
                            </div>
                        </div>

                        @* En la sección de Tarjetas *@
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
                            @foreach (var plan in planesDisponibles)
                            {
                                bool esPlanActual = plan.Nombre == resumenFacturacion.PlanActualNombre;
                                bool esRecomendado = plan.Nombre == "Business";

                                <div class="flex flex-col relative bg-white rounded-[2rem] p-6 border transition-all hover:shadow-lg @(esRecomendado ? "border-primary shadow-md" : "border-surface-container-high") @(esPlanActual ? "opacity-80" : "")">

                                    <h3 class="text-xl font-bold text-primary mb-2">@plan.Nombre</h3>
                                    <div class="mb-4">
                                        <span class="text-3xl font-black font-headline">@plan.PrecioTexto</span>
                                    </div>

                                    <ul class="space-y-3 mb-8 text-sm text-on-surface-variant flex-grow">
                                        @* ... tus li del plan ... *@
                                    </ul>

                                    <button @onclick="() => IniciarCambioPlan(plan)" disabled="@esPlanActual"
                                            class="w-full mt-auto py-3 rounded-xl font-bold transition-all @(esPlanActual ? "bg-surface-container-low text-on-surface-variant cursor-not-allowed" : esRecomendado ? "bg-primary text-white hover:brightness-110" : "bg-primary/10 text-primary hover:bg-primary/20")">
                                        @(esPlanActual ? "Plan Actual" : (plan.PrecioMensual > 0 ? "Mejorar Plan" : "Cambiar Plan"))
                                    </button>
                                </div>
                            }
                        </div>

                        <hr class="border-surface-container-high my-8" />

                        @* 3. HISTORIAL DE PAGOS *@
                        <div>
                            <h3 class="text-lg font-headline font-bold text-primary mb-4">Historial de Pagos</h3>
                            <div class="overflow-x-auto rounded-2xl border border-surface-container-high">
                                <table class="w-full text-sm text-left min-w-[600px]">
                                    <thead class="bg-surface-container-low text-on-surface-variant text-[10px] uppercase tracking-wider">
                                        <tr>
                                            <th class="px-6 py-4 rounded-tl-2xl">Fecha</th>
                                            <th class="px-6 py-4">Monto</th>
                                            <th class="px-6 py-4">Plan</th>
                                            <th class="px-6 py-4">Estado</th>
                                            <th class="px-6 py-4 text-right rounded-tr-2xl">Transacción</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-surface-container-high bg-white">
                                        @if (resumenFacturacion.Pagos.Any())
                                        {
                                            @foreach (var pago in resumenFacturacion.Pagos)
                                            {
                                                <tr class="hover:bg-surface-container-low/50 transition-colors">
                                                    <td class="px-6 py-4 whitespace-nowrap text-on-surface-variant">@pago.Fecha.ToString("dd/MM/yyyy")</td>
                                                    <td class="px-6 py-4 font-bold text-primary">@pago.Monto.ToString("C")</td>
                                                    <td class="px-6 py-4">@pago.PlanNombre</td>
                                                    <td class="px-6 py-4">
                                                        <span class="px-2 py-1 bg-green-100 text-green-700 text-[10px] font-bold rounded-md">@pago.Estado</span>
                                                    </td>
                                                    <td class="px-6 py-4 text-right text-xs font-mono text-on-surface-variant">#@pago.TransaccionId</td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="5" class="px-6 py-8 text-center text-on-surface-variant">
                                                    Aún no hay registros de pago.
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

<UpgradeModal @bind-Visible="mostrarModalUpgrade" Titulo="Confirmar cambio de plan" Icono="shopping_cart_checkout">
    @if (planSeleccionado != null)
    {
        <p class="mb-4">Estás a punto de suscribirte al plan <strong>@planSeleccionado.Nombre</strong>.</p>

        <div class="bg-surface-container-low p-4 rounded-2xl mb-6">
            <p class="text-xs uppercase tracking-wider text-on-surface-variant mb-1">Total a pagar hoy:</p>
            <p class="text-3xl font-black text-primary font-headline">@planSeleccionado.PrecioTexto</p>
        </div>

        <button @onclick="PagarConMercadoPago" class="w-full py-4 bg-[#009EE3] text-white rounded-2xl font-bold hover:brightness-110 active:scale-95 transition-all flex justify-center items-center gap-2">
            <span class="material-symbols-outlined">payments</span>
            Pagar con MercadoPago
        </button>
    }
</UpgradeModal>

<style>
    /* Reutilizamos la clase que armamos para Sedes para mantener consistencia visual */
    .input-zenda {
        width: 100%;
        padding: 1rem 1.25rem;
        border-radius: 1.25rem;
        background-color: #f1f5f0;
        border: 2px solid transparent;
        font-size: 0.9rem;
        transition: all 0.2s;
        color: #1a1a1a;
        outline: none;
    }

        .input-zenda:focus {
            border-color: #166534; /* Tu color primary */
            background-color: white;
        }
</style>