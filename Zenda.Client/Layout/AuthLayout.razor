@inherits LayoutComponentBase
@using Zenda.Client.Components

<div class="min-h-screen bg-slate-50 flex flex-col relative font-body">

    @* 🔥 HEADER MINIMALISTA (Branding + Escape) *@
    <header class="absolute top-0 left-0 right-0 p-6 flex justify-between items-center z-10 max-w-7xl mx-auto w-full">
        @* Logo de Zendy *@
        <div class="flex items-center gap-3">
            @* 
               Implementación del nuevo logo:
               - h-10 para dar un poco más de presencia visual que el div original.
               - object-contain para prevenir distorsiones.
               - alt="Zendy Logo" para accesibilidad (Principio de Diseño Inclusivo).
            *@
            <img src="img/zendy-logo.png"
                 alt="Zendy Logo"
                 class="w-10 h-10 object-contain drop-shadow-sm transition-transform hover:scale-105" />

            <span class="text-xl font-bold text-primary tracking-tighter font-headline">
                zendy
            </span>
        </div>

        @* Link de escape *@
        <a href="https://zendy.com.ar/" class="text-sm font-bold text-slate-400 hover:text-primary transition-colors flex items-center gap-1 group">
            <span class="material-symbols-outlined text-[18px] group-hover:-translate-x-1 transition-transform">arrow_back</span>
            <span class="hidden sm:inline">Volver a la web</span>
        </a>
    </header>

    @* FORMULARIO CENTRADO *@
    <main class="flex-1 flex items-center justify-center py-20 px-4 sm:px-6 lg:px-8">
        <div class="w-full max-w-md">
            @Body
        </div>
    </main>

    @* COMPONENTE GLOBAL DE SOPORTE *@
    <SupportWidget />

</div>