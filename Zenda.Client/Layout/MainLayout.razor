@inherits LayoutComponentBase
@inject NegocioClient NegocioService
@inject AppState State
@inject NavigationManager Nav
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject AuthenticationStateProvider AuthStateProvider
@implements IDisposable
@using Zenda.Client.Services
@using Microsoft.AspNetCore.Components.Authorization
@using Zenda.Core.DTOs
@using Zenda.Client.Auth

<div class="min-h-screen bg-background font-body">
    <nav class="fixed top-0 w-full z-50 bg-[#f7faf6]/80 backdrop-blur-xl border-b border-surface-container-high">
        <div class="flex justify-between items-center px-6 md:px-8 py-4 max-w-7xl mx-auto">

            <div class="flex items-center gap-2 md:gap-3">
                @* --- LOGO O INICIAL --- *@
                @if (!string.IsNullOrEmpty(State.CurrentNegocio?.LogoUrl))
                {
                    <img src="@State.CurrentNegocio.LogoUrl" alt="Logo"
                         class="w-8 h-8 md:w-10 md:h-10 rounded-full object-cover border border-surface-container-high shadow-sm shrink-0" />
                }
                else if (State.CurrentNegocio != null)
                {
                    <div class="w-8 h-8 md:w-10 md:h-10 rounded-full bg-primary text-white flex items-center justify-center font-bold text-base md:text-lg shadow-sm shrink-0">
                        @(State.CurrentNegocio.Nombre.FirstOrDefault())
                    </div>
                }

                @* --- NOMBRE DEL NEGOCIO (Ahora visible en todo tamaño) --- *@
                @* Eliminamos 'hidden sm:block' y ajustamos el tamaño de fuente en mobile *@
                <div class="text-lg md:text-2xl font-bold text-primary tracking-tighter font-headline truncate max-w-[120px] sm:max-w-none">
                    @(State.CurrentNegocio?.Nombre ?? "Zenda")
                </div>

                @* Badge (SaaS) *@
                @if (State.CurrentNegocio != null)
                {
                    <div class="flex items-center gap-2">
                        @* LA ETIQUETA DEL PLAN LEYENDO DESDE LA MEMORIA *@
                        @if (State.CurrentNegocio.PlanNombre == "Single")
                        {
                            <span class="px-2 py-0.5 bg-surface-container-high text-on-surface-variant text-[10px] uppercase font-bold rounded-lg tracking-wider">
                                @State.CurrentNegocio.PlanNombre
                            </span>
                        }
                        else
                        {
                            <span class="px-2 py-0.5 bg-primary/10 text-primary text-[10px] uppercase font-bold rounded-lg tracking-wider border border-primary/20">
                                @State.CurrentNegocio.PlanNombre
                            </span>
                        }
                    </div>
                }
            </div>
            <div class="hidden md:flex items-center gap-8">
                <NavLink href="" Match="NavLinkMatch.All" class="nav-desktop">Inicio</NavLink>

                <AuthorizeView>
                    <Authorized>
                        <NavLink href="prestadores" class="nav-desktop">Equipo</NavLink>
                        <NavLink href="turnos" class="nav-desktop">Agenda</NavLink>
                        <NavLink href="sedes" class="nav-desktop">Sedes</NavLink>
                        <NavLink href="servicios" class="nav-desktop">Servicios</NavLink>
                    </Authorized>
                    <NotAuthorized>
                        <NavLink href="reserva" class="nav-desktop">Sacar Turno</NavLink>
                    </NotAuthorized>
                </AuthorizeView>
            </div>

            <div class="flex items-center gap-3">
                <AuthorizeView>
                    <Authorized>
                        <NavLink href="configuracion" class="group flex items-center gap-2 hover:bg-surface-container-low p-1.5 pr-3 rounded-full transition-all cursor-pointer border border-transparent hover:border-surface-container-high">
                            <div class="text-right hidden sm:block pl-2">
                                <p class="text-xs font-bold text-primary leading-none group-hover:text-primary transition-colors">@context.User.Identity?.Name</p>
                                <p class="text-[10px] text-on-surface-variant font-medium">Mi Perfil</p>
                            </div>
                            <div class="w-9 h-9 md:w-10 md:h-10 rounded-full bg-secondary-container flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-all shadow-sm">
                                <span class="material-symbols-outlined text-xl">manage_accounts</span>
                            </div>
                        </NavLink>
                        <button @onclick="CerrarSesion" class="text-error hover:bg-error/10 rounded-full transition-colors flex items-center justify-center" title="Cerrar Sesión">
                            <span class="material-symbols-outlined">logout</span>
                        </button>
                    </Authorized>
                    <NotAuthorized>
                        <NavLink href="login" class="text-sm font-bold text-primary">Iniciar Sesión</NavLink>
                    </NotAuthorized>
                </AuthorizeView>
            </div>

        </div>
    </nav>

    <main class="pt-24 pb-24 md:pb-12 px-6 md:px-8 max-w-7xl mx-auto">
        @Body
    </main>

    <nav class="md:hidden fixed bottom-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-lg border-t border-surface-container-high pb-safe">
        <div class="flex justify-around items-center h-16">
            <NavLink href="" Match="NavLinkMatch.All" class="nav-mobile">
                <span class="material-symbols-outlined text-[24px]">dashboard</span>
                <span class="text-[10px] font-bold">Inicio</span>
            </NavLink>

            <AuthorizeView>
                <Authorized>
                    <NavLink href="prestadores" class="nav-mobile">
                        <span class="material-symbols-outlined text-[24px]">content_cut</span>
                        <span class="text-[10px] font-bold">Equipo</span>
                    </NavLink>

                    <NavLink href="turnos" class="nav-mobile">
                        <span class="material-symbols-outlined text-[24px]">calendar_month</span>
                        <span class="text-[10px] font-bold">Agenda</span>
                    </NavLink>

                    <NavLink href="sedes" class="nav-mobile">
                        <span class="material-symbols-outlined text-[24px]">location_on</span>
                        <span class="text-[10px] font-bold">Sedes</span>
                    </NavLink>

                    <NavLink href="servicios" class="nav-mobile">
                        <span class="material-symbols-outlined text-[24px]">inventory_2</span>
                        <span class="text-[10px] font-bold">Servicios</span>
                    </NavLink>
                </Authorized>
                <NotAuthorized>
                    <NavLink href="reserva" class="nav-mobile">
                        <span class="material-symbols-outlined text-[24px]">add_circle</span>
                        <span class="text-[10px] font-bold">Reservar</span>
                    </NavLink>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </nav>
</div>

<style>
    /* ... (Mismos estilos que ya tenías) ... */
    .nav-desktop {
        font-family: 'Inter', sans-serif;
        font-size: 0.875rem;
        font-weight: 600;
        color: #6b7280;
        transition: color 0.2s ease-in-out;
    }

        .nav-desktop:hover {
            color: #166534;
        }

        .nav-desktop.active {
            color: #166534;
            font-weight: 800;
        }

    .nav-mobile {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.25rem;
        width: 100%;
        height: 100%;
        color: #9ca3af;
        transition: color 0.2s ease-in-out;
    }

        .nav-mobile.active {
            color: #166534;
        }

    .pb-safe {
        padding-bottom: env(safe-area-inset-bottom);
    }
</style>

@code {
    protected override async Task OnInitializedAsync()
    {
        // 1. Suscripciones a eventos
        Nav.LocationChanged += OnLocationChanged;
        State.OnChange += StateHasChanged;

        try
        {
            // 2. Cargamos el negocio en el AppState si no está cargado aún
            // Verificamos si está autenticado primero para no pegarle a la API innecesariamente
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            if (authState.User.Identity?.IsAuthenticated == true && State.CurrentNegocio == null)
            {
                State.CurrentNegocio = await NegocioService.GetPerfilAsync();
                State.NotifyStateChanged(); // Avisamos que la UI debe actualizarse
            }
        }
        catch
        {
            // Fallback (ej: usuario no logueado, lo maneja el interceptor)
        }
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        // 🎯 EL FIX: Si va a login O a register, lo dejamos pasar sin pedirle token.
        if (e.Location.Contains("/login", StringComparison.OrdinalIgnoreCase) ||
            e.Location.Contains("/register", StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();

        if (authState.User.Identity == null || !authState.User.Identity.IsAuthenticated)
        {
            // Corregimos "/" por "/login" para que lo mande a la pantalla correcta
            Nav.NavigateTo("/login", forceLoad: true);
        }
    }

    private async Task CerrarSesion()
    {
        await LocalStorage.RemoveItemAsync("authToken");
        State.Clear();

        if (AuthStateProvider is CustomAuthStateProvider customProvider)
        {
            customProvider.NotifyUserLogout();
        }

        // 🎯 ACÁ ESTÁ EL FIX: Le decimos a Blazor "Navegá al login y RECARGÁ la pestaña"
        Nav.NavigateTo("/login", forceLoad: true);
    }

    public void Dispose()
    {
        // Limpiamos la memoria al destruir el layout
        State.OnChange -= StateHasChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }
}