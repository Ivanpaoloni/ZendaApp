@inherits LayoutComponentBase
@inject NegocioClient NegocioService
@inject AppState State
@inject NavigationManager Nav
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject AuthenticationStateProvider AuthStateProvider
@implements IDisposable

@using Zenda.Client.Services
@using Microsoft.AspNetCore.Components.Authorization
@using Zenda.Core.DTOs
@using Zenda.Client.Auth

<div class="min-h-screen bg-background font-body flex">

    @* ========================================== *@
    @* SIDEBAR VERTICAL (Solo visible en PC)      *@
    @* ========================================== *@
    <aside class="hidden md:flex flex-col w-64 fixed inset-y-0 left-0 bg-[#f7faf6]/80 backdrop-blur-xl border-r border-surface-container-high z-50">

        @* 1. Cabecera del Sidebar (Logo y Nombre) *@
        <div class="h-20 flex items-center gap-3 px-6 border-b border-surface-container-high shrink-0">
            @if (!string.IsNullOrEmpty(State.CurrentNegocio?.LogoUrl))
            {
                <img src="@State.CurrentNegocio.LogoUrl" alt="Logo" class="w-10 h-10 rounded-full object-cover border border-surface-container-high shadow-sm" />
            }
            else if (State.CurrentNegocio != null)
            {
                <div class="w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center font-bold text-lg shadow-sm">
                    @(State.CurrentNegocio.Nombre.FirstOrDefault())
                </div>
            }
            <div class="flex flex-col overflow-hidden">
                <span class="text-xl font-bold text-primary tracking-tighter font-headline truncate">
                    @(State.CurrentNegocio?.Nombre ?? "Zenda")
                </span>
                <span class="text-[9px] uppercase font-bold text-on-surface-variant tracking-wider">
                     @(State.CurrentNegocio?.PlanNombre ?? "")
                </span>
            </div>
        </div>

        @* 2. Links de Navegación *@
        <nav class="flex-1 px-4 py-6 space-y-2 overflow-y-auto">
            <NavLink href="" Match="NavLinkMatch.All" class="nav-sidebar">
                <span class="material-symbols-outlined text-[20px]">dashboard</span> Inicio
            </NavLink>

            <AuthorizeView>
                <Authorized>
                    <NavLink href="turnos" class="nav-sidebar">
                        <span class="material-symbols-outlined text-[20px]">calendar_month</span> Agenda
                    </NavLink>
                    <NavLink href="prestadores" class="nav-sidebar">
                        <span class="material-symbols-outlined text-[20px]">content_cut</span> Equipo
                    </NavLink>
                    <NavLink href="sedes" class="nav-sidebar">
                        <span class="material-symbols-outlined text-[20px]">location_on</span> Sedes
                    </NavLink>
                    <NavLink href="servicios" class="nav-sidebar">
                        <span class="material-symbols-outlined text-[20px]">inventory_2</span> Servicios
                    </NavLink>
                </Authorized>
            </AuthorizeView>
        </nav>

        @* 3. Pie del Sidebar (Perfil y Salir) *@
        <div class="p-4 border-t border-surface-container-high">
            <AuthorizeView>
                <Authorized>
                    @* Tarjeta de Mi Perfil con el ícono manage_accounts *@
                    <NavLink href="configuracion" class="group flex items-center gap-3 mb-3 p-2 rounded-xl hover:bg-surface-container-low transition-all border border-transparent hover:border-surface-container-high">
                        <div class="w-9 h-9 rounded-full bg-secondary-container flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-all shadow-sm shrink-0">
                            <span class="material-symbols-outlined text-[20px]">manage_accounts</span>
                        </div>
                        <div class="overflow-hidden">
                            <p class="text-xs font-bold text-primary truncate">@context.User.Identity?.Name</p>
                            <p class="text-[10px] text-on-surface-variant font-medium group-hover:text-primary transition-colors truncate">Configurar Perfil</p>
                        </div>
                    </NavLink>

                    @* Botón de Cerrar Sesión *@
                    <button @onclick="CerrarSesion" class="w-full flex items-center gap-2 px-3 py-2 text-sm font-bold text-error hover:bg-error/10 rounded-xl transition-colors">
                        <span class="material-symbols-outlined text-[20px]">logout</span> Cerrar Sesión
                    </button>
                </Authorized>
            </AuthorizeView>
        </div>
    </aside>

    @* ========================================== *@
    @* CONTENIDO PRINCIPAL (App)                  *@
    @* ========================================== *@
    <main class="flex-1 md:pl-64 min-h-screen flex flex-col">
        @* Header en móvil para que no quede pelado arriba *@
        <div class="md:hidden h-16 flex items-center px-6 bg-[#f7faf6]/90 backdrop-blur-md border-b border-surface-container-high sticky top-0 z-40 shrink-0">
            @if (!string.IsNullOrEmpty(State.CurrentNegocio?.LogoUrl))
            {
                <img src="@State.CurrentNegocio.LogoUrl" alt="Logo" class="w-8 h-8 rounded-full object-cover border border-surface-container-high shadow-sm mr-3" />
            }
            <span class="text-lg font-bold text-primary tracking-tighter font-headline truncate">
                @(State.CurrentNegocio?.Nombre ?? "Zenda")
            </span>
        </div>

        <div class="p-6 md:p-8 max-w-7xl mx-auto w-full pb-24 md:pb-12 flex-1">
            @Body
        </div>
    </main>

    @* ========================================== *@
    @* BARRA INFERIOR (Solo visible en Celulares) *@
    @* ========================================== *@
    <nav class="md:hidden fixed bottom-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-lg border-t border-surface-container-high pb-safe">
        <div class="flex justify-around items-center h-16">
            <NavLink href="" Match="NavLinkMatch.All" class="nav-mobile">
                <span class="material-symbols-outlined text-[24px]">dashboard</span>
                <span class="text-[10px] font-bold">Inicio</span>
            </NavLink>

            <AuthorizeView>
                <Authorized>
                    <NavLink href="prestadores" class="nav-mobile">
                        <span class="material-symbols-outlined text-[24px]">content_cut</span>
                        <span class="text-[10px] font-bold">Equipo</span>
                    </NavLink>

                    <NavLink href="turnos" class="nav-mobile">
                        <span class="material-symbols-outlined text-[24px]">calendar_month</span>
                        <span class="text-[10px] font-bold">Agenda</span>
                    </NavLink>

                    <NavLink href="sedes" class="nav-mobile">
                        <span class="material-symbols-outlined text-[24px]">location_on</span>
                        <span class="text-[10px] font-bold">Sedes</span>
                    </NavLink>

                    <NavLink href="servicios" class="nav-mobile">
                        <span class="material-symbols-outlined text-[24px]">inventory_2</span>
                        <span class="text-[10px] font-bold">Servicios</span>
                    </NavLink>
                </Authorized>
                <NotAuthorized>
                    <NavLink href="reserva" class="nav-mobile">
                        <span class="material-symbols-outlined text-[24px]">add_circle</span>
                        <span class="text-[10px] font-bold">Reservar</span>
                    </NavLink>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </nav>
</div>

<style>
    /* Estilos del Sidebar (PC) */
    .nav-sidebar {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 1rem;
        border-radius: 1rem;
        font-family: 'Inter', sans-serif;
        font-size: 0.875rem;
        font-weight: 600;
        color: #6b7280;
        transition: all 0.2s ease-in-out;
    }

        .nav-sidebar:hover {
            background-color: rgba(22, 101, 52, 0.05); /* primary con opacidad */
            color: #166534; /* primary */
        }

        .nav-sidebar.active {
            background-color: #166534; /* primary */
            color: white;
            box-shadow: 0 4px 12px rgba(22, 101, 52, 0.2);
        }

    /* Estilos de la Barra Inferior (Móvil) */
    .nav-mobile {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.25rem;
        width: 100%;
        height: 100%;
        color: #9ca3af;
        transition: color 0.2s ease-in-out;
    }

        .nav-mobile.active {
            color: #166534; /* primary */
        }

    .pb-safe {
        padding-bottom: env(safe-area-inset-bottom);
    }
</style>

@code {
    protected override async Task OnInitializedAsync()
    {
        // 1. Suscripciones a eventos
        Nav.LocationChanged += OnLocationChanged;
        State.OnChange += StateHasChanged;

        try
        {
            // 2. Cargamos el negocio en el AppState si no está cargado aún
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            if (authState.User.Identity?.IsAuthenticated == true && State.CurrentNegocio == null)
            {
                State.CurrentNegocio = await NegocioService.GetPerfilAsync();
                State.NotifyStateChanged();
            }
        }
        catch
        {
            // Fallback silencioso
        }
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        // 🎯 FIX: Dejamos pasar si va al login o register
        if (e.Location.Contains("/login", StringComparison.OrdinalIgnoreCase) ||
            e.Location.Contains("/register", StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();

        if (authState.User.Identity == null || !authState.User.Identity.IsAuthenticated)
        {
            Nav.NavigateTo("/login", forceLoad: true);
        }
    }

    private async Task CerrarSesion()
    {
        await LocalStorage.RemoveItemAsync("authToken");
        State.Clear();

        if (AuthStateProvider is CustomAuthStateProvider customProvider)
        {
            customProvider.NotifyUserLogout();
        }

        Nav.NavigateTo("/login", forceLoad: true);
    }

    public void Dispose()
    {
        State.OnChange -= StateHasChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }
}