@inherits LayoutComponentBase
@inject NegocioClient NegocioService
@inject AppState State
@inject NavigationManager Nav
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject AuthenticationStateProvider AuthStateProvider
@inject HttpClient Http
@implements IDisposable

@using Zenda.Client.Components
@using Zenda.Application.DTOs.Auth
@using Zenda.Client.Services
@using Microsoft.AspNetCore.Components.Authorization
@using Zenda.Core.DTOs
@using Zenda.Client.Auth

@* 1. ESCUDO RAÍZ: max-w-[100vw] y overflow-x-hidden *@
<div class="min-h-[100dvh] max-w-[100vw] overflow-x-hidden relative bg-background font-body flex">

    @* SIDEBAR VERTICAL (Solo visible en PC) *@
    <aside class="hidden md:flex flex-col w-64 fixed inset-y-0 left-0 bg-[#f7faf6]/80 backdrop-blur-xl border-r border-surface-container-high z-50">

        @* 1. Cabecera del Sidebar (Logo y Nombre) *@
        <div class="h-20 flex items-center gap-3 px-6 border-b border-surface-container-high shrink-0">
            @if (!string.IsNullOrEmpty(State.CurrentNegocio?.LogoUrl))
            {
                <img src="@State.CurrentNegocio.LogoUrl" alt="Logo" class="w-10 h-10 rounded-full object-cover border border-surface-container-high shadow-sm" />
            }
            else if (State.CurrentNegocio != null)
            {
                <div class="w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center font-bold text-lg shadow-sm">
                    @(State.CurrentNegocio.Nombre.FirstOrDefault())
                </div>
            }
            <div class="flex flex-col overflow-hidden">
                <span class="text-xl font-bold text-primary tracking-tighter font-headline truncate">
                    @(State.CurrentNegocio?.Nombre ?? "Zendy")
                </span>
                <span class="text-[9px] uppercase font-bold text-on-surface-variant tracking-wider">
                    @(State.CurrentNegocio?.PlanNombre ?? "")
                </span>
            </div>
        </div>

        @* 2. Links de Navegación *@
        <nav class="flex-1 px-4 py-6 space-y-2 overflow-y-auto">
            <NavLink href="" Match="NavLinkMatch.All" class="nav-sidebar">
                <span class="material-symbols-outlined text-[20px]">dashboard</span> Inicio
            </NavLink>

            <AuthorizeView>
                <Authorized>
                    <NavLink href="turnos" class="nav-sidebar">
                        <span class="material-symbols-outlined text-[20px]">calendar_month</span> Agenda
                    </NavLink>
                    <NavLink href="clientes" class="nav-sidebar">
                        <span class="material-symbols-outlined text-[20px]">groups</span> Clientes
                    </NavLink>
                    <NavLink href="prestadores" class="nav-sidebar">
                        <span class="material-symbols-outlined text-[20px]">content_cut</span> Equipo
                    </NavLink>
                    <NavLink href="sedes" class="nav-sidebar">
                        <span class="material-symbols-outlined text-[20px]">location_on</span> Sedes
                    </NavLink>
                    <NavLink href="servicios" class="nav-sidebar">
                        <span class="material-symbols-outlined text-[20px]">inventory_2</span> Servicios
                    </NavLink>
                    <NavLink href="caja" class="nav-sidebar">
                        <span class="material-symbols-outlined text-[20px]">point_of_sale</span> Caja Diaria
                    </NavLink>
                    @if (State.CurrentNegocio?.PlanNombre == "Single")
                    {
                        <NavLink href="reportes" class="nav-sidebar opacity-60 grayscale hover:opacity-100 hover:grayscale-0 group relative flex justify-between">
                            <div class="flex items-center gap-[0.75rem]">
                                <span class="material-symbols-outlined text-[20px]">bar_chart</span>
                                <span>Reportes</span>
                            </div>
                            <span class="material-symbols-outlined text-[14px] text-orange-500 group-hover:scale-110 transition-transform">lock</span>
                        </NavLink>
                    }
                    else
                    {
                        <NavLink href="reportes" class="nav-sidebar">
                            <span class="material-symbols-outlined text-[20px]">bar_chart</span> Reportes
                        </NavLink>
                    }
                </Authorized>
            </AuthorizeView>
        </nav>

        @* 3. Pie del Sidebar (Perfil y Salir) *@
        <div class="p-4 border-t border-surface-container-high">
            <AuthorizeView>
                <Authorized>
                    <NavLink href="configuracion" class="group flex items-center gap-3 mb-3 p-2 rounded-xl hover:bg-surface-container-low transition-all border border-transparent hover:border-surface-container-high">
                        <div class="w-9 h-9 rounded-full bg-secondary-container flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-all shadow-sm shrink-0">
                            <span class="material-symbols-outlined text-[20px]">manage_accounts</span>
                        </div>
                        <div class="overflow-hidden">
                            <p class="text-xs font-bold text-primary truncate">@context.User.Identity?.Name</p>
                            <p class="text-[10px] text-on-surface-variant font-medium group-hover:text-primary transition-colors truncate">Configurar Perfil</p>
                        </div>
                    </NavLink>

                    <button @onclick="CerrarSesion" class="w-full flex items-center gap-2 px-3 py-2 text-sm font-bold text-error hover:bg-error/10 rounded-xl transition-colors">
                        <span class="material-symbols-outlined text-[20px]">logout</span> Cerrar Sesión
                    </button>
                </Authorized>
            </AuthorizeView>
        </div>
    </aside>

    @* ========================================== *@
    @* CONTENIDO PRINCIPAL (App)                  *@
    @* ========================================== *@

    @* 2. ESCUDO DEL MAIN: pb-[70px] asegura que la barra inferior no tape nada, y max-w-[100vw] evita scroll *@
    <main class="flex-1 md:pl-64 min-h-[100dvh] max-w-[100vw] overflow-x-hidden flex flex-col pb-[70px] md:pb-0">

        @* Header en móvil *@
        <div class="md:hidden h-16 flex items-center justify-between px-6 bg-[#f7faf6]/95 backdrop-blur-md border-b border-surface-container-high sticky top-0 z-40 shrink-0">
            <div class="flex items-center gap-3 overflow-hidden">
                @if (!string.IsNullOrEmpty(State.CurrentNegocio?.LogoUrl))
                {
                    <img src="@State.CurrentNegocio.LogoUrl" alt="Logo" class="w-8 h-8 rounded-full object-cover border border-surface-container-high shadow-sm" />
                }
                <div class="flex flex-col overflow-hidden">
                    <span class="text-sm font-bold text-primary truncate leading-tight">
                        @(State.CurrentNegocio?.Nombre ?? "Zendy")
                    </span>
                    <span class="text-[8px] uppercase font-black text-on-surface-variant tracking-widest">
                        @(State.CurrentNegocio?.PlanNombre ?? "")
                    </span>
                </div>
            </div>

            <div class="flex items-center gap-4">
                <AuthorizeView>
                    <Authorized>
                        <NavLink href="configuracion" class="text-primary flex items-center justify-center">
                            <span class="material-symbols-outlined text-[22px]">manage_accounts</span>
                        </NavLink>
                        <button @onclick="CerrarSesion" class="text-error flex items-center justify-center">
                            <span class="material-symbols-outlined text-[22px]">logout</span>
                        </button>
                    </Authorized>
                </AuthorizeView>
            </div>
        </div>

        @* 🔥 BANNER DE VERIFICACIÓN 🔥 *@
        <AuthorizeView>
            <Authorized>
                @if (!context.User.HasClaim(c => c.Type == "email_verified" && c.Value == "true"))
                {
                    <div class="bg-orange-50 border-b border-orange-200 px-6 py-3 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-2 shadow-sm shrink-0">
                        <div class="flex items-center gap-3 text-orange-800 text-xs font-medium">
                            <span class="material-symbols-outlined text-[20px]">mark_email_unread</span>
                            <span>Tu cuenta no está verificada. Revisá tu bandeja de entrada para no perder acceso.</span>
                        </div>

                        <div class="flex items-center gap-4 mt-2 sm:mt-0">
                            <button @onclick="RefrescarEstado" disabled="@refrescando"
                                    class="text-[10px] font-black uppercase tracking-widest text-green-700 hover:text-green-900 hover:underline whitespace-nowrap transition-all disabled:opacity-50">
                                @(refrescando ? "Comprobando..." : "Ya lo confirmé")
                            </button>

                            <button @onclick="ReenviarEmailConfirmacion" disabled="@reenviandoEmail"
                                    class="text-[10px] font-black uppercase tracking-widest text-orange-700 hover:text-orange-900 hover:underline whitespace-nowrap transition-all disabled:opacity-50">
                                @(reenviandoEmail ? "Enviando..." : "Reenviar enlace")
                            </button>
                        </div>
                    </div>
                }
            </Authorized>
        </AuthorizeView>

        @* 3. ESCUDO INTERNO: Evita que el @Body empuje la página hacia afuera *@
        <div class="p-6 md:p-8 max-w-7xl mx-auto w-full flex-1 overflow-x-hidden">
            @Body
        </div>
    </main>

    @* ========================================== *@
    @* BARRA INFERIOR (Solo visible en Celulares) *@
    @* ========================================== *@
    <nav class="md:hidden fixed bottom-0 left-0 right-0 z-50 pb-safe">

        @* MENÚ DESPLEGABLE "MÁS" (Fondo oscuro + Lista) *@
        @if (mostrarMenuMovil)
        {
            @* Backdrop para cerrar al hacer clic afuera *@
            <div class="fixed inset-0 bg-black/20 backdrop-blur-sm -z-10" @onclick="CerrarMenuMovil"></div>

            @* Lista de opciones flotante *@
            <div class="absolute bottom-[72px] right-4 left-4 bg-white rounded-3xl p-2 shadow-xl border border-surface-container-high animate-in slide-in-from-bottom-4 fade-in duration-200">
                <AuthorizeView>
                    <Authorized>
                        <NavLink href="clientes" @onclick="CerrarMenuMovil" class="flex items-center gap-3 p-4 rounded-2xl hover:bg-surface-container-low transition-colors text-primary font-bold">
                            <span class="material-symbols-outlined text-[24px]">groups</span>
                            <span>Clientes</span>
                        </NavLink>

                        <NavLink href="prestadores" @onclick="CerrarMenuMovil" class="flex items-center gap-3 p-4 rounded-2xl hover:bg-surface-container-low transition-colors text-primary font-bold">
                            <span class="material-symbols-outlined text-[24px]">content_cut</span>
                            <span>Equipo</span>
                        </NavLink>

                        <NavLink href="sedes" @onclick="CerrarMenuMovil" class="flex items-center gap-3 p-4 rounded-2xl hover:bg-surface-container-low transition-colors text-primary font-bold">
                            <span class="material-symbols-outlined text-[24px]">location_on</span>
                            <span>Sedes</span>
                        </NavLink>

                        <NavLink href="servicios" @onclick="CerrarMenuMovil" class="flex items-center gap-3 p-4 rounded-2xl hover:bg-surface-container-low transition-colors text-primary font-bold">
                            <span class="material-symbols-outlined text-[24px]">inventory_2</span>
                            <span>Servicios</span>
                        </NavLink>
                        @if (State.CurrentNegocio?.PlanNombre == "Single")
                        {
                            <NavLink href="reportes" @onclick="CerrarMenuMovil" class="flex items-center justify-between p-4 rounded-2xl hover:bg-surface-container-low transition-all text-primary font-bold opacity-60 grayscale group">
                                <div class="flex items-center gap-3">
                                    <span class="material-symbols-outlined text-[24px]">bar_chart</span>
                                    <span>Reportes</span>
                                </div>
                                <span class="material-symbols-outlined text-[16px] text-orange-500">lock</span>
                            </NavLink>
                        }
                        else
                        {
                            <NavLink href="reportes" @onclick="CerrarMenuMovil" class="flex items-center gap-3 p-4 rounded-2xl hover:bg-surface-container-low transition-colors text-primary font-bold">
                                <span class="material-symbols-outlined text-[24px]">bar_chart</span>
                                <span>Reportes</span>
                            </NavLink>
                        }
                    </Authorized>
                    <NotAuthorized>
                        <NavLink href="reserva" @onclick="CerrarMenuMovil" class="flex items-center gap-3 p-4 rounded-2xl hover:bg-surface-container-low transition-colors text-primary font-bold">
                            <span class="material-symbols-outlined text-[24px]">add_circle</span>
                            <span>Reservar</span>
                        </NavLink>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        }

        @* BARRA PRINCIPAL FLOTANTE (Estilo Isla) *@
        <div class="mx-3 mb-3 bg-white/90 backdrop-blur-lg border border-surface-container-high rounded-[2rem] shadow-lg flex justify-around items-center h-16 px-2 relative z-10">

            <NavLink href="" Match="NavLinkMatch.All" class="nav-mobile" @onclick="CerrarMenuMovil">
                <span class="material-symbols-outlined text-[24px]">dashboard</span>
                <span class="text-[10px] font-bold">Inicio</span>
            </NavLink>

            <AuthorizeView>
                <Authorized>
                    <NavLink href="turnos" class="nav-mobile" @onclick="CerrarMenuMovil">
                        <span class="material-symbols-outlined text-[24px]">calendar_month</span>
                        <span class="text-[10px] font-bold">Agenda</span>
                    </NavLink>

                    <NavLink href="caja" class="nav-mobile" @onclick="CerrarMenuMovil">
                        <span class="material-symbols-outlined text-[24px]">point_of_sale</span>
                        <span class="text-[10px] font-bold">Caja</span>
                    </NavLink>
                </Authorized>
            </AuthorizeView>

            @* BOTÓN "MÁS" *@
            <button @onclick="ToggleMenuMovil" class="flex flex-col items-center justify-center gap-[0.25rem] w-full h-full transition-colors @(mostrarMenuMovil ? "text-primary" : "text-[#9ca3af]")">
                <span class="material-symbols-outlined text-[24px]">more_horiz</span>
                <span class="text-[10px] font-bold">Más</span>
            </button>

        </div>
    </nav>

</div>
<SupportWidget />

<style>
    /* Estilos del Sidebar (PC) */
    .nav-sidebar {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 1rem;
        border-radius: 1rem;
        font-family: 'Inter', sans-serif;
        font-size: 0.875rem;
        font-weight: 600;
        color: #6b7280;
        transition: all 0.2s ease-in-out;
    }

        .nav-sidebar:hover {
            background-color: rgba(22, 101, 52, 0.05); /* primary con opacidad */
            color: #166534; /* primary */
        }

        .nav-sidebar.active {
            background-color: #166534; /* primary */
            color: white;
            box-shadow: 0 4px 12px rgba(22, 101, 52, 0.2);
        }

    /* Estilos de la Barra Inferior (Móvil) */
    .nav-mobile {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.25rem;
        width: 100%;
        height: 100%;
        color: #9ca3af;
        transition: color 0.2s ease-in-out;
    }

        .nav-mobile.active {
            color: #166534; /* primary */
        }

    .pb-safe {
        padding-bottom: env(safe-area-inset-bottom);
    }
</style>

@code {
    private bool reenviandoEmail = false;
    private bool refrescando = false;
    private bool mostrarMenuMovil = false;

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += OnLocationChanged;
        State.OnChange += StateHasChanged;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();

            if (authState.User.Identity?.IsAuthenticated == true)
            {
                // 🔥 BÚSQUEDA IMPLACABLE DEL ROL:
                // Buscamos si la palabra "SuperAdmin" existe en CUALQUIER claim del token
                var esSuperAdmin = authState.User.Claims.Any(c => c.Value == "SuperAdmin");

                Console.WriteLine($"¿Es SuperAdmin?: {esSuperAdmin}");

                if (esSuperAdmin)
                {
                    var rutaActual = Nav.ToBaseRelativePath(Nav.Uri);
                    Console.WriteLine($"Ruta actual: '{rutaActual}'");

                    // Si está en la raíz (Home), lo pateamos al panel de Admin
                    if (string.IsNullOrEmpty(rutaActual))
                    {
                        Console.WriteLine("Redirigiendo a /admin...");
                        Nav.NavigateTo("admin"); // Sin la barra inicial a veces funciona mejor
                    }

                    return; // Cortamos para que no busque el perfil de negocio
                }

                // Lógica normal para dueños de peluquerías
                // 2. Lógica normal para dueños de peluquerías
                if (State.CurrentNegocio == null)
                {
                    try
                    {
                        State.CurrentNegocio = await NegocioService.GetPerfilAsync();

                        // Si por algún motivo devuelve null, también lo pateamos
                        if (State.CurrentNegocio == null)
                        {
                            await ForzarCierreSesion();
                            return;
                        }

                        State.NotifyStateChanged();
                    }
                    catch (Exception ex)
                    {
                        // 🔥 SI SALTA EL ERROR DE "CUENTA_SUSPENDIDA" O CUALQUIER 401
                        Console.WriteLine($"Error de sesión: {ex.Message}");
                        await ForzarCierreSesion();
                        return;
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error en Layout: {ex.Message}");
        }
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (e.Location.Contains("/login", StringComparison.OrdinalIgnoreCase) ||
            e.Location.Contains("/register", StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();

        if (authState.User.Identity == null || !authState.User.Identity.IsAuthenticated)
        {
            Nav.NavigateTo("/login", forceLoad: true);
        }
    }

    private async Task CerrarSesion()
    {
        await LocalStorage.RemoveItemAsync("authToken");
        State.Clear();

        if (AuthStateProvider is CustomAuthStateProvider customProvider)
        {
            customProvider.NotifyUserLogout();
        }

        Nav.NavigateTo("/login", forceLoad: true);
    }

    public void Dispose()
    {
        State.OnChange -= StateHasChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }

    private async Task ReenviarEmailConfirmacion()
    {
        if (reenviandoEmail) return;

        reenviandoEmail = true;
        StateHasChanged();

        try
        {
            var token = await LocalStorage.GetItemAsync<string>("authToken");

            if (string.IsNullOrEmpty(token)) return;

            var request = new HttpRequestMessage(HttpMethod.Post, "api/auth/resend-confirmation");
            request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            var response = await Http.SendAsync(request);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error de conexión: {ex.Message}");
        }
        finally
        {
            await Task.Delay(3000);
            reenviandoEmail = false;
            StateHasChanged();
        }
    }
    private async Task RefrescarEstado()
    {
        if (refrescando) return;

        refrescando = true;
        StateHasChanged();

        try
        {
            var tokenViejo = await LocalStorage.GetItemAsync<string>("authToken");

            if (string.IsNullOrEmpty(tokenViejo)) return;

            var request = new HttpRequestMessage(HttpMethod.Get, "api/auth/refresh-token");
            request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", tokenViejo);

            var response = await Http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<AuthResponseDto>();

                if (result != null && result.Success && !string.IsNullOrEmpty(result.Token))
                {
                    await LocalStorage.SetItemAsync("authToken", result.Token);
                    ((CustomAuthStateProvider)AuthStateProvider).NotifyUserAuthentication(result.Token);
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al refrescar estado: {ex.Message}");
        }
        finally
        {
            refrescando = false;
            StateHasChanged();
        }
    }

    private void ToggleMenuMovil()
    {
        mostrarMenuMovil = !mostrarMenuMovil;
    }

    private void CerrarMenuMovil()
    {
        mostrarMenuMovil = false;
    }

    private async Task ForzarCierreSesion()
    {
        await LocalStorage.RemoveItemAsync("authToken"); // Borramos el token

        if (AuthStateProvider is Zenda.Client.Auth.CustomAuthStateProvider customProvider)
        {
            customProvider.NotifyUserLogout();
        }

        Nav.NavigateTo("/login", forceLoad: true); // Lo pateamos al login
    }
}