@using Zenda.Core.DTOs
@using System.Text.RegularExpressions

@if (Sede != null)
{
    <!-- Diseño responsivo: Se acopla al fondo emulando un "Bottom Sheet" nativo -->
    <div class="mt-12 bg-white rounded-t-[2.5rem] p-6 md:p-8 editorial-shadow-up relative z-10 animate-in slide-in-from-bottom duration-700">
        <div class="max-w-md mx-auto">
            <h3 class="font-headline font-bold text-lg text-primary mb-4">Información del local</h3>

            <div class="space-y-4 mb-6 text-on-surface-variant text-sm font-body">

                <!-- Dirección -->
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-primary">location_on</span>
                    <span>@Sede.Direccion</span>
                </div>

                <!-- Botón de WhatsApp -->
                @if (Negocio != null && !string.IsNullOrEmpty(Negocio.Telefono))
                {
                    <a href="https://wa.me/@LimpiarNumeroForUrl(Negocio.Telefono)"
                       target="_blank"
                       rel="noopener noreferrer"
                       class="flex items-center justify-center gap-2 w-full bg-[#25D366] text-white p-3.5 rounded-2xl font-headline font-bold shadow-lg shadow-[#25D366]/30 hover:bg-[#1ebe57] active:scale-95 transition-all text-decoration-none mt-2">

                        <!-- SVG de WhatsApp optimizado -->
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c-.003 1.396.366 2.76 1.056 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c.004-3.639 2.961-6.592 6.608-6.592A6.56 6.56 0 0 1 14.6 7.926c-.004 3.639-2.961 6.592-6.606 6.592z" />
                            <path d="M11.854 9.665c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232z" />
                        </svg>
                        Escribinos por WhatsApp
                    </a>
                }
            </div>

            <!-- Mapa embebido con aspect-ratio de Tailwind -->
            <div class="w-full aspect-video rounded-2xl overflow-hidden bg-surface-container-low shadow-inner">
                <iframe src="https://maps.google.com/maps?q=@Uri.EscapeDataString(Sede.Direccion)&t=&z=15&ie=UTF8&iwloc=&output=embed"
                        class="w-full h-full border-0"
                        loading="lazy">
                </iframe>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public SedeReadDto? Sede { get; set; }

    [Parameter]
    public NegocioReadDto? Negocio { get; set; }

    /// <summary>
    /// Elimina espacios, guiones y caracteres no numéricos del teléfono
    /// para asegurar la compatibilidad con el formato de wa.me
    /// </summary>
    private string LimpiarNumeroForUrl(string? telefonoStr)
    {
        if (string.IsNullOrWhiteSpace(telefonoStr)) return string.Empty;

        // Expresión regular que reemplaza cualquier cosa que NO sea un dígito numérico (\d) por vacío.
        return Regex.Replace(telefonoStr, @"[^\d]", "");
    }
}