@using Zenda.Core.DTOs

@if (Sede != null)
{
    <!-- Diseño responsivo: Se acopla al fondo emulando un "Bottom Sheet" nativo -->
    <div class="mt-12 bg-white rounded-t-[2.5rem] p-6 md:p-8 editorial-shadow-up relative z-10 animate-in slide-in-from-bottom duration-700">
        <div class="max-w-md mx-auto">
            <h3 class="font-headline font-bold text-lg text-primary mb-4">Información del local</h3>

            <div class="space-y-3 mb-6 text-on-surface-variant text-sm font-body">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-primary">location_on</span>
                    <span>@Sede.Direccion</span>
                </div>

                @if (Negocio != null && !string.IsNullOrEmpty(Negocio.Telefono))
                {
                    <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-primary">call</span>
                        <span>@Negocio.Telefono</span>
                    </div>
                }
            </div>

            <!-- Mapa embebido con aspect-ratio de Tailwind -->
            <div class="w-full aspect-video rounded-2xl overflow-hidden bg-surface-container-low shadow-inner">
                <iframe src="https://maps.google.com/maps?q=@Uri.EscapeDataString(Sede.Direccion)&t=&z=15&ie=UTF8&iwloc=&output=embed"
                        class="w-full h-full border-0"
                        loading="lazy">
                </iframe>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public SedeReadDto? Sede { get; set; }

    [Parameter]
    public NegocioReadDto? Negocio { get; set; }
}