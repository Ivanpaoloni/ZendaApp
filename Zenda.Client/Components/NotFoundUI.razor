@inject NavigationManager Nav

<div class="min-h-[80vh] flex flex-col items-center justify-center text-center px-6 animate-in fade-in zoom-in duration-500">
    <div class="w-24 h-24 bg-surface-container-low text-on-surface-variant rounded-[2rem] flex items-center justify-center mb-6 shadow-sm rotate-12">
        <span class="material-symbols-outlined text-6xl">travel_explore</span>
    </div>

    <h1 class="text-7xl font-headline font-black text-primary tracking-tighter mb-2">404</h1>
    <h2 class="text-2xl font-bold text-primary mb-4">Página no encontrada</h2>

    <p class="text-on-surface-variant max-w-sm mx-auto mb-8 text-sm">
        Parece que te perdiste. El enlace puede estar roto, el negocio ya no existe o la URL está mal escrita.
    </p>

    <button @onclick='() => Nav.NavigateTo("https://zendalanding.onrender.com/")'
            class="px-8 py-4 bg-primary text-white font-bold rounded-2xl shadow-xl shadow-primary/20 hover:scale-105 transition-all flex items-center gap-2">
        <span class="material-symbols-outlined">home</span>
        Volver al inicio
    </button>
</div>