@using Zenda.Core.DTOs
@using Zenda.Client.Services
@inject ClienteClient ClienteService
@inject SedeClient SedeService
@inject PrestadorClient PrestadorService
@inject ServicioClient ServicioService
@inject TurnoClient TurnoService

@if (Visible)
{
    <div class="fixed inset-0 z-[100] flex justify-end">
        <div class="absolute inset-0 bg-black/20 backdrop-blur-sm animate-in fade-in duration-300" @onclick="Cerrar"></div>

        <div class="relative w-full max-w-md bg-white h-full shadow-2xl flex flex-col animate-in slide-in-from-right duration-300">

            <div class="p-6 border-b border-surface-container flex items-center justify-between bg-surface-container-low/50 shrink-0">
                <div>
                    <h3 class="font-headline font-bold text-xl text-primary">Nuevo Turno</h3>
                    <p class="text-xs text-on-surface-variant mt-1">Carga manual para agenda</p>
                </div>
                <button @onclick="Cerrar" class="w-8 h-8 flex items-center justify-center rounded-full bg-surface-container-high text-on-surface-variant hover:text-primary transition-colors">
                    <span class="material-symbols-outlined text-sm">close</span>
                </button>
            </div>

            <div class="flex-1 overflow-y-auto p-6">
                @if (cargandoCatalogos)
                {
                    <div class="flex justify-center py-10">
                        <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
                    </div>
                }
                else
                {
                    <EditForm Model="dto" OnValidSubmit="GuardarTurno">
                        <DataAnnotationsValidator />

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="mb-6 p-4 bg-error/10 text-error rounded-2xl text-sm font-bold flex items-center gap-2">
                                <span class="material-symbols-outlined text-lg">error</span>
                                @errorMessage
                            </div>
                        }

                        <div class="space-y-6">

                            @* 1. CLIENTE *@
                            <div class="bg-surface-container-low p-5 rounded-3xl border border-surface-container-high">
                                <h4 class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-4">1. Datos del Cliente</h4>

                                <div class="space-y-4">
                                    <div>
                                        <label class="block text-xs font-bold text-primary mb-1 ml-2">Nombre / Buscar Cliente</label>
                                        <input type="text" value="@busquedaCliente" @oninput="OnClienteInput" list="clientes-list" placeholder="Ej: Juan Pérez"
                                               class="w-full p-4 bg-white rounded-2xl border border-surface-container-high focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-sm" />

                                        <datalist id="clientes-list">
                                            @foreach (var c in clientesDb)
                                            {
                                                <option value="@c.Nombre">@c.Telefono - @c.Email</option>
                                            }
                                        </datalist>
                                    </div>

                                    @if (dto.ClienteId == null)
                                    {
                                        <div class="grid grid-cols-2 gap-3 animate-in fade-in zoom-in-95 duration-200">
                                            <div>
                                                <label class="block text-xs font-bold text-primary mb-1 ml-2">Teléfono <span class="text-on-surface-variant font-normal">(Opc)</span></label>
                                                <input type="text" @bind="dto.NuevoClienteTelefono" placeholder="Opcional"
                                                       class="w-full p-4 bg-white rounded-2xl border border-surface-container-high focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-sm" />
                                            </div>
                                            <div>
                                                <label class="block text-xs font-bold text-primary mb-1 ml-2">Email <span class="text-on-surface-variant font-normal">(Opc)</span></label>
                                                <input type="email" @bind="dto.NuevoClienteEmail" placeholder="Opcional"
                                                       class="w-full p-4 bg-white rounded-2xl border border-surface-container-high focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-sm" />
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="p-3 bg-green-50 text-green-700 rounded-xl text-xs font-bold flex items-center gap-2 border border-green-200 animate-in fade-in zoom-in-95 duration-200">
                                            <span class="material-symbols-outlined text-sm">check_circle</span>
                                            Cliente vinculado.
                                            <button type="button" @onclick="LimpiarCliente" class="ml-auto underline hover:text-green-800">Cambiar</button>
                                        </div>
                                    }
                                </div>
                            </div>

                            @* 2. SEDE, PROFESIONAL Y SERVICIO *@
                            <div>
                                <h4 class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-4 ml-2">2. Sucursal y Profesional</h4>

                                @* Sede (Oculto si solo hay 1) *@
                                @if (sedesDb.Count > 1)
                                {
                                    <select value="@sedeSeleccionadaId" @onchange="OnSedeChanged" class="w-full p-4 bg-white rounded-2xl border border-surface-container-high focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-sm mb-4">
                                        <option value="@Guid.Empty">Seleccioná una sucursal...</option>
                                        @foreach (var s in sedesDb)
                                        {
                                            <option value="@s.Id">@s.Nombre</option>
                                        }
                                    </select>
                                }

                                @* Profesional *@
                                <select value="@dto.PrestadorId" @onchange="OnPrestadorChanged" disabled="@(sedeSeleccionadaId == Guid.Empty)"
                                        class="w-full p-4 bg-white rounded-2xl border border-surface-container-high focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-sm mb-4 disabled:opacity-50">
                                    <option value="@Guid.Empty">Seleccioná un profesional...</option>
                                    @foreach (var p in prestadoresDeSede)
                                    {
                                        <option value="@p.Id">@p.Nombre</option>
                                    }
                                </select>

                                @* Servicio (Filtrado por los que ofrece el profesional) *@
                                <select @bind="dto.ServicioId" disabled="@(dto.PrestadorId == Guid.Empty)"
                                        class="w-full p-4 bg-white rounded-2xl border border-surface-container-high focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-sm disabled:opacity-50">
                                    <option value="@Guid.Empty">Seleccioná un servicio...</option>
                                    @foreach (var s in serviciosFiltrados)
                                    {
                                        <option value="@s.Id">@s.Nombre (@s.DuracionMinutos min - $@s.Precio)</option>
                                    }
                                </select>
                            </div>

                            @* 3. FECHA Y HORA *@
                            <div class="grid grid-cols-2 gap-3">
                                <div>
                                    <label class="block text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-2 ml-2">3. Fecha</label>
                                    <input type="date" @bind="fechaSeleccionada"
                                           class="w-full p-4 bg-white rounded-2xl border border-surface-container-high focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-sm font-bold" />
                                </div>
                                <div>
                                    <label class="block text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-2 ml-2">Hora (Local)</label>
                                    <input type="time" @bind="horaSeleccionada"
                                           class="w-full p-4 bg-white rounded-2xl border border-surface-container-high focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-sm font-bold" />
                                </div>
                            </div>

                        </div>

                        <div class="mt-8 mb-4">
                            <button type="submit" disabled="@(guardando || dto.ServicioId == Guid.Empty || dto.PrestadorId == Guid.Empty)"
                                    class="w-full py-4 bg-primary text-white rounded-2xl font-headline font-bold shadow-md hover:brightness-110 active:scale-95 transition-all flex justify-center items-center gap-2 disabled:opacity-50 disabled:active:scale-100">
                                @if (guardando)
                                {
                                    <div class="animate-spin rounded-full h-5 w-5 border-t-2 border-b-2 border-white"></div>
                                    <span>Agendando...</span>
                                }
                                else
                                {
                                    <span class="material-symbols-outlined">event_available</span>
                                    <span>Agendar Turno</span>
                                }
                            </button>
                        </div>
                    </EditForm>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public EventCallback OnTurnoGuardado { get; set; }

    private TurnoAdminCreateDto dto = new();
    private bool cargandoCatalogos = true;
    private bool guardando = false;
    private string errorMessage = "";

    // Bases de datos maestras para este componente
    private List<ClienteReadDto> clientesDb = new();
    private List<SedeReadDto> sedesDb = new();

    // Listas dinámicas en cascada
    private Guid sedeSeleccionadaId = Guid.Empty;
    private List<PrestadorReadDto> prestadoresDeSede = new();
    private List<ServicioPublicoDto> serviciosDeSede = new();

    // Propiedad computada: Filtra los servicios de la sede para mostrar SOLO los que realiza el profesional elegido
    private IEnumerable<ServicioPublicoDto> serviciosFiltrados =>
        dto.PrestadorId == Guid.Empty
            ? new List<ServicioPublicoDto>()
            : serviciosDeSede.Where(s =>
                prestadoresDeSede.FirstOrDefault(p => p.Id == dto.PrestadorId)?.Servicios?.Any(ps => ps.Id == s.Id) == true);

    // Estado UI
    private string busquedaCliente = "";
    private DateTime fechaSeleccionada = DateTime.Today;
    private TimeOnly horaSeleccionada = TimeOnly.FromDateTime(DateTime.Now);

    protected override async Task OnParametersSetAsync()
    {
        if (Visible && !clientesDb.Any())
        {
            await CargarDatosIniciales();
        }
    }

    private async Task CargarDatosIniciales()
    {
        cargandoCatalogos = true;
        try
        {
            // 1. Cargamos Clientes y Sedes (Nivel 0 de la cascada)
            var tClientes = ClienteService.GetAll();
            var tSedes = SedeService.GetAll();

            await Task.WhenAll(tClientes, tSedes);

            clientesDb = tClientes.Result?.ToList() ?? new();
            sedesDb = tSedes.Result?.ToList() ?? new();

            // Si hay una sola sede, evitamos que el usuario tenga que hacer el click manual
            if (sedesDb.Count == 1)
            {
                await SeleccionarSede(sedesDb.First().Id);
            }
        }
        catch
        {
            errorMessage = "Error al cargar datos. Refresque la pantalla.";
        }
        finally
        {
            cargandoCatalogos = false;
        }
    }

    // ==========================================
    // LOGICA EN CASCADA (Sede -> Prestador -> Servicio)
    // ==========================================
    private async Task OnSedeChanged(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out Guid id) && id != Guid.Empty)
        {
            await SeleccionarSede(id);
        }
        else
        {
            sedeSeleccionadaId = Guid.Empty;
            prestadoresDeSede.Clear();
            serviciosDeSede.Clear();
            dto.PrestadorId = Guid.Empty;
            dto.ServicioId = Guid.Empty;
        }
    }

    private async Task SeleccionarSede(Guid id)
    {
        sedeSeleccionadaId = id;
        dto.PrestadorId = Guid.Empty;
        dto.ServicioId = Guid.Empty;

        // Reutilizamos los métodos de tu flujo público para cargar lo asociado a esta sede
        var tPrestadores = PrestadorService.GetPublicBySede(id);
        var tServicios = ServicioService.GetServiciosPublicosPorSede(id);

        await Task.WhenAll(tPrestadores, tServicios);

        prestadoresDeSede = tPrestadores.Result?.ToList() ?? new();
        serviciosDeSede = tServicios.Result?.ToList() ?? new();
    }

    private void OnPrestadorChanged(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out Guid id) && id != Guid.Empty)
        {
            dto.PrestadorId = id;
            dto.ServicioId = Guid.Empty; // Reseteamos el servicio al cambiar de profesional
        }
        else
        {
            dto.PrestadorId = Guid.Empty;
            dto.ServicioId = Guid.Empty;
        }
    }

    // ==========================================
    // AUTOCOMPLETE DEL CLIENTE
    // ==========================================
    private void OnClienteInput(ChangeEventArgs e)
    {
        busquedaCliente = e.Value?.ToString() ?? "";

        var matchExacto = clientesDb.FirstOrDefault(c => c.Nombre.Equals(busquedaCliente, StringComparison.OrdinalIgnoreCase));

        if (matchExacto != null)
        {
            dto.ClienteId = matchExacto.Id;
            dto.NuevoClienteNombre = null;
        }
        else
        {
            dto.ClienteId = null;
            dto.NuevoClienteNombre = busquedaCliente;
        }
    }

    private void LimpiarCliente()
    {
        dto.ClienteId = null;
        busquedaCliente = "";
        dto.NuevoClienteNombre = "";
    }

    // ==========================================
    // GUARDAR Y CERRAR
    // ==========================================
    private async Task GuardarTurno()
    {
        if (guardando) return;

        guardando = true;
        errorMessage = "";

        try
        {
            dto.FechaHoraInicio = fechaSeleccionada.Date.Add(horaSeleccionada.ToTimeSpan());

            await TurnoService.CrearTurnoAdmin(dto);

            await Cerrar();
            await OnTurnoGuardado.InvokeAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            guardando = false;
        }
    }

    private async Task Cerrar()
    {
        dto = new();
        busquedaCliente = "";
        errorMessage = "";
        fechaSeleccionada = DateTime.Today;
        horaSeleccionada = TimeOnly.FromDateTime(DateTime.Now);

        if (sedesDb.Count > 1)
        {
            // Si hay varias sedes, reseteamos la cascada
            sedeSeleccionadaId = Guid.Empty;
            prestadoresDeSede.Clear();
            serviciosDeSede.Clear();
        }

        Visible = false;
        await VisibleChanged.InvokeAsync(false);
    }
}