@inject IConfiguration Config

<div class="fixed bottom-24 md:bottom-6 right-4 md:right-6 z-50 flex items-center">
    
    <a href="@GetWhatsAppLink()" 
       target="_blank" 
       class="group relative flex items-center justify-center w-14 h-14 bg-[#25D366] text-white rounded-full shadow-lg hover:shadow-xl hover:-translate-y-1 active:scale-95 transition-all duration-300 editorial-shadow">
        
        <i class="fa-brands fa-whatsapp text-3xl"></i>

        <span class="hidden md:block absolute right-16 px-3 py-2 bg-on-surface text-background text-sm font-body font-medium rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none whitespace-nowrap">
            ¿Necesitas ayuda?
        </span>
    </a>
</div>

@code {
    private string GetWhatsAppLink()
    {
        var number = Config["SupportSettings:WhatsAppNumber"] ?? "5491100000000";
        var message = Uri.EscapeDataString(Config["SupportSettings:DefaultMessage"] ?? "Hola, necesito ayuda con ZendaApp.");
        return $"https://wa.me/{number}?text={message}";
    }
}
